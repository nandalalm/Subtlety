<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product View - SUBTLETY</title>
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/styles/user/single-product.css">
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <style>
    body>section.single-product-section>div>div:nth-child(1)>a {
      color: black !important;
    }

    body>section.single-product-section>div>div:nth-child(1)>a:hover {
      color: #9135ED !important;
    }

    .out-of-stock {
      opacity: 0.5;
    }

    .out-of-stock-label {
      position: absolute;
      top: 10px;
      right: 10px;
      background-color: rgba(255, 0, 0, 0.7);
      color: white;
      padding: 5px 10px;
      border-radius: 5px;
      font-weight: bold;
      z-index: 1;
    }

    .img-magnifier-container {
      position: relative;
      cursor: none;
      /* Hide cursor when over the container */
    }

    .img-magnifier-glass {
      position: absolute;
      border: 3px solid #000;
      border-radius: 50%;
      cursor: none;
      pointer-events: none; /* Crucial: ensures glass doesn't block mouse events */
      width: 150px;
      height: 150px;
      display: none;
      z-index: 1000;
      border: none;
    }

    #mainImage {
      cursor: none;
      /* Hide cursor when over the main image */
    }
    /* Styling for the coupon list */
.list-group-item {
  display: flex;
  justify-content: space-between; /* Space out the items */
  align-items: center;
  padding: 10px 15px;
}

/* Ensure the items are evenly spaced and fill the container */
.list-group-item .d-flex {
  width: 100%;
  justify-content: space-between;
}

/* Optional: Style the coupon code and discount */
.coupon-code {
  font-weight: bold;
}

.discount {
  color: #28a745; /* Green color for discounts */
}

.expiry-date {
  font-size: 0.9rem;
  color: #999; /* Light grey color for expiry */
}

  </style>
</head>

<body>

  <%- include('partials/navBar') %>
  <section class="single-product-section">
    <div class="container mt-5">
      <% if (!product.isListed) { %>
      <div class="alert alert-warning" role="alert">
        The product you are looking for is currently unavailable.
      </div>
      <% } else { %>
      <div>
        <a href="/user/home" class="text-decoration-none">Home</a> /
        <a href="#" class="text-decoration-none"><%= categoryName %></a> /
        <span style="color: #9135ED;" class="text-decoration-none"><%= product.name %></span>
      </div>

      <div class="row mt-4">
        <!-- Image Column -->
        <div class="col-md-6 image-view">
          <div class="main-image">
            <div class="img-magnifier-container">
              <img id="mainImage" src="/<%= product.images[0].replace(/\\/g, '/') %>" class="product-image" alt="Product Image">
            </div>
          </div>
          <div class="thumbnails">
            <% product.images.forEach((image, index) => { %>
            <img src="/<%= image.replace(/\\/g, '/') %>" 
                 class="thumbnail <%= index === 0 ? 'active' : '' %>" 
                 alt="Thumbnail <%= index + 1 %>" 
                 onclick="changeMainImage('/<%= image.replace(/\\/g, '/') %>', this)">
            <% }) %>
          </div>
        </div>

        <!-- Details Column -->
        <div style="display: flex; flex-direction: column; justify-content: start;" class="col-md-5">
          <h5 class="card-title"><%= product.name %></h5>
          <div class="mb-2">
            <span class="text-warning">
              <% for(let i=1; i<=5; i++) { %>
                <i class="<%= i <= Math.round(averageRating) ? 'fas' : 'far' %> fa-star" style="font-size: 0.9rem;"></i>
              <% } %>
              <span class="ml-1 font-weight-bold" style="color: #555;"><%= averageRating %></span>
            </span>
            <span class="text-muted small ml-2">(<%= totalReviewsCount %> Reviews)</span>
          </div>
          <div class="price mb-2">
            <% if (bestOffer) { %>
                <span class="old-price text-muted">₹<%= product.price %></span>
                <span class="new-price">₹<%= bestOffer.discountedPrice.toFixed(0) %></span>
                <span class="discount-separator">-</span>
                <span class="discount-text text-success">
                  <%= bestOffer.value %><%= bestOffer.offerType === 'percentage' ? '%' : '₹' %> off
                </span>
            <% } else { %>
                <span class="current-price">₹<%= product.price %></span>
            <% } %>
          </div>
          <div class="line"></div>

          <div>
            <% if (product.stock > 0) { %>
            <span class="in-stock">In Stock</span>
            <% } else { %>
            <span class="text-danger">Out of Stock</span>
            <% } %>
          </div>

          <div class="line"></div>
          <p class="description" style="font-size: 1.1em;"><%= product.description %></p>

          <div class="line"></div>
          <div class="">
            <button type="button" style="font-size: small;" class="btn btn-dark btn-add-to-wishlist" data-product-id="<%= product._id %>">
              <i class="fas fa-heart"></i> Add to Wishlist
            </button>
          </div>

          <div class="line"></div>
          <p class="offer" style="font-weight: bold;">Top Coupons Available for This Product:</p>
          <% if (activeCoupons.length > 0) { %>
            <ul class="list-group">
              <% activeCoupons.forEach(coupon => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <!-- Horizontal layout with space between coupon info -->
                  <div class="d-flex justify-content-between w-100">
                    <!-- Coupon Code -->
                    <span class="coupon-code"><%= coupon.code %></span>
          
                    <!-- Discount Amount and Max Discount for percentage type -->
                    <span class="discount">
                      <% if (coupon.discountType === 'flat') { %>
                        ₹ <%= coupon.discountAmount %> off
                      <% } else if (coupon.discountType === 'percentage') { %>
                        <%= coupon.discountAmount %>% off (Upto ₹<%= coupon.maxDiscount %>)
                      <% } %>
                    </span>
          
                    <!-- Expiry Date -->
                    <span class="expiry-date">Expires on: <%= new Date(coupon.expiresAt).toLocaleDateString() %></span>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p>No active coupons available for this product.</p>
          <% } %>          

          <div class="line"></div>
          <div class="d-flex align-items-center">
            <!-- Buy Now is always fixed here — never moves -->
            <button style="background-color: #9135ED; color: white;" class="btn buy-buy <%= product.stock === 0 ? 'disabled' : '' %>" data-product-id="<%= product._id %>">
              <i class="fa-solid fa-bolt" style="color: #ffffff;"></i> Buy Now
            </button>
            <!-- Cart controls container only swaps Add to Cart ↔ quantity pill -->
            <div class="cart-controls-container ml-2" data-product-id="<%= product._id %>" data-sp-layout="true">
              <% if (typeof cartItemMap !== 'undefined' && cartItemMap && cartItemMap[product._id.toString()]) { %>
                <div class="cart-quantity-controls d-flex align-items-center">
                  <div class="d-flex align-items-center btn btn-dark p-0" style="border-radius: 6px; overflow: hidden;">
                    <button type="button" class="btn btn-dark btn-decrement m-0 border-0" data-product-id="<%= product._id %>" style="border-radius: 0; border-right: 1px solid rgba(255,255,255,0.3); min-width: 36px;">−</button>
                    <span class="quantity-display px-3" style="font-weight: bold; font-size: 1rem; color: #fff; min-width: 36px; text-align: center;"><%= cartItemMap[product._id.toString()] %></span>
                    <button type="button" class="btn btn-dark btn-increment m-0 border-0" data-product-id="<%= product._id %>" style="border-radius: 0; border-left: 1px solid rgba(255,255,255,0.3); min-width: 36px;">+</button>
                  </div>
                </div>
              <% } else { %>
                <button class="btn btn-dark btn-add-to-cart <%= product.stock === 0 ? 'disabled' : '' %>" data-product-id="<%= product._id %>">
                  <i class="fas fa-shopping-cart"></i> Add To Cart
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Reviews Section -->
      <div class="mt-5 pb-5 border-top pt-4">
        <div class="reviews mt-2 d-flex justify-content-between align-items-center">
          <h4 class="font-weight-bold">Customer Reviews</h4>
        </div>
        <div class="review-list mt-3" id="reviewList">
          <% if (reviews && reviews.length > 0) { %>
              <% reviews.forEach((review, index) => { %>
              <div class="review-item bg-white border-bottom py-3 mb-2 px-3">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="d-flex align-items-start">
                    <span class="mr-3 font-weight-bold text-dark" style="min-width: 20px;"><%= index + 1 %>.</span>
                    <div>
                      <strong class="text-dark"><%= review.userId.firstname %> <%= review.userId.lastname || '' %></strong>
                      <div class="text-warning mb-1" style="font-size: 0.8rem;">
                        <% for(let i=1; i<=5; i++) { %>
                          <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                        <% } %>
                        <span class="badge badge-light border ml-2 text-success" style="font-size: 0.65rem; vertical-align: middle;">Verified Purchase</span>
                      </div>
                    </div>
                  </div>
                  <span class="text-muted" style="font-size: 0.85rem;"><%= new Date(review.createdAt).toLocaleDateString('en-GB') %></span>
                </div>
                <p class="mb-0 text-muted mt-2 pl-4" style="font-size: 0.95rem; line-height: 1.5; margin-left: 10px;"><%= review.comment || 'No comment provided.' %></p>
              </div>
            <% }) %>
          <% } else { %>
            <div class="text-center py-5 bg-light rounded" style="border: 1px dashed #ddd;">
              <i class="fas fa-comment-slash fa-2x text-muted mb-2"></i>
              <p class="text-muted mb-0">No reviews yet for this product. Be the first to share your experience!</p>
            </div>
          <% } %>
        </div>
        
        <% if (hasMoreReviews) { %>
          <div class="text-center mt-4" id="loadMoreReviewsContainer">
            <button id="loadMoreReviewsBtn" class="btn btn-outline-dark rounded-pill px-5 py-2 font-weight-bold" 
                    style="border-width: 2px;"
                    data-page="2" data-product-id="<%= product._id %>">
              Load More Reviews
            </button>
          </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </section>

  <!-- RELATED PRODUCTS Section -->
  <section class="related-products pb-4">
    <div class="container">
      <div class="this-month">
        <div class="this-month-box ml-3">
          <div class="this-month-square"></div>
          <span style="color: #9135ED;">Related Products</span>
        </div>
        <h2 class="text-left mt-3 ml-3 pb-3">SHOP BY RELATED PRODUCTS</h2>
      </div>
      <div class="row g-5" id="related-product-grid">
        <% if (relatedProductsWithOffers && relatedProductsWithOffers.length > 0) { %>
        <% relatedProductsWithOffers.forEach(({ product, bestOffer, averageRating }) => { %>
          <%- include('partials/productCard', { product: product, bestOffer: bestOffer, cartItemMap: cartItemMap, averageRating: averageRating }) %>
        <% }) %>
        <% } else { %>
        <div class="col-12 mb-5 pb-5">
          <p class="text-center">No related products available.</p>
        </div>
        <% } %>
      </div>
      <% if (hasMoreRelated) { %>
      <div id="load-more-related-container" class="text-center mt-4">
        <button id="load-more-related-btn" class="btn text-white view-more-btn" 
                style="background-color: #9135ED;"
                data-page="2" 
                data-product-id="<%= product._id %>" 
                data-category-id="<%= product.category._id %>">View More</button>
      </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>

  <!-- Bootstrap JS and dependencies -->
  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>  <!-- Toastify JS -->
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="/js/cartControls.js"></script>

  <script>
    function changeMainImage(imageUrl, element) {
      const mainImage = document.getElementById('mainImage');
      mainImage.src = imageUrl;

      // Update active state for thumbnails
      document.querySelectorAll('.thumbnail').forEach(thumb => {
        thumb.classList.remove('active');
      });
      if (element) {
        element.classList.add('active');
      }

      // Remove existing magnifier glass
      const existingGlass = document.querySelector('.img-magnifier-glass');
      if (existingGlass) {
        existingGlass.remove();
      }
      // Re-initialize magnifier with new image (only for Large screens and above)
      if (window.innerWidth >= 992) {
        magnify("mainImage", 3);
      }
    }

    function magnify(imgID, zoom) {
      var img, glass, w, h, bw;
      img = document.getElementById(imgID);

      /* Create magnifier glass: */
      glass = document.createElement("DIV");
      glass.setAttribute("class", "img-magnifier-glass");

      /* Insert magnifier glass: */
      img.parentElement.insertBefore(glass, img);

      /* Set background properties for the magnifier glass: */
      glass.style.backgroundImage = "url('" + img.src + "')";
      glass.style.backgroundRepeat = "no-repeat";
      glass.style.backgroundSize = (img.width * zoom) + "px " + (img.height * zoom) + "px";
      bw = 3;
      w = glass.offsetWidth / 2;
      h = glass.offsetHeight / 2;

      /* Show the magnifier when hovering over the image */
      img.addEventListener("mouseenter", () => {
        glass.style.display = "block"; // Show magnifier on mouse enter
      });
      img.addEventListener("mouseleave", () => {
        glass.style.display = "none"; // Hide magnifier on mouse leave
      });

      /* Execute a function when someone moves the magnifier glass over the image: */
      glass.addEventListener("mousemove", moveMagnifier);
      img.addEventListener("mousemove", moveMagnifier);

      /* And also for touch screens: */
      glass.addEventListener("touchmove", moveMagnifier);
      img.addEventListener("touchmove", moveMagnifier);

      function moveMagnifier(e) {
        var pos, x, y;
        /* Prevent any other actions that may occur when moving over the image */
        e.preventDefault();
        /* Get the cursor's x and y positions: */
        pos = getCursorPos(e);
        x = pos.x;
        y = pos.y;

        /* Prevent the magnifier glass from being positioned outside the image: */
        if (x > img.width - (w / zoom)) {
          x = img.width - (w / zoom);
        }
        if (x < w / zoom) {
          x = w / zoom;
        }
        if (y > img.height - (h / zoom)) {
          y = img.height - (h / zoom);
        }
        if (y < h / zoom) {
          y = h / zoom;
        }

        /* Set the position of the magnifier glass to center it over the cursor: */
        glass.style.left = (x - w) + "px";
        glass.style.top = (y - h) + "px";

        /* Display what the magnifier glass "sees": */
        // Calculate the center point for the background position
        var bgX = (x * zoom) - w;
        var bgY = (y * zoom) - h;
        glass.style.backgroundPosition = "-" + bgX + "px -" + bgY + "px";
      }

      function getCursorPos(e) {
        var a, x = 0, y = 0;
        e = e || window.event;
        /* Get the x and y positions of the image: */
        a = img.getBoundingClientRect();
        /* Calculate the cursor's x and y coordinates, relative to the image: */
        x = e.clientX - a.left;
        y = e.clientY - a.top;
        return { x: x, y: y };
      }
    }
  </script>

  <script>
    // Related Products Load More Functionality
    const loadMoreRelatedBtn = document.getElementById('load-more-related-btn');
    if (loadMoreRelatedBtn) {
      loadMoreRelatedBtn.addEventListener('click', async () => {
        const page = loadMoreRelatedBtn.getAttribute('data-page');
        const productId = loadMoreRelatedBtn.getAttribute('data-product-id');
        const categoryId = loadMoreRelatedBtn.getAttribute('data-category-id');

        try {
          const response = await fetch(`/user/related-products/load-more?page=${page}&productId=${productId}&categoryId=${categoryId}`);
          const data = await response.json();

          if (data.products && data.products.length > 0) {
            const grid = document.getElementById('related-product-grid');
            data.products.forEach(({
              product,
              bestOffer,
              averageRating
            }) => {
              const cartQty = (data.cartItemMap && data.cartItemMap[product._id]) ? data.cartItemMap[product._id] : 0;
              const cartControls = cartQty > 0 ? `
                <div class="cart-quantity-controls d-flex align-items-center">
                  <button type="button" class="btn btn-dark btn-decrement m-0" data-product-id="${product._id}">-</button>
                  <span class="px-3 quantity-display" style="min-width: 40px; text-align: center; font-weight: bold; color: #9135ED;">${cartQty}</span>
                  <button type="button" class="btn btn-dark btn-increment m-0" data-product-id="${product._id}">+</button>
                </div>
              ` : `
                <button type="button" class="btn btn-dark m-0 btn-add-to-cart ${product.stock === 0 ? 'disabled' : ''}" data-product-id="${product._id}">
                  <i class="fas fa-shopping-cart"></i> Add to Cart
                </button>
              `;

              const productHtml = `
                <div class="card-div col-xl-3 col-lg-4 col-md-6 col-sm-6 col-12 ${product.stock === 0 ? 'out-of-stock' : ''}">
                  <a href="/user/single-product/${product._id}" class="card-link">
                    <div class="card-img-half position-relative">
                      <img src="/${product.images[0].replace(/\\/g, '/')}" class="card-img-top fixed-height" alt="${product.name}">
                      ${product.stock === 0 ? '<span class="out-of-stock-label">Out of Stock</span>' : ''}
                    </div>
                    <div class="card-body-half">
                      <div class="product-details">
                        <h5 class="card-title text-center" style="font-size: 0.9rem; font-weight: 600; color: #333; margin-bottom: 0 !important;">${product.name}</h5>
                        
                        <div class="d-flex justify-content-between align-items-center mb-1 px-1">
                            <div class="star-rating d-flex align-items-center" style="color: #ffc107;">
                                <div class="stars mr-1" style="display: flex; gap: 1px;">
                                    ${averageRating > 0 ? 
                                        Array.from({length: 5}, (_, i) => `<i class="${i < Math.round(averageRating) ? 'fas' : 'far'} fa-star" style="font-size: 0.75rem !important;"></i>`).join('') :
                                        '<i class="far fa-star" style="font-size: 0.75rem !important;"></i><i class="far fa-star" style="font-size: 0.75rem !important;"></i><i class="far fa-star" style="font-size: 0.75rem !important;"></i><i class="far fa-star" style="font-size: 0.75rem !important;"></i><i class="far fa-star" style="font-size: 0.75rem !important;"></i>'
                                    }
                                </div>
                                <span class="text-muted font-weight-bold" style="font-size: 0.80rem;">${averageRating > 0 ? averageRating : '(0)'}</span>
                            </div>

                            <div class="price-container d-flex align-items-center gap-2">
                                ${bestOffer ? `
                                    <span class="old-price mr-1" style="font-size: 0.65rem; color: #777; text-decoration: line-through;">₹${product.price}</span>
                                    <span class="new-price font-weight-bold" style="color: #28a745 !important; font-size: 0.82rem;">₹${bestOffer.discountedPrice.toFixed(0)}</span>
                                ` : `<span class="current-price font-weight-bold" style="color: #333; font-size: 0.82rem;">₹${product.price}</span>`}
                            </div>
                        </div>
                        <div class="btn-group button-container cart-controls-container" role="group" data-product-id="${product._id}">
                          ${cartControls}
                          <button type="button" class="btn btn-outline-dark m-0 btn-add-to-wishlist" data-product-id="${product._id}">
                            <i class="fas fa-heart"></i> Wishlist
                          </button>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>`;
              grid.insertAdjacentHTML('beforeend', productHtml);
            });

            if (data.hasMore) {
              loadMoreRelatedBtn.setAttribute('data-page', parseInt(page) + 1);
            } else {
              const container = document.getElementById('load-more-related-container');
              if (container) container.remove();
              else loadMoreRelatedBtn.remove();
            }
          }
        } catch (error) {
          console.error('Error loading more related products:', error);
        }
      });
    }

    // Buy Now logic specifically for single product page
    document.addEventListener('click', async (e) => {
        if (e.target.closest('.buy-buy')) {
            const button = e.target.closest('.buy-buy');
            const productId = button.getAttribute('data-product-id');
            const userId = '<%= user ? user._id : null %>';

            if (!userId) {
                showToast("Please log in to buy items", true);
                return;
            }

            try {
                const response = await fetch('/user/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user: userId, productId, quantity: 1 })
                });
                if (response.ok) {
                    window.location.href = '/user/cart';
                }
            } catch (err) {
                console.error(err);
            }
        }
    });

    // Zoom and thumbnail logic stays here
  </script>

  <script>
    // Load More Reviews Logic
    const loadMoreReviewsBtn = document.getElementById('loadMoreReviewsBtn');
    if (loadMoreReviewsBtn) {
      loadMoreReviewsBtn.addEventListener('click', async () => {
        const page = loadMoreReviewsBtn.getAttribute('data-page');
        const productId = loadMoreReviewsBtn.getAttribute('data-product-id');

        try {
          loadMoreReviewsBtn.disabled = true;
          loadMoreReviewsBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Loading...';
          
          const response = await fetch(`/user/reviews/load-more/${productId}?page=${page}`);
          const data = await response.json();

          if (data.success && data.reviews.length > 0) {
            const reviewList = document.getElementById('reviewList');
            data.reviews.forEach((review, index) => {
              const serialNo = reviewList.children.length + 1;
              let stars = '';
              for (let i = 1; i <= 5; i++) {
                stars += `<i class="${i <= review.rating ? 'fas' : 'far'} fa-star"></i>`;
              }
              
              const reviewHtml = `
                <div class="review-item bg-white border-bottom py-3 mb-2 px-3">
                  <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex align-items-start">
                      <span class="mr-3 font-weight-bold text-dark" style="min-width: 20px;">${serialNo}</span>
                      <div>
                        <strong class="text-dark">${review.user}</strong>
                        <div class="text-warning mb-1" style="font-size: 0.8rem;">
                          ${stars}
                          <span class="badge badge-light border ml-2 text-success" style="font-size: 0.65rem; vertical-align: middle;">Verified Purchase</span>
                        </div>
                      </div>
                    </div>
                    <span class="text-muted" style="font-size: 0.85rem;">${review.date}</span>
                  </div>
                  <p class="mb-0 text-muted mt-2 pl-4" style="font-size: 0.95rem; line-height: 1.5; margin-left: 10px;">${review.comment || 'No comment provided.'}</p>
                </div>
              `;
              reviewList.insertAdjacentHTML('beforeend', reviewHtml);
            });

            if (data.hasMore) {
              loadMoreReviewsBtn.setAttribute('data-page', parseInt(page) + 1);
              loadMoreReviewsBtn.disabled = false;
              loadMoreReviewsBtn.innerHTML = 'Load More Reviews';
            } else {
              document.getElementById('loadMoreReviewsContainer').remove();
            }
          }
        } catch (error) {
          console.error('Error loading more reviews:', error);
          loadMoreReviewsBtn.disabled = false;
          loadMoreReviewsBtn.innerHTML = 'Load More Reviews';
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (window.innerWidth >= 992) {
        magnify("mainImage", 3);
      }
    });
  </script>

</body>

</html>
