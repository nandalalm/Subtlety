<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - SUBTLETY</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/user/login.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    .auth-card {
      border-radius: 16px;
      border: 1px solid #e8e8e8;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      background: #fff;
    }

    .auth-title {
      letter-spacing: 0.14em;
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #111 !important;
    }

    .auth-subtitle {
      font-weight: 600;
      color: #2c2c2c;
    }

    input:focus,
    .btn:focus,
    .btn:active {
      box-shadow: none !important;
      outline: none !important;
    }

    .form-control:focus {
      border-color: #d9d9d9;
      box-shadow: none;
    }

    .form-control.is-valid,
    .form-control.is-invalid {
      background-image: none;
      box-shadow: none !important;
    }

    .password-wrapper .input-group {
      position: relative;
      align-items: stretch;
    }

    .password-wrapper .form-control {
      padding-right: 3rem;
    }

    .password-toggle-btn {
      height: 34px;
      width: 34px;
      border: 0;
      background: transparent;
      color: #6b7280;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
      padding: 0;
      appearance: none;
      -webkit-appearance: none;
    }

    .password-toggle-btn:hover {
      color: #111827;
    }

    .password-toggle-btn:focus,
    .password-toggle-btn:active {
      outline: none;
      box-shadow: none !important;
      background: transparent !important;
      border-color: transparent !important;
    }

    .password-wrapper .input-group-append {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }

    .password-wrapper .input-group-append button {
      height: 100%;
      width: 100%;
      border: 0;
      background: transparent;
      box-shadow: none !important;
    }

    .otp-inputs {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 16px;
      width: 100%;
      max-width: 100%;
      overflow: hidden;
    }

    .otp-box {
      width: 42px;
      min-width: 42px;
      height: 46px;
      border: 1px solid #d9d9d9;
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      color: #111;
      outline: none;
      border-radius: 12px;
      background: #fff;
      box-shadow: none;
      transition: border-color 0.2s ease, background-color 0.2s ease;
    }

    .otp-box:focus {
      border-color: #111;
      box-shadow: none;
    }

    .step-container {
      display: none;
    }

    .step-active {
      display: block;
    }

    .otp-panel {
      margin-top: 1.25rem;
      padding: 0.25rem 0 0;
      border: 0;
      border-radius: 0;
      background: transparent;
    }

    .otp-action-btn {
      border-radius: 10px !important;
      font-weight: 600;
      min-height: 44px;
      border: 0;
    }

    .otp-secondary-btn {
      background: #111;
      color: #fff;
      border: 1px solid #111;
    }

    .otp-secondary-btn:hover {
      background: #2c2c2c;
      color: #fff;
    }

    #verifyOtpBtn.btn-success {
      background: #9135ED;
      color: #fff;
      border: 1px solid #9135ED;
    }

    #verifyOtpBtn.btn-success:hover {
      background: #7f22d8;
      color: #fff;
    }

    @media(max-width: 415px) {
      .otp-inputs {
        gap: 6px;
      }

      .otp-box {
        width: 36px;
        min-width: 36px;
        height: 42px;
      }
    }
  </style>
</head>

<body>
  <div class="login-container">
    <div class="auth-card p-4 p-sm-4">
    <h2 class="text-center auth-title">SUBTLETY</h2>
    <h4 class="text-center mb-4 auth-subtitle">Reset Password</h4>

    <!-- Step 1: Enter Email -->
    <div id="step-email" class="step-container step-active">
      <div class="form-group">
        <label for="resetEmail"><small>Enter registered email</small></label>
        <input type="email" id="resetEmail" class="form-control" placeholder="example@mail.com" value="<%= pendingReset?.email || '' %>" required>
        <div id="emailValidation" class="text-danger mt-1" style="display: none;"><small>Please enter a valid email address.</small></div>
      </div>
      <button id="sendOtpBtn" class="btn btn-primary btn-block hello mt-3">Send OTP</button>
      <div id="loader" class="text-center mt-3" style="display: none;">
        <div class="spinner-border text-primary" role="status">
          <span class="sr-only">Loading...</span>
        </div>
        <p><small id="loaderText">Sending OTP...</small></p>
      </div>
    </div>

    <!-- Step 2: Verify OTP -->
    <div id="step-otp" class="step-container otp-panel">
      <p class="text-center text-muted"><small>Enter the 6-digit code sent to your email.</small></p>
      <div class="otp-inputs text-center">
        <input type="text" class="otp-box" id="otp-box-1" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-2" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-3" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-4" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-5" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-6" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
      </div>
      <p id="timer-message" class="text-center text-danger mt-3 mb-0" style="display: none;"></p>
      <button id="verifyOtpBtn" class="btn btn-success btn-block otp-action-btn mt-4">Verify OTP</button>
      <button id="resendOtpBtn" class="btn btn-block otp-action-btn otp-secondary-btn mt-2" style="display: none;"><small>Resend OTP</small></button>
      <div id="resendLoader" class="text-center mt-2" style="display: none;">
        <div class="spinner-border spinner-border-sm text-primary" role="status">
          <span class="sr-only">Loading...</span>
        </div>
        <p class="mb-0 mt-2"><small>Resending OTP...</small></p>
      </div>
    </div>

    <!-- Step 3: New Password -->
    <div id="step-password" class="step-container otp-panel">
      <div class="form-group password-wrapper">
        <label for="newPassword"><small>New Password</small></label>
        <div class="input-group">
          <input type="password" id="newPassword" class="form-control" placeholder="Enter new password" required>
          <div class="input-group-append">
            <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
          </div>
        </div>
        <div id="passwordValidation" class="text-danger mt-1" style="display: none;">
          <small>At least 6 characters, 1 uppercase, 1 lowercase, 1 number, 1 special character.</small>
        </div>
      </div>
      <div class="form-group password-wrapper">
        <label for="confirmPassword"><small>Confirm Password</small></label>
        <div class="input-group">
          <input type="password" id="confirmPassword" class="form-control" placeholder="Confirm new password" required>
          <div class="input-group-append">
            <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
          </div>
        </div>
        <div id="matchValidation" class="text-danger mt-1" style="display: none;"><small>Passwords do not match.</small></div>
      </div>
      <button id="resetPasswordBtn" class="btn btn-primary btn-block hello otp-action-btn mt-4">
        <span class="btn-label">Update Password</span>
        <span class="spinner-border spinner-border-sm ml-2 d-none" id="resetPasswordSpinner" role="status" aria-hidden="true"></span>
      </button>
    </div>

    <p class="text-center mt-4"><a href="/auth/login" class="text-muted"><small><i class="fas fa-arrow-left mr-1"></i> Back to Login</small></a></p>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/swalHelper.js"></script>
  <script>
    const otpBoxes = document.querySelectorAll('.otp-box');
    const FORGOT_PASSWORD_OTP_STORAGE_KEY = 'forgotPasswordOtpState';
    const OTP_VALIDITY_MS = 60 * 1000;
    const resetPasswordButton = document.getElementById('resetPasswordBtn');
    const resetPasswordSpinner = document.getElementById('resetPasswordSpinner');
    let otpTimer;

    // Helper functions
    function showStep(stepId) {
      $('.step-container').removeClass('step-active');
      $(`#step-${stepId}`).addClass('step-active');
    }

    function toggleLoader(show, text = 'Processing...') {
      $('#loaderText').text(text);
      $('#loader').toggle(show);
      $('#sendOtpBtn').toggle(!show);
    }

    function setOtpState(email, otpTimestamp) {
      if (!email || !otpTimestamp) return;
      sessionStorage.setItem(FORGOT_PASSWORD_OTP_STORAGE_KEY, JSON.stringify({
        email,
        otpTimestamp,
        expiresAt: Number(otpTimestamp) + OTP_VALIDITY_MS
      }));
    }

    function getOtpState() {
      try {
        const raw = sessionStorage.getItem(FORGOT_PASSWORD_OTP_STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch (error) {
        return null;
      }
    }

    function clearOtpState() {
      clearInterval(otpTimer);
      sessionStorage.removeItem(FORGOT_PASSWORD_OTP_STORAGE_KEY);
    }

    function setResetPasswordLoading(isLoading) {
      resetPasswordButton.disabled = isLoading;
      resetPasswordSpinner.classList.toggle('d-none', !isLoading);
      resetPasswordButton.querySelector('.btn-label').textContent = isLoading ? 'Updating...' : 'Update Password';
    }

    function validateEmailInput(showMessage = true) {
      const email = $('#resetEmail').val().trim();
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const isValid = emailRegex.test(email);
      $('#emailValidation').toggle(showMessage && !isValid && email.length > 0);
      $('#resetEmail').toggleClass('is-invalid', showMessage && !isValid && email.length > 0);
      $('#resetEmail').toggleClass('is-valid', isValid);
      return isValid;
    }

    function validatePasswordInput() {
      const newPassword = $('#newPassword').val();
      const passRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*])[A-Za-z\d!@#$%^&*]{6,}$/;
      const isValid = passRegex.test(newPassword);
      $('#passwordValidation').toggle(!isValid && newPassword.length > 0);
      $('#newPassword').toggleClass('is-invalid', !isValid && newPassword.length > 0);
      $('#newPassword').toggleClass('is-valid', isValid);
      return isValid;
    }

    function validateConfirmPasswordInput() {
      const newPassword = $('#newPassword').val();
      const confirmPassword = $('#confirmPassword').val();
      const isValid = confirmPassword.length > 0 && newPassword === confirmPassword;
      $('#matchValidation').toggle(confirmPassword.length > 0 && !isValid);
      $('#confirmPassword').toggleClass('is-invalid', confirmPassword.length > 0 && !isValid);
      $('#confirmPassword').toggleClass('is-valid', isValid);
      return isValid;
    }

    // Step 1: Send OTP
    $('#sendOtpBtn').click(async function() {
      const email = $('#resetEmail').val().trim();

      if (!validateEmailInput(true)) {
        $('#emailValidation').show();
        return;
      }
      $('#emailValidation').hide();

      toggleLoader(true, 'Sending OTP...');

      try {
        const response = await fetch('/auth/forgot-password/send-otp', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ email })
        });

        if (response.ok) {
          const data = await response.json();
          showStep('otp');
          setOtpState(email, data.otpTimestamp);
          startTimer(data.otpTimestamp);
        } else {
          const error = await response.json().catch(() => ({}));
          SwalCustom.error('Error', error.message || 'Unable to send OTP.');
        }
      } catch (err) {
        SwalCustom.error('Error', 'Something went wrong.');
      } finally {
        toggleLoader(false);
      }
    });

    // Step 2: OTP Logic
    otpBoxes.forEach((box, index) => {
      box.addEventListener('input', (e) => {
        if (box.value.length === 1 && index < otpBoxes.length - 1) {
          otpBoxes[index + 1].focus();
        }
      });

      box.addEventListener('keydown', (e) => {
        if (e.key === "Backspace") {
          if (box.value === '' && index > 0) {
            otpBoxes[index - 1].focus();
          }
        }
      });

      box.addEventListener('paste', (e) => {
        e.preventDefault();
        const pasteData = e.clipboardData.getData('text').slice(0, 6).split('');
        pasteData.forEach((char, i) => {
          if (otpBoxes[index + i]) otpBoxes[index + i].value = char;
        });
        const nextIndex = Math.min(index + pasteData.length, otpBoxes.length - 1);
        otpBoxes[nextIndex].focus();
      });
    });

    function startTimer(otpTimestamp = Date.now()) {
      const expiresAt = Number(otpTimestamp) + OTP_VALIDITY_MS;
      let timeLeft = Math.max(0, Math.ceil((expiresAt - Date.now()) / 1000));
      $('#resendOtpBtn').hide();
      clearInterval(otpTimer);

      if (timeLeft <= 0) {
        $('#timer-message').show().text('OTP has expired.');
        $('#resendOtpBtn').show();
        return;
      }

      $('#timer-message').show().text(`OTP valid for 00:${timeLeft.toString().padStart(2, '0')}`);
      
      otpTimer = setInterval(() => {
        timeLeft--;
        if (timeLeft <= 0) {
          clearInterval(otpTimer);
          $('#timer-message').text('OTP has expired.');
          $('#resendOtpBtn').show();
          return;
        }
        $('#timer-message').text(`OTP valid for 00:${timeLeft.toString().padStart(2, '0')}`);
      }, 1000);
    }

    $('#verifyOtpBtn').click(async function() {
      const otp = Array.from(otpBoxes).map(box => box.value).join('');
      const email = $('#resetEmail').val();

      if (otp.length < 6) return;

      try {
        const response = await fetch('/auth/forgot-password/verify-otp', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ email, otp })
        });

        if (response.ok) {
          clearInterval(otpTimer);
          showStep('password');
        } else {
          const error = await response.json().catch(() => ({}));
          SwalCustom.error('Verification Failed', error.message || 'Please check the code and try again.');
        }
      } catch (err) {
        SwalCustom.error('Error', 'Verification failed.');
      }
    });

    $('#resendOtpBtn').click(async function() {
      const email = $('#resetEmail').val();
      $('#resendOtpBtn').hide();
      $('#resendLoader').show();
      try {
        const response = await fetch('/auth/forgot-password/resend-otp', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ email })
        });
        if (response.ok) {
          const data = await response.json();
          setOtpState(email, data.otpTimestamp);
          startTimer(data.otpTimestamp);
          otpBoxes.forEach(box => box.value = '');
          otpBoxes[0].focus();
        } else {
          const error = await response.json().catch(() => ({}));
          SwalCustom.error('Error', error.message || 'Could not resend OTP.');
          $('#resendOtpBtn').show();
        }
      } catch (err) {
        SwalCustom.error('Error', 'Could not resend OTP.');
        $('#resendOtpBtn').show();
      } finally {
        $('#resendLoader').hide();
      }
    });

    // Step 3: Reset Password
    $('#resetPasswordBtn').click(async function() {
      const email = $('#resetEmail').val();
      const newPassword = $('#newPassword').val().trim();
      const confirmPassword = $('#confirmPassword').val().trim();

      if (!validatePasswordInput()) {
        $('#passwordValidation').show();
        return;
      }
      $('#passwordValidation').hide();

      if (!validateConfirmPasswordInput()) {
        $('#matchValidation').show();
        return;
      }
      $('#matchValidation').hide();

      setResetPasswordLoading(true);
      try {
        const response = await fetch('/auth/forgot-password/reset', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ email, newPassword })
        });

        if (response.ok) {
          const data = await response.json().catch(() => ({}));
          clearOtpState();
          await SwalCustom.success('Updated!', data.message || 'Your password has been reset successfully.');
          window.location.href = '/auth/login';
        } else {
          const error = await response.json().catch(() => ({}));
          SwalCustom.error('Failed', error.message || 'Could not update password.');
        }
      } catch (err) {
        SwalCustom.error('Failed', 'Could not update password.');
      } finally {
        setResetPasswordLoading(false);
      }
    });

    // Toggle password
    $('.toggle-password').click(function() {
      const input = $(this).closest('.input-group').find('input');
      const type = input.attr('type') === 'password' ? 'text' : 'password';
      input.attr('type', type);
      $(this).find('i').toggleClass('fa-eye fa-eye-slash');
    });

    $('#resetEmail').on('input blur', function() {
      validateEmailInput(true);
    });

    $('#newPassword').on('input blur', function() {
      validatePasswordInput();
      if ($('#confirmPassword').val()) validateConfirmPasswordInput();
    });

    $('#confirmPassword').on('input blur', function() {
      validateConfirmPasswordInput();
    });

    window.addEventListener('pageshow', () => {
      const pendingReset = <%- JSON.stringify(pendingReset || null) %>;
      const storedState = getOtpState();
      const pendingState = pendingReset ? {
        email: pendingReset.email,
        otpTimestamp: pendingReset.otpTimestamp,
        expiresAt: Number(pendingReset.otpTimestamp) + OTP_VALIDITY_MS,
        isOtpVerified: Boolean(pendingReset.isOtpVerified)
      } : null;
      const activeState = pendingState?.isOtpVerified ? pendingState : (storedState || pendingState);

      if (!activeState || !activeState.email || !activeState.otpTimestamp) {
        clearOtpState();
        return;
      }

      $('#resetEmail').val(activeState.email);
      setOtpState(activeState.email, activeState.otpTimestamp);
      if (activeState.isOtpVerified) {
        showStep('password');
        return;
      }
      showStep('otp');
      startTimer(activeState.otpTimestamp);
    });
  </script>
</body>
</html>
