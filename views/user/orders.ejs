<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Orders - SUBTLETY</title>
  <!-- Bootstrap CSS -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <!-- Google Fonts: Poppins -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/styles/user/userProfile.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <style>
    .product-image {
      width: 50px;
      height: 50px;
      object-fit: cover;
    }
    .text-purple { color: #9135ED; }
  </style>
</head>

<body>

  <!-- Navbar -->
  <%- include('../partials/User/navBar') %>

  <section class="profile-section">
    <div class="container profile pt-2">
      <div class="d-flex justify-content-between align-items-center mb-4 breadcrumbs mt-4 mt-lg-0">
        <div>
          <a href="/user/home" class="text-decoration-none">Home</a> /
          <span style="color: #9135ED;" class="text-decoration-none">My Orders</span>
        </div>
        <div>
          <h5>Welcome, <span style="color: #9135ED;"><%= user.firstname %>!</span></h5>
        </div>
      </div>

      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
          <%- include('../partials/User/userSidebar', { activePage: 'orders' }) %>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9 col-12">
          <h2 class="section-main-title">My Orders</h2>

          <!-- Search & Filter Bar -->
          <% if (totalOrdersUnfiltered > 0) { %>
          <div class="row mt-2 mb-3 align-items-start g-2">
            <!-- Search -->
            <div class="col-lg-5 col-md-12 mb-2">
              <%- include('../partials/Common/searchBar', {
                searchInputId: 'orderSearchInput',
                searchContainerId: 'userOrderContainer',
                searchPlaceholder: 'Search by Order ID...',
                searchValue: search || '',
                searchBasePath: 'orders'
              }) %>
            </div>
            <!-- Order Status Sort/Filter -->
            <div class="col-lg-3 col-md-6 mb-2">
              <div class="filter-sort-pill">
                <select id="orderSortSelect" onchange="applyAjaxFilter('userOrderContainer', 'sort', this.value, 'orders'); document.getElementById('clearOrderSortBtn').style.display=this.value!=='latest'?'flex':'none';">
                  <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Sort: Latest</option>
                  <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Sort: Oldest</option>
                  <option disabled>── Order Status ──</option>
                  <option value="Pending" <%= sort === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="Shipped" <%= sort === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                  <option value="Completed" <%= sort === 'Completed' ? 'selected' : '' %>>Completed</option>
                  <option value="Cancelled" <%= sort === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <button id="clearOrderSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                  style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                  onclick="clearAjaxFilter('userOrderContainer', 'sort', 'orders'); this.style.display='none'; document.getElementById('orderSortSelect').value='latest';">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>
            <!-- Payment Status Filter -->
            <div class="col-lg-3 col-md-6 mb-2">
              <div class="filter-sort-pill">
                <select id="orderPaymentSelect" onchange="applyAjaxFilter('userOrderContainer', 'paymentStatus', this.value, 'orders'); document.getElementById('clearOrderPaymentBtn').style.display=this.value?'flex':'none';">
                  <option value="">Payment: All</option>
                  <option value="Pending" <%= paymentStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="Successful" <%= paymentStatus === 'Successful' ? 'selected' : '' %>>Successful</option>
                  <option value="Failed" <%= paymentStatus === 'Failed' ? 'selected' : '' %>>Failed</option>
                </select>
                <button id="clearOrderPaymentBtn" type="button" class="sort-clear-inner" title="Clear filter"
                  style="display:<%= paymentStatus ? 'flex' : 'none' %>;"
                  onclick="clearAjaxFilter('userOrderContainer', 'paymentStatus', 'orders'); this.style.display='none'; document.getElementById('orderPaymentSelect').value='';">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>
          </div>
          <% } %>

          <div id="userOrderContainer">
            <%- include('../partials/Common/orderTable') %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/User/footer') %>

  <!-- Bootstrap JS and dependencies -->
  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

  <script src="/js/ajaxTable.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {});

    // Search, Filter, and Pagination is now handled by /js/ajaxTable.js
  </script>
