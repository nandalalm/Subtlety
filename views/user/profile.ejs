<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile - SUBTLETY</title>

  <!-- Stylesheets -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/user/userProfile.css">
  <style>
    /* Custom CSS to remove default focus styles */
    input:focus,
    .btn:focus,
    .btn:active {
      box-shadow: none !important;
      outline: none !important;
    }

    .password-shell .input-group {
      position: relative;
      align-items: stretch;
    }

    .password-shell .form-control {
      padding-right: 3rem;
      position: relative;
      z-index: 1;
    }

    .password-shell .input-group-append {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 3;
    }

    .password-toggle-btn {
      height: 34px;
      width: 34px;
      border: 0;
      background: transparent;
      color: #6b7280;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
    }

    .password-toggle-btn:hover {
      color: #111827;
    }
  </style>
</head>

<body>
  <%- include('../partials/User/navBar') %>

  <section class="profile-section">
    <div class="container profile pt-2">
      <div class="d-flex justify-content-between align-items-center mb-4 breadcrumbs mt-4 mt-lg-0">
        <div>
          <a href="/user/home" class="text-decoration-none">Home</a> /
          <span style="color: #9135ED;" class="text-decoration-none">My Profile</span>
        </div>
        <div>
          <h5>Welcome, <span style="color: #9135ED;"><%= user.firstname %>!</span></h5>
        </div>
      </div>

      <div class="row">
        <div class="col-md-3">
          <%- include('../partials/User/userSidebar', { activePage: 'profile' }) %>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9 col-12">
          <div id="content">
            <h2 class="section-main-title">My Profile</h2>
            <div id="myProfile" class="content-section">
              <h4>Username
                <a id="edit-btn" class="pl-2 text-decoration-none" href="#" style="font-size: 14px;">Edit</a>
              </h4>
              <form id="profile-form" method="POST" action="/profile/update">
                <div class="form-group">
                  <div class="d-flex justify-content-between">
                    <div class="mr-2" style="flex: 1;">
                      <label>First Name</label>
                      <input type="text" name="firstname" id="first-name" value="<%= user.firstname %>" placeholder="First Name" class="form-control" disabled pattern="^[a-zA-Z]{3,}$" title="At least 3 letters, no numbers or special characters" required>
                      <small id="first-name-error" class="form-text text-danger" style="display: none;">At least 3 letters, no numbers or special characters</small>
                    </div>
                    <div style="flex: 1;">
                      <label>Last Name</label>
                      <input type="text" name="lastname" id="last-name" value="<%= user.lastname || '' %>" placeholder="Last Name (optional)" class="form-control" disabled pattern="^[a-zA-Z]*$" title="No numbers or special characters">
                      <small id="last-name-error" class="form-text text-danger" style="display: none;">No numbers or special characters</small>
                    </div>
                  </div>
                  <button id="save-btn" class="btn btn-primary mt-2" style="display: none;">Save</button>
                </div>
              </form>

              <h4>Phone Number
                <a id="edit-phone-btn" class="pl-2 text-decoration-none" href="#" style="font-size: 14px;">Edit</a>
              </h4>
              <form id="phone-form" method="POST" action="/profile/update-phone">
                <div class="form-group">
                  <input type="tel" name="phone" id="phone" value="<%= user.phoneNo || '' %>" placeholder="<%= user.phoneNo ? user.phoneNo : 'Update your phone number' %>" class="form-control" disabled pattern="^[0-9]{10}$" title="10 digits, no spaces or special characters" required>
                  <small id="phone-error" class="form-text text-danger" style="display: none;">Please enter a valid 10-digit phone number</small>
                </div>
                <button id="save-phone-btn" class="btn btn-primary" style="display: none;">Save</button>
              </form>

              <h4>Email Address</h4>
              <div class="form-group">
                <input type="email" name="email" id="email" value="<%= user.email %>" placeholder="Email Address" class="form-control" disabled>
              </div>

              <button class="btn btn-sm btn-primary mt-2" data-toggle="modal" data-target="#changePasswordModal">
                <i class="fas fa-lock"></i> Change Password
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Change Password Modal -->
  <div class="modal fade mt-5 pt-5" id="changePasswordModal" tabindex="-1" role="dialog" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="changePasswordModalLabel">Change Password</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="change-password-form">
            <div class="form-group password-shell">
              <label for="current-password">Current Password</label>
              <div class="input-group">
                <input type="password" id="current-password" class="form-control" placeholder="Enter current password">
                <div class="input-group-append">
                  <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
                </div>
              </div>
              <small id="current-password-error" class="form-text text-danger" style="display: none;"></small>
            </div>
            <div class="form-group password-shell">
              <label for="new-password">New Password</label>
              <div class="input-group">
                <input type="password" id="new-password" class="form-control" placeholder="Enter new password">
                <div class="input-group-append">
                  <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
                </div>
              </div>
              <small id="new-password-error" class="form-text text-danger" style="display: none;"></small>
            </div>
            <div class="form-group password-shell">
              <label for="confirm-password">Confirm Password</label>
              <div class="input-group">
                <input type="password" id="confirm-password" class="form-control" placeholder="Confirm new password">
                <div class="input-group-append">
                  <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
                </div>
              </div>
              <small id="confirm-password-error" class="form-text text-danger" style="display: none;"></small>
            </div>
            <button type="submit" class="btn btn-primary">Change Password</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/User/footer') %>

  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <!-- SweetAlert2 and swalHelper are now global via navBar partial -->

  <!-- JavaScript -->
  <script>
    // ── Store original server-rendered values so Cancel can restore them ──
    const originalFirstName = document.getElementById('first-name').value;
    const originalLastName  = document.getElementById('last-name').value;
    const originalPhone     = document.getElementById('phone').value;

    // ─────────────────────────────────────────────
    // Helper: clear validation state on an input
    // ─────────────────────────────────────────────
    function clearInputState(inputEl, errorEl) {
      inputEl.style.borderColor = '';
      if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }
    }

    function setInputError(inputEl, errorEl, msg) {
      inputEl.style.borderColor = 'red';
      if (errorEl) { errorEl.textContent = msg; errorEl.style.display = 'block'; }
    }

    function setInputOk(inputEl, errorEl) {
      inputEl.style.borderColor = 'green';
      if (errorEl) errorEl.style.display = 'none';
    }

    // ─────────────────────────────────────────────
    // USERNAME (First/Last Name) — Edit toggle
    // ─────────────────────────────────────────────
    const firstNameInput = document.getElementById('first-name');
    const lastNameInput  = document.getElementById('last-name');
    const firstNameError = document.getElementById('first-name-error');
    const lastNameError  = document.getElementById('last-name-error');
    const editBtn        = document.getElementById('edit-btn');
    const saveBtn        = document.getElementById('save-btn');

    editBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (firstNameInput.disabled) {
        // Enter edit mode
        firstNameInput.disabled = false;
        lastNameInput.disabled  = false;
        this.textContent = 'Cancel';
        saveBtn.style.display = 'inline-block';
      } else {
        // Cancel — restore originals, no reload
        firstNameInput.value    = originalFirstName;
        lastNameInput.value     = originalLastName;
        firstNameInput.disabled = true;
        lastNameInput.disabled  = true;
        this.textContent = 'Edit';
        saveBtn.style.display = 'none';
        clearInputState(firstNameInput, firstNameError);
        clearInputState(lastNameInput, lastNameError);
      }
    });

    // Live validation: First Name (alpha only, min 3 chars, no spaces)
    firstNameInput.addEventListener('input', function() {
      if (!this.value) { clearInputState(this, firstNameError); return; }
      if (!/^[a-zA-Z]{3,}$/.test(this.value)) {
        setInputError(this, firstNameError, 'At least 3 letters, alphabets only — no spaces or special characters');
      } else {
        setInputOk(this, firstNameError);
      }
    });

    // Live validation: Last Name (alpha only, optional but no spaces)
    lastNameInput.addEventListener('input', function() {
      if (!this.value) { clearInputState(this, lastNameError); return; }
      if (!/^[a-zA-Z]+$/.test(this.value)) {
        setInputError(this, lastNameError, 'Alphabets only — no spaces or special characters');
      } else {
        setInputOk(this, lastNameError);
      }
    });

    // Save First/Last Name via AJAX
    saveBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (!/^[a-zA-Z]{3,}$/.test(firstNameInput.value)) {
        setInputError(firstNameInput, firstNameError, 'At least 3 letters, alphabets only — no spaces or special characters');
        return;
      }
      if (lastNameInput.value && !/^[a-zA-Z]+$/.test(lastNameInput.value)) {
        setInputError(lastNameInput, lastNameError, 'Alphabets only — no spaces or special characters');
        return;
      }

      authAwareFetch('/profile/update', {
        method: 'POST',
        body: JSON.stringify({ firstname: firstNameInput.value, lastname: lastNameInput.value }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r ? (r.ok ? r.json() : Promise.reject('Update failed')) : null)
      .then(data => {
        if (!data) return;
        SwalCustom.success('Success', data.message);
        firstNameInput.disabled = true;
        lastNameInput.disabled  = true;
        editBtn.textContent     = 'Edit';
        saveBtn.style.display   = 'none';
        clearInputState(firstNameInput, firstNameError);
        clearInputState(lastNameInput, lastNameError);
        const welcomeName = document.querySelector('.breadcrumbs h5 span');
        if (welcomeName) welcomeName.textContent = firstNameInput.value + '!';
      })
      .catch(() => SwalCustom.error('Error', 'Failed to update profile'));
    });

    // ─────────────────────────────────────────────
    // PHONE — Edit toggle
    // ─────────────────────────────────────────────
    const phoneInput     = document.getElementById('phone');
    const phoneError     = document.getElementById('phone-error');
    const editPhoneBtn   = document.getElementById('edit-phone-btn');
    const savePhoneBtn   = document.getElementById('save-phone-btn');

    editPhoneBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (phoneInput.disabled) {
        phoneInput.disabled = false;
        this.textContent    = 'Cancel';
        savePhoneBtn.style.display = 'inline-block';
      } else {
        // Cancel — restore original, no reload
        phoneInput.value    = originalPhone;
        phoneInput.disabled = true;
        this.textContent    = 'Edit';
        savePhoneBtn.style.display = 'none';
        clearInputState(phoneInput, phoneError);
      }
    });

    // Live validation: Phone (exactly 10 digits)
    phoneInput.addEventListener('input', function() {
      // Strip non-digits as user types
      this.value = this.value.replace(/\D/g, '');
      if (!this.value) { clearInputState(this, phoneError); return; }
      if (!/^[0-9]{10}$/.test(this.value)) {
        setInputError(this, phoneError, 'Enter a valid 10-digit phone number');
      } else {
        setInputOk(this, phoneError);
      }
    });

    // Save Phone via AJAX
    savePhoneBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (!/^[0-9]{10}$/.test(phoneInput.value)) {
        setInputError(phoneInput, phoneError, 'Enter a valid 10-digit phone number');
        return;
      }
      authAwareFetch('/profile/update-phone', {
        method: 'POST',
        body: JSON.stringify({ phone: phoneInput.value }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r ? (r.ok ? r.json() : Promise.reject('Update failed')) : null)
      .then(data => {
        if (!data) return;
        SwalCustom.success('Success', data.message);
        phoneInput.disabled = true;
        editPhoneBtn.textContent   = 'Edit';
        savePhoneBtn.style.display = 'none';
        clearInputState(phoneInput, phoneError);
      })
      .catch(() => SwalCustom.error('Error', 'Failed to update phone number'));
    });

    // ─────────────────────────────────────────────
    // CHANGE PASSWORD MODAL
    // ─────────────────────────────────────────────
    const currentPasswordInput = document.getElementById('current-password');
    const newPasswordInput     = document.getElementById('new-password');
    const confirmPasswordInput = document.getElementById('confirm-password');
    const currentPasswordError = document.getElementById('current-password-error');
    const newPasswordError     = document.getElementById('new-password-error');
    const confirmPasswordError = document.getElementById('confirm-password-error');
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*])[A-Za-z\d!@#$%^&*]{6,}$/;

    // Clear all modal state each time it opens (stale errors/values don't persist)
    $('#changePasswordModal').on('show.bs.modal', function() {
      document.getElementById('change-password-form').reset();
      [currentPasswordInput, newPasswordInput, confirmPasswordInput].forEach(inp => {
        inp.style.borderColor = '';
      });
      clearInputState(currentPasswordInput, currentPasswordError);
      clearInputState(newPasswordInput, newPasswordError);
      clearInputState(confirmPasswordInput, confirmPasswordError);
    });

    // Live validation — current password: clear error as user re-types
    currentPasswordInput.addEventListener('input', function() {
      if (currentPasswordError.style.display !== 'none') {
        clearInputState(this, currentPasswordError);
      }
    });

    // Live validation — new password strength
    newPasswordInput.addEventListener('input', function() {
      if (!this.value) { clearInputState(this, newPasswordError); return; }
      if (!passwordRegex.test(this.value)) {
        setInputError(this, newPasswordError, 'Min 6 chars, 1 upper & 1 lowercase, 1 num, no spaces, 1 special char - !@#$%^&*');
      } else {
        setInputOk(this, newPasswordError);
      }
    });

    // Live validation — confirm password match
    confirmPasswordInput.addEventListener('input', function() {
      if (!this.value) { clearInputState(this, confirmPasswordError); return; }
      if (this.value !== newPasswordInput.value) {
        setInputError(this, confirmPasswordError, 'Passwords do not match');
      } else {
        setInputOk(this, confirmPasswordError);
      }
    });

    // Submit change password
    document.getElementById('change-password-form').addEventListener('submit', function(e) {
      e.preventDefault();

      const currentVal = currentPasswordInput.value;
      const newVal = newPasswordInput.value;
      const confirmVal = confirmPasswordInput.value;

      // Trigger live validation for all fields
      if (!currentVal) setInputError(currentPasswordInput, currentPasswordError, 'Please enter your current password');
      else setInputOk(currentPasswordInput, currentPasswordError);

      if (!newVal) setInputError(newPasswordInput, newPasswordError, 'Please enter a new password');
      else if (!passwordRegex.test(newVal)) setInputError(newPasswordInput, newPasswordError, 'Min 6 chars, 1 upper & 1 lowercase, 1 num, no spaces, 1 special char - !@#$%^&*');
      else if (newVal === currentVal) setInputError(newPasswordInput, newPasswordError, 'New password cannot be the same as current password');
      else setInputOk(newPasswordInput, newPasswordError);

      if (!confirmVal) setInputError(confirmPasswordInput, confirmPasswordError, 'Please confirm your password');
      else if (confirmVal !== newVal) setInputError(confirmPasswordInput, confirmPasswordError, 'Passwords do not match');
      else setInputOk(confirmPasswordInput, confirmPasswordError);

      // Block if any red borders exist
      const fields = [currentPasswordInput, newPasswordInput, confirmPasswordInput];
      if (fields.some(inp => inp.style.borderColor === 'red')) {
        return;
      }

      authAwareFetch('/profile/change-password', {
        method: 'POST',
        body: JSON.stringify({
          currentPassword: currentVal,
          newPassword: newVal,
          confirmPassword: confirmVal
        }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(async response => {
        if (!response) return null;
        const data = await response.json();
        if (!response.ok) throw data;
        return data;
      })
      .then(data => {
        if (!data) return;
        // Reset form first, then close modal (ensures fields are cleared)
        document.getElementById('change-password-form').reset();
        [currentPasswordInput, newPasswordInput, confirmPasswordInput].forEach(inp => inp.style.borderColor = '');
        clearInputState(currentPasswordInput, currentPasswordError);
        clearInputState(newPasswordInput, newPasswordError);
        clearInputState(confirmPasswordInput, confirmPasswordError);
        // Close modal by clicking the native dismiss button
        document.querySelector('#changePasswordModal [data-dismiss="modal"]').click();
        setTimeout(() => SwalCustom.success('Success', data.message || 'Password changed successfully'), 300);
      })
      .catch(error => {
        if (error.message && error.message.toLowerCase().includes('current password')) {
          setInputError(currentPasswordInput, currentPasswordError, error.message);
        } else if (error.message && error.message.toLowerCase().includes('same')) {
          setInputError(newPasswordInput, newPasswordError, error.message);
        } else {
          SwalCustom.error('Error', error.message || 'Failed to change password');
        }
      });
    });

    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(button => {
      button.addEventListener('click', function() {
        const input = this.closest('.input-group').querySelector('input');
        const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
        input.setAttribute('type', type);
        this.querySelector('i').classList.toggle('fa-eye');
        this.querySelector('i').classList.toggle('fa-eye-slash');
      });
    });

  </script>

</body>

</html>
