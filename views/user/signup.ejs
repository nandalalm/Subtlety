<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup - SUBTLETY</title>
  <!-- Bootstrap CSS CDN -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <!-- Poppins Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/styles/user/signup.css"> <!-- Point to your CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    .auth-card {
      border-radius: 16px;
      border: 1px solid #e8e8e8;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      background: #fff;
      max-height: calc(100vh - 64px);
      overflow-y: auto;
    }

    .auth-title {
      letter-spacing: 0.14em;
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 1.2rem;
      color: #111 !important;
    }

    .password-wrapper {
      position: relative;
    }

    .password-wrapper .input-group {
      position: relative;
      align-items: stretch;
    }

    .password-wrapper .form-control {
      padding-right: 3rem;
    }

    .password-toggle-btn {
      height: 34px;
      width: 34px;
      border: 0;
      background: transparent;
      color: #6b7280;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
      padding: 0;
      appearance: none;
      -webkit-appearance: none;
    }

    .password-toggle-btn:hover {
      color: #111827;
    }

    .password-toggle-btn:focus,
    .password-toggle-btn:active {
      outline: none;
      box-shadow: none !important;
      background: transparent !important;
      border-color: transparent !important;
    }

    .otp-inputs {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 16px;
      width: 100%;
      max-width: 100%;
      overflow: hidden;
    }

    .otp-box {
      width: 42px;
      min-width: 42px;
      height: 46px;
      border: 1px solid #d9d9d9;
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      color: #111;
      outline: none;
      cursor: text;
      border-radius: 12px;
      background: #fff;
      box-shadow: none;
      transition: border-color 0.2s ease, background-color 0.2s ease;
    }

    .otp-box:focus {
      border-color: #111;
      box-shadow: none;
    }

    input:focus {
      box-shadow: none !important;
      /* Removes the box shadow */
    }

    .input-group-append {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      z-index: 10;
      width: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .input-group-append button {
      height: 100%;
      width: 100%;
      border: none;
      background: none;
      box-shadow: none !important;
    }

    .otp-panel {
      margin-top: 1.25rem;
      padding: 0.25rem 0 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .otp-action-btn {
      border-radius: 10px !important;
      font-weight: 600;
      min-height: 44px;
      border: 0;
    }

    .otp-secondary-btn {
      background: #111;
      color: #fff;
      border: 1px solid #111;
    }

    .otp-secondary-btn:hover {
      background: #2c2c2c;
      color: #fff;
    }

    .form-control.is-valid,
    .form-control.is-invalid {
      background-image: none;
      padding-right: 0.75rem;
    }

    #verify-otp.btn-success {
      background: #9135ED;
      color: #fff;
      border: 1px solid #9135ED;
    }

    #verify-otp.btn-success:hover {
      background: #7f22d8;
      color: #fff;
    }

    @media(max-width: 415px) {
      .otp-inputs {
        gap: 6px;
      }

      .otp-box {
        width: 36px;
        min-width: 36px;
        height: 42px;
      }
    }

    @media(max-height: 900px) {
      .auth-card {
        max-height: none;
      }
    }
  </style>
</head>

<body>
  <div class="register-container">
    <div class="auth-card p-4 p-sm-4">
    <h2 class="text-center auth-title">SUBTLETY</h2>
    <form id="signupForm" method="post">
      <div class="form-group">
        <label for="firstname"><small>Firstname</small></label>
        <input type="text" class="form-control" id="firstname" name="firstname" placeholder="Enter firstname" required>
        <small id="firstname-error" class="form-text text-danger" style="display: none;"></small>
      </div>
      <div class="form-group">
        <label for="lastname"><small>Lastname <span class="text-muted">(optional)</span></small></label>
        <input type="text" class="form-control" id="lastname" name="lastname" placeholder="Enter lastname">
        <small id="lastname-error" class="form-text text-danger" style="display: none;"></small>
      </div>
      <div class="form-group">
        <label for="email"><small>Email</small></label>
        <input type="email" class="form-control" id="email" name="email" placeholder="Enter email" required>
        <small id="email-error" class="form-text text-danger" style="display: none;"></small>
      </div>
      <div class="form-group password-wrapper">
        <label for="password"><small>Password</small></label>
        <div class="input-group">
          <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" required>
          <div class="input-group-append">
            <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
          </div>
        </div>
        <small id="password-error" class="form-text text-danger" style="display: none;"></small>
      </div>
      <div class="form-group password-wrapper">
        <label for="confirmPassword"><small>Confirm Password</small></label>
        <div class="input-group">
          <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required>
          <div class="input-group-append">
            <button class="password-toggle-btn toggle-password" type="button"><i class="fa fa-eye"></i></button>
          </div>
        </div>
        <small id="confirm-password-error" class="form-text text-danger" style="display: none;"></small>
      </div>
      <button type="submit" class="btn btn-primary btn-block hello mt-4">Signup</button>
    </form>

    <!-- Loading Spinner -->
    <div id="loading" style="display: none;" class="text-center mt-4">
      <div class="spinner-border" role="status">
        <span class="sr-only">Loading...</span>
      </div>
      <p>Sending your request...</p>
    </div>

    <!-- OTP Section -->
    <div id="otp-section" class="otp-panel" style="display: none;">
      <h3 class="text-center mt-4">Verify Your Email</h3>
      <div class="otp-inputs text-center">
        <input type="text" class="otp-box" id="otp-box-1" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-2" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-3" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-4" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-5" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
        <input type="text" class="otp-box" id="otp-box-6" maxlength="1" pattern="\d*" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'');">
      </div>
      <small id="timer-message" class="text-danger text-center pt-2 pb-2" style="display: none;">OTP valid for 00:60</small>
      <button id="verify-otp" class="btn btn-success btn-block otp-action-btn mt-3">Verify OTP</button>
      <!-- Resend OTP Button -->
      <button id="resend-otp" class="btn btn-secondary btn-block otp-action-btn otp-secondary-btn mt-2" style="display: none;">Resend OTP</button>

      <!-- Loading Spinner for Resend OTP -->
      <div id="resend-loading" style="display: none;" class="text-center mt-2">
        <div class="spinner-border" role="status">
          <span class="sr-only">Resending OTP...</span>
        </div>
        <p>Resending OTP...</p>
      </div>
    </div>

    <p class="text-center mt-3"><small>Already have an account? </small><a href="/auth/login"><small>Login here</small></a></p>
    </div>
  </div>

  <!-- Bootstrap JS and dependencies -->
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <!-- SweetAlert2 and swalHelper -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/swalHelper.js"></script>

  <script>
    const SIGNUP_OTP_STORAGE_KEY = 'signupOtpState';
    const OTP_VALIDITY_MS = 60 * 1000;
    let otpTimeout;

    function setOtpState(email, otpTimestamp) {
      if (!email || !otpTimestamp) return;
      sessionStorage.setItem(SIGNUP_OTP_STORAGE_KEY, JSON.stringify({
        email,
        otpTimestamp,
        expiresAt: Number(otpTimestamp) + OTP_VALIDITY_MS,
        stage: 'otp'
      }));
    }

    function getOtpState() {
      try {
        const raw = sessionStorage.getItem(SIGNUP_OTP_STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch (error) {
        return null;
      }
    }

    function clearOtpState() {
      clearInterval(otpTimeout);
      sessionStorage.removeItem(SIGNUP_OTP_STORAGE_KEY);
    }

    function shouldResumeSignupOtpFlow() {
      const storedState = getOtpState();
      if (!storedState || storedState.stage !== 'otp') {
        return false;
      }

      const navEntry = performance.getEntriesByType('navigation')[0];
      const navType = navEntry ? navEntry.type : '';
      return navType === 'reload' || navType === 'back_forward';
    }

    function showOtpSection() {
      document.getElementById('otp-section').style.display = 'block';
      document.getElementById('signupForm').style.display = 'none';
    }

    function showSignupForm() {
      document.getElementById('otp-section').style.display = 'none';
      document.getElementById('signupForm').style.display = 'block';
    }

    function setFieldMessage(inputId, errorId, message = '', isValid = false) {
      const input = document.getElementById(inputId);
      const errorEl = document.getElementById(errorId);

      input.classList.remove('is-valid', 'is-invalid');
      errorEl.style.display = 'none';

      if (!input.value.trim()) {
        return true;
      }

      if (message) {
        input.classList.add('is-invalid');
        errorEl.textContent = message;
        errorEl.style.display = 'block';
        return false;
      }

      if (isValid) {
        input.classList.add('is-valid');
      }

      return true;
    }

    function getFirstnameMessage(value) {
      if (!value) return '';
      if (/\s/.test(value)) return 'No spaces allowed';
      if (/[^a-zA-Z\s]/.test(value) && /\d/.test(value)) return 'No numbers allowed';
      if (/[^a-zA-Z]/.test(value)) return 'No special characters allowed';
      if (value.length < 4) return 'Min 4 chars required';
      return '';
    }

    function getLastnameMessage(value) {
      const trimmed = value.trim();
      if (!trimmed) return '';
      if (/\d/.test(trimmed)) return 'No numbers allowed';
      if (/\s/.test(trimmed)) return 'No spaces allowed';
      if (/[^a-zA-Z]/.test(trimmed)) return 'No special characters allowed';
      return '';
    }

    function getPasswordMessage(value) {
      if (!value) return '';
      if (/\s/.test(value)) return 'No spaces allowed';
      if (value.length < 6) return 'Min 6 chars required';
      if (!/[A-Z]/.test(value)) return 'One uppercase char required';
      if (!/[a-z]/.test(value)) return 'One lowercase char required';
      if (!/\d/.test(value)) return 'One number required';
      if (!/[!@#$%^&*]/.test(value)) return 'One special char required: ! @ # $ % ^ & *';
      if (/[^A-Za-z\d!@#$%^&*]/.test(value)) return 'Only !@#$%^&* allowed as special chars';
      return '';
    }

    function validateFirstname() {
      const value = document.getElementById('firstname').value.trim();
      const message = getFirstnameMessage(value);
      return setFieldMessage('firstname', 'firstname-error', message, !message && !!value);
    }

    function validateLastname() {
      const rawValue = document.getElementById('lastname').value;
      const trimmedValue = rawValue.trim();
      if (!trimmedValue) {
        document.getElementById('lastname').value = '';
      }
      const message = getLastnameMessage(trimmedValue);
      return setFieldMessage('lastname', 'lastname-error', message, !message && !!trimmedValue);
    }

    function validateEmail() {
      const value = document.getElementById('email').value.trim();
      const message = value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value) ? 'Invalid email format' : '';
      return setFieldMessage('email', 'email-error', message, !message && !!value);
    }

    function validatePassword() {
      const value = document.getElementById('password').value;
      const message = getPasswordMessage(value);
      return setFieldMessage('password', 'password-error', message, !message && !!value);
    }

    function validateConfirmPassword() {
      const value = document.getElementById('confirmPassword').value;
      const password = document.getElementById('password').value;
      let message = '';
      if (value && value !== password) {
        message = 'Passwords do not match';
      }
      return setFieldMessage('confirmPassword', 'confirm-password-error', message, !message && !!value);
    }

    document.getElementById('signupForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const firstnameEl = document.getElementById('firstname');
      const lastnameEl = document.getElementById('lastname');
      const emailEl = document.getElementById('email');
      const passwordEl = document.getElementById('password');
      const confirmPasswordEl = document.getElementById('confirmPassword');

      const firstname = firstnameEl.value.trim();
      const lastname = lastnameEl.value.trim();
      const email = emailEl.value.trim();
      const password = passwordEl.value;
      const confirmPassword = confirmPasswordEl.value;

      let isValid = true;
      isValid = validateFirstname() && isValid;
      isValid = validateLastname() && isValid;
      isValid = validateEmail() && isValid;
      isValid = validatePassword() && isValid;
      isValid = validateConfirmPassword() && isValid;

      if (!isValid) return; // Stop - don't send OTP if any field is invalid

      // All validations passed — proceed to send OTP
      const urlParams = new URLSearchParams(window.location.search);
      const referral = urlParams.get('referral');

      const data = { firstname, lastname, email, password, confirmPassword, referral };

      document.getElementById('loading').style.display = 'block';

      const response = await fetch('/auth/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
      });

      document.getElementById('loading').style.display = 'none';

      if (response.ok) {
        const result = await response.json();
        showOtpSection();
        setOtpState(email, result.otpTimestamp);
        startOtpTimer(result.otpTimestamp);
      } else {
        const error = await response.json().catch(() => ({}));
        SwalCustom.error('Error', error.message || 'Unable to continue signup.');
      }
    });

    function startOtpTimer(otpTimestamp = Date.now()) {
      const timerMessage = document.getElementById('timer-message');
      const resendButton = document.getElementById('resend-otp');
      const expiresAt = Number(otpTimestamp) + OTP_VALIDITY_MS;
      let timeLeft = Math.max(0, Math.ceil((expiresAt - Date.now()) / 1000));

      timerMessage.style.display = 'block'; // Show timer message
      resendButton.style.display = 'none'; // Hide resend button initially
      clearInterval(otpTimeout);

      if (timeLeft <= 0) {
        timerMessage.innerText = 'OTP has expired. Please resend OTP.';
        resendButton.style.display = 'block';
        return;
      }

      timerMessage.innerText = `OTP valid for 00:${timeLeft.toString().padStart(2, '0')}`;

      otpTimeout = setInterval(() => {
        timeLeft--;

        if (timeLeft <= 0) {
          clearInterval(otpTimeout);
          timerMessage.innerText = 'OTP has expired. Please resend OTP.';
          resendButton.style.display = 'block'; // Show resend button
          return;
        }

        timerMessage.innerText = `OTP valid for 00:${timeLeft.toString().padStart(2, '0')}`;
      }, 1000);
    }

    const otpBoxes = document.querySelectorAll('.otp-box');

    otpBoxes.forEach((box, index) => {
      box.addEventListener('input', (e) => {
        if (box.value.length === 1 && index < otpBoxes.length - 1) {
          otpBoxes[index + 1].focus();
        }
      });

      box.addEventListener('keydown', (e) => {
        if (e.key === "Backspace") {
          if (box.value === '' && index > 0) {
            otpBoxes[index - 1].focus();
          }
        }
      });

      box.addEventListener('paste', (e) => {
        e.preventDefault();
        const pasteData = e.clipboardData.getData('text').slice(0, 6).split('');
        pasteData.forEach((char, i) => {
          if (otpBoxes[index + i]) {
            otpBoxes[index + i].value = char;
          }
        });
        const nextIndex = index + pasteData.length;
        if (otpBoxes[nextIndex]) {
          otpBoxes[nextIndex].focus();
        } else if (otpBoxes[otpBoxes.length - 1]) {
          otpBoxes[otpBoxes.length - 1].focus();
        }
      });
    });

    document.getElementById('verify-otp').addEventListener('click', async () => {
      const otp = Array.from(otpBoxes).map(box => box.value).join('');
      const email = document.querySelector('input[name="email"]').value;

      // Get the referral ID from the URL or form (if any)
      const urlParams = new URLSearchParams(window.location.search);
      const referral = urlParams.get('referral'); // Get the referral ID from query params

      const response = await fetch('/auth/verify-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
          email,
          otp,
          referral
        })
      });

      if (response.ok) {
        const data = await response.json();
        clearOtpState();
        SwalCustom.success('Success!', 'OTP verified successfully!').then(() => {
          window.location.href = data.redirect || '/user/home';
        });
      } else {
        const error = await response.json().catch(() => ({}));
        SwalCustom.error('Oops...', error.message || 'Invalid OTP. Please try again.');
      }
    });

    document.getElementById('resend-otp').addEventListener('click', async () => {
      const email = document.querySelector('input[name="email"]').value;


      // Show loading spinner
      document.getElementById('resend-loading').style.display = 'block';
      document.getElementById('resend-otp').style.display = 'none'; // Hide resend button

      const response = await fetch('/auth/resend-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({
          email
        })
      });



      // Hide loading spinner
      document.getElementById('resend-loading').style.display = 'none';

      if (response.ok) {
        const result = await response.json();
        otpBoxes.forEach(box => box.value = ''); // Clear OTP inputs
        otpBoxes[0].focus(); // Focus on the first box
        setOtpState(email, result.otpTimestamp);
        startOtpTimer(result.otpTimestamp); // Restart the timer
      } else {
        const errorData = await response.json(); // Get error message
        SwalCustom.error('Error', `Error resending OTP: ${errorData.message || 'Unknown error'}`);
        console.error('Error resending OTP:', errorData); // Log error data to console
      }
    });

    // Input validation
    function validateInput(input, regex, errorId, successId, errorMessage) {
      const errorElement = document.getElementById(errorId);
      const successElement = document.getElementById(successId);

      if (!regex.test(input.value)) {
        errorElement.textContent = errorMessage;
        errorElement.style.display = 'block';
        successElement.style.display = 'none';
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        return false;
      } else {
        errorElement.style.display = 'none';
        successElement.style.display = 'block';
        input.classList.remove('is-invalid');
        input.classList.add('is-valid');
        return true;
      }
    }

    document.getElementById('firstname').addEventListener('input', validateFirstname);
    document.getElementById('lastname').addEventListener('input', validateLastname);
    document.getElementById('email').addEventListener('input', validateEmail);
    document.getElementById('password').addEventListener('input', function() {
      validatePassword();
      if (document.getElementById('confirmPassword').value) validateConfirmPassword();
    });
    document.getElementById('confirmPassword').addEventListener('input', validateConfirmPassword);

    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(button => {
      button.addEventListener('click', function() {
        const input = this.closest('.input-group').querySelector('input');
        const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
        input.setAttribute('type', type);
        this.querySelector('i').classList.toggle('fa-eye');
        this.querySelector('i').classList.toggle('fa-eye-slash');
      });
    });

    window.addEventListener('pageshow', () => {
      if (!shouldResumeSignupOtpFlow()) {
        clearOtpState();
        showSignupForm();
        return;
      }
      const storedState = getOtpState();

      if (!storedState || !storedState.email || !storedState.otpTimestamp) {
        clearOtpState();
        showSignupForm();
        return;
      }

      setOtpState(storedState.email, storedState.otpTimestamp);
      showOtpSection();
      startOtpTimer(storedState.otpTimestamp);
    });
  </script>
</body>

</html>
