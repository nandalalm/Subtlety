<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Address - SUBTLETY</title>
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/styles/user/userProfile.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    .is-valid { border-color: green !important; }
    .is-invalid { border-color: red !important; }

    .validation-message {
      font-size: 0.875em;
      margin-top: 0.25rem;
      color: #dc3545;
    }

    /* Custom CSS to remove default focus styles */
    input:focus,
    .btn:focus,
    .btn:active {
      box-shadow: none !important;
      outline: none !important;
    }
  </style>
</head>

<body>
  <%- include('../partials/User/navBar') %>
  <section class="profile-section">
    <div class="container profile pt-2">
      <div class="d-flex justify-content-between align-items-center mb-4 breadcrumbs mt-4 mt-lg-0">
        <div>
          <a href="/user/home" class="text-decoration-none">Home</a> /
          <span style="color: #9135ED;" class="text-decoration-none">My Addresses</span>
        </div>
        <div>
          <h5>Welcome, <span style="color: #9135ED;"><%= user.firstname %>!</span></h5>
        </div>
      </div>

      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
          <%- include('../partials/User/userSidebar', { activePage: 'address' }) %>
        </div>

        <div class="col-lg-9 col-12">
          <div id="content">
            <h2 class="section-main-title">My Addresses</h2>
            <div id="manage-address" class="content-section">
              <button class="btn btn-primary mb-3" data-toggle="modal" data-target="#addAddressModal">
                <i class="fas fa-plus mr-2"></i> Add New Address
              </button>
              
              <div id="address-list">
                <% if (typeof addresses !== 'undefined' && addresses.length > 0) { %>
                  <% addresses.forEach(function(address) { %>
                  <div class="address-item mb-3 p-3 border rounded shadow-sm bg-white">
                    <div class="d-flex justify-content-between">
                      <h5 class="text-dark font-weight-bold">
                        <%= address.addressType.charAt(0).toUpperCase() + address.addressType.slice(1) %>
                      </h5>
                      <div>
                        <button class="btn btn-sm btn-outline-warning mr-1" data-toggle="modal" data-target="#editAddressModal" data-id="<%= address._id %>" data-username="<%= address.username %>" data-phone="<%= address.phoneNo %>" data-address="<%= address.address %>" data-country="<%= address.country %>" data-state="<%= address.state %>" data-district="<%= address.district %>" data-pincode="<%= address.pincode %>" data-house-flat-no="<%= address.houseFlatNo %>" data-address-type="<%= address.addressType %>">Edit</button>
                        <button class="btn btn-sm btn-outline-danger delete-address" data-id="<%= address._id %>">Delete</button>
                      </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Name:</strong> <%= address.username %></p>
                            <p class="mb-1"><strong>Phone:</strong> <%= address.phoneNo %></p>
                        </div>
                        <div class="col-md-6">
                             <p class="mb-1"><strong>House/Flat No:</strong> <%= address.houseFlatNo %></p>
                             <p class="mb-1"><strong>Pincode:</strong> <%= address.pincode %></p>
                        </div>
                    </div>
                    <p class="mt-2 mb-1">
                      <strong>Address:</strong> <%= address.address %>, <%= address.district %>, <%= address.state %>, <%= address.country %>
                    </p>
                  </div>
                  <% }) %>
                <% } else { %>
                  <div class="text-center py-5 shadow-sm bg-white rounded border mb-3">
                    <i class="fas fa-map-marker-alt fa-3x mb-3 text-muted"></i>
                    <p class="text-muted mb-0">No addresses added currently.</p>
                  </div>
                <% } %>
              </div>
  
              <!-- Standardized Pagination -->
              <% if (typeof addresses !== 'undefined' && addresses.length > 0) { %>
              <%- include('../partials/Common/pagination') %>
              <% } %>

            <!-- Modal Structure for adding a new address -->
            <div class="modal fade mt-5 pt-4" id="addAddressModal" tabindex="-1" role="dialog" aria-labelledby="addAddressModalLabel" aria-hidden="true">
              <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="addAddressModalLabel">Add New Address</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                    </button>
                  </div>
                  <form id="add-address-form">
                    <div class="modal-body">
                      <div class="form-row">
                        <div class="form-group col-6">
                          <label for="username">Username</label>
                          <input type="text" class="form-control" id="username" name="username" placeholder="Ex: Nandalal">
                          <div class="validation-message" id="username-validation"></div>
                        </div>
                        <div class="form-group col-6">
                          <label for="phoneNo">Phone No</label>
                          <input type="text" class="form-control" id="phoneNo" name="phoneNo" placeholder="Ex: 9207402085" maxlength="10">
                          <div class="validation-message" id="phoneNo-validation"></div>
                        </div>
                      </div>
                      <div class="form-group">
                        <label for="address">Address</label>
                        <input type="text" class="form-control" id="address" name="address" placeholder="Ex: Harinandanam,Ettukandamnilam,CottonmillRoadThiruvannur">
                        <div class="validation-message" id="address-validation"></div>
                      </div>
                      <div class="form-row">
                        <div class="form-group col-4">
                          <label for="country">Country</label>
                          <input type="text" class="form-control" id="country" name="country" placeholder="Ex: India">
                          <div class="validation-message" id="country-validation"></div>
                        </div>
                        <div class="form-group col-4">
                          <label for="state">State</label>
                          <input type="text" class="form-control" id="state" name="state" placeholder="Ex: Kerala">
                          <div class="validation-message" id="state-validation"></div>
                        </div>
                        <div class="form-group col-4">
                          <label for="district">District</label>
                          <input type="text" class="form-control" id="district" name="district" placeholder="Ex: Calicut">
                          <div class="validation-message" id="district-validation"></div>
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-group col-md-4 col-sm-4 col-6">
                          <label for="pincode">Pincode</label>
                          <input type="text" class="form-control" id="pincode" name="pincode" placeholder="Ex: 673029" maxlength="6">
                          <div class="validation-message" id="pincode-validation"></div>
                        </div>
                        <div class="form-group col-md-4 col-sm-4 col-6">
                          <label for="houseFlatNo">House/Flat No</label>
                          <input type="text" class="form-control" id="houseFlatNo" name="houseFlatNo" placeholder="Ex: 3H">
                          <div class="validation-message" id="houseFlatNo-validation"></div>
                        </div>
                        <div class="form-group col-md-4 col-sm-4 col-12">
                          <label>Address Type</label><br>
                          <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="addressType" id="addressTypeHome" value="home">
                            <label class="form-check-label" for="addressTypeHome">Home</label>
                          </div>
                          <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="addressType" id="addressTypeWork" value="work">
                            <label class="form-check-label" for="addressTypeWork">Work</label>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="submit" class="btn btn-primary">Add Address</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <!-- Modal Structure for editing an address -->
            <div class="modal fade mt-5 pt-4" id="editAddressModal" tabindex="-1" role="dialog" aria-labelledby="editAddressModalLabel" aria-hidden="true">
              <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="editAddressModalLabel">Edit Address</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                    </button>
                  </div>
                  <form id="edit-address-form">
                    <input type="hidden" id="edit-address-id">
                    <div class="modal-body">
                      <div class="form-row">
                        <div class="form-group col-6">
                          <label for="edit-username">Username</label>
                          <input type="text" class="form-control" id="edit-username" name="edit-username" placeholder="Ex: Nandalal">
                          <div class="validation-message" id="edit-username-validation"></div>
                        </div>
                        <div class="form-group col-6">
                          <label for="edit-phoneNo">Phone No</label>
                          <input type="text" class="form-control" id="edit-phoneNo" name="edit-phoneNo" placeholder="Ex: 9207402085" maxlength="10">
                          <div class="validation-message" id="edit-phoneNo-validation"></div>
                        </div>
                      </div>
                      <div class="form-group">
                        <label for="edit-address">Address</label>
                        <input type="text" class="form-control" id="edit-address" name="edit-address" placeholder="Ex: Harinandanam,Ettukandamnilam,CottonmillRoadThiruvannur">
                        <div class="validation-message" id="edit-address-validation"></div>
                      </div>
                      <div class="form-row">
                        <div class="form-group col-4">
                          <label for="edit-country">Country</label>
                          <input type="text" class="form-control" id="edit-country" name="edit-country" placeholder="Ex: India">
                          <div class="validation-message" id="edit-country-validation"></div>
                        </div>
                        <div class="form-group col-4">
                          <label for="edit-state">State</label>
                          <input type="text" class="form-control" id="edit-state" name="edit-state" placeholder="Ex: Kerala">
                          <div class="validation-message" id="edit-state-validation"></div>
                        </div>
                        <div class="form-group col-4">
                          <label for="edit-district">District</label>
                          <input type="text" class="form-control" id="edit-district" name="edit-district" placeholder="Ex: Calicut">
                          <div class="validation-message" id="edit-district-validation"></div>
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-group col-md-4 col-sm-4 col-6">
                          <label for="edit-pincode">Pincode</label>
                          <input type="text" class="form-control" id="edit-pincode" name="edit-pincode" placeholder="Ex: 673029" maxlength="6">
                          <div class="validation-message" id="edit-pincode-validation"></div>
                        </div>
                        <div class="form-group col-md-4 col-sm-4 col-6">
                          <label for="edit-houseFlatNo">House/Flat No</label>
                          <input type="text" class="form-control" id="edit-houseFlatNo" name="edit-houseFlatNo" placeholder="Ex: 3H">
                          <div class="validation-message" id="edit-houseFlatNo-validation"></div>
                        </div>
                        <div class="form-group col-md-4 col-sm-4 col-12">
                          <label>Address Type</label><br>
                          <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="edit-addressType" id="edit-addressTypeHome" value="home">
                            <label class="form-check-label" for="edit-addressTypeHome">Home</label>
                          </div>
                          <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="edit-addressType" id="edit-addressTypeWork" value="work">
                            <label class="form-check-label" for="edit-addressTypeWork">Work</label>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="modal-footer">
                      <button type="submit" class="btn btn-primary">Update Address</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/User/footer') %>

  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function validateInput(input, validationId, regex, minLength, maxLength, errorMessage) {
      const value = input.value;
      const validationElement = document.getElementById(validationId);

      if (regex.test(value) && value.length >= minLength && value.length <= maxLength) {
        input.style.borderColor = 'green';
        validationElement.textContent = '';
        validationElement.style.display = 'none';
        return true;
      } else {
        input.style.borderColor = 'red';
        validationElement.textContent = errorMessage;
        validationElement.style.display = 'block';
        return false;
      }
    }

    // Restrict Phone and Pincode to digits only
    ['phoneNo', 'pincode', 'edit-phoneNo', 'edit-pincode'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', function() {
          this.value = this.value.replace(/\D/g, ''); // Remove any non-digit character
        });
      }
    });

    function setupValidation(inputId, validationId, regex, minLength, maxLength, errorMessage) {
      const input = document.getElementById(inputId);
      input.addEventListener('input', () => {
        validateInput(input, validationId, regex, minLength, maxLength, errorMessage);
      });
    }

    // Setup validation for add address form
    setupValidation('username', 'username-validation', /^[a-zA-Z]+$/, 3, 20, 'At least 3 characters (no spaces/numbers).');
    setupValidation('phoneNo', 'phoneNo-validation', /^\d+$/, 10, 10, 'Exactly 10 digits.');
    setupValidation('address', 'address-validation', /^[a-zA-Z0-9,]+$/, 10, 50, '10-50 chars, no spaces, only commas.');
    setupValidation('country', 'country-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).');
    setupValidation('state', 'state-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).');
    setupValidation('district', 'district-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).');
    setupValidation('pincode', 'pincode-validation', /^\d+$/, 6, 6, 'Exactly 6 digits.');
    setupValidation('houseFlatNo', 'houseFlatNo-validation', /^[a-zA-Z0-9]+$/, 1, 10, 'Alpha-numeric only.');

    // Setup validation for edit address form
    setupValidation('edit-username', 'edit-username-validation', /^[a-zA-Z]+$/, 3, 20, 'Username should be 3-20 characters long with no spaces, special characters, or numbers.');
    setupValidation('edit-phoneNo', 'edit-phoneNo-validation', /^\d+$/, 10, 10, 'Phone number should be exactly 10 digits.');
    setupValidation('edit-address', 'edit-address-validation', /^[a-zA-Z0-9,]+$/, 10, 50, 'Address should be 10-50 characters long, with no spaces and only commas allowed as special characters.');
    setupValidation('edit-country', 'edit-country-validation', /^[a-zA-Z]+$/, 4, 15, 'Country should contain 4-15 alphabets (no spaces).');
    setupValidation('edit-state', 'edit-state-validation', /^[a-zA-Z]+$/, 4, 15, 'State should contain 4-15 alphabets (no spaces).');
    setupValidation('edit-district', 'edit-district-validation', /^[a-zA-Z]+$/, 4, 15, 'District should contain 4-15 alphabets (no spaces).');
    setupValidation('edit-pincode', 'edit-pincode-validation', /^\d+$/, 6, 6, 'Pincode should be exactly 6 digits.');
    setupValidation('edit-houseFlatNo', 'edit-houseFlatNo-validation', /^[a-zA-Z0-9]+$/, 1, 10, 'House/Flat No. (no spaces).');

    // Helper to refresh the address list via AJAX
    async function refreshAddressList() {
      try {
        const url = new URL(window.location.href);
        url.searchParams.set('ajax', 'true');
        
        const response = await fetch(url.toString());
        if (!response.ok) throw new Error('Failed to fetch address list');
        
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        // Update the address list container
        const newList = doc.getElementById('address-list');
        const currentList = document.getElementById('address-list');
        if (newList && currentList) {
          currentList.innerHTML = newList.innerHTML;
          // Re-attach delete listeners
          attachDeleteListeners();
        }

        // Update pagination if it exists
        const newPagination = doc.getElementById('paginationContainer');
        const currentPagination = document.getElementById('paginationContainer');
        if (newPagination && currentPagination) {
            currentPagination.innerHTML = newPagination.innerHTML;
            // ajaxTable.js will handle re-initializing pagination via its standard logic if needed,
            // but we might need to manually call initializePagination if it's a new container.
            if (typeof initializePagination === 'function') {
                initializePagination('manage-address'); 
            }
        } else if (!newPagination && currentPagination) {
            currentPagination.innerHTML = ''; // Hide if no longer needed
        }
      } catch (error) {
        console.error('Error refreshing address list:', error);
        // Fallback or show error
      }
    }

    function attachDeleteListeners() {
      document.querySelectorAll('.delete-address').forEach(button => {
        // Remove existing listener first to avoid duplicates if any
        const newButton = button.cloneNode(true);
        button.parentNode.replaceChild(newButton, button);
        
        newButton.addEventListener('click', function() {
          const id = this.getAttribute('data-id');
          Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
          }).then((result) => {
            if (result.isConfirmed) {
              fetch(`/profile/address/delete/${id}`, {
                  method: 'DELETE',
                })
                .then(response => response.ok ? response.json() : Promise.reject('Delete failed'))
                .then(data => {
                  Swal.fire('Deleted!', 'Your address has been deleted.', 'success');
                  refreshAddressList();
                })
                .catch(error => {
                  console.error('Error:', error);
                  Swal.fire('Error!', 'There was a problem deleting the address.', 'error');
                });
            }
          });
        });
      });
    }

    // Initial attachment
    attachDeleteListeners();

    // Population of Edit Modal
    let modalTriggerBtn = null;
    $('#editAddressModal').on('show.bs.modal', function(event) {
      modalTriggerBtn = $(event.relatedTarget);
      const button = modalTriggerBtn;
      const modal = $(this);
      
      modal.find('#edit-address-id').val(button.data('id'));
      modal.find('#edit-username').val(button.data('username'));
      modal.find('#edit-phoneNo').val(button.data('phone'));
      modal.find('#edit-address').val(button.data('address'));
      modal.find('#edit-country').val(button.data('country'));
      modal.find('#edit-state').val(button.data('state'));
      modal.find('#edit-district').val(button.data('district'));
      modal.find('#edit-pincode').val(button.data('pincode'));
      modal.find('#edit-houseFlatNo').val(button.data('house-flat-no'));
      
      const type = button.data('address-type');
      if (type === 'home') modal.find('#edit-addressTypeHome').prop('checked', true);
      else if (type === 'work') modal.find('#edit-addressTypeWork').prop('checked', true);
      
      // Trigger live validation for all fields upon population
      const fields = [
        ['edit-username', 'edit-username-validation', /^[a-zA-Z]+$/, 3, 20, 'At least 3 characters (no spaces/numbers).'],
        ['edit-phoneNo', 'edit-phoneNo-validation', /^\d+$/, 10, 10, 'Exactly 10 digits.'],
        ['edit-address', 'edit-address-validation', /^[a-zA-Z0-9,]+$/, 10, 50, '10-50 chars, no spaces, only commas.'],
        ['edit-country', 'edit-country-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-state', 'edit-state-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-district', 'edit-district-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-pincode', 'edit-pincode-validation', /^\d+$/, 6, 6, 'Exactly 6 digits.'],
        ['edit-houseFlatNo', 'edit-houseFlatNo-validation', /^[a-zA-Z0-9]+$/, 1, 10, 'Alpha-numeric only.']
      ];
      
      fields.forEach(f => {
        const input = document.getElementById(f[0]);
        validateInput(input, f[1], f[2], f[3], f[4], f[5]);
      });
    });

    // Cleanup modals on hide
    $('#addAddressModal, #editAddressModal').on('hidden.bs.modal', function() {
      const form = $(this).find('form')[0];
      if (form) form.reset();
      $(this).find('.form-control').css('border-color', '');
      $(this).find('.validation-message').text('').hide();
      if (modalTriggerBtn) {
        modalTriggerBtn.blur();
        modalTriggerBtn = null;
      }
    });

    // Handle the add address form submission
    document.getElementById('add-address-form').addEventListener('submit', function(e) {
      e.preventDefault(); 

      const config = [
        ['username', 'username-validation', /^[a-zA-Z]+$/, 3, 20, 'At least 3 characters (no spaces/numbers).'],
        ['phoneNo', 'phoneNo-validation', /^\d+$/, 10, 10, 'Exactly 10 digits.'],
        ['address', 'address-validation', /^[a-zA-Z0-9,]+$/, 10, 50, '10-50 chars, no spaces, only commas.'],
        ['country', 'country-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['state', 'state-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['district', 'district-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['pincode', 'pincode-validation', /^\d+$/, 6, 6, 'Exactly 6 digits.'],
        ['houseFlatNo', 'houseFlatNo-validation', /^[a-zA-Z0-9]+$/, 1, 10, 'Alpha-numeric only.']
      ];

      let isValid = true;
      config.forEach(f => {
        if (!validateInput(document.getElementById(f[0]), f[1], f[2], f[3], f[4], f[5])) isValid = false;
      });

      // Special check for radio buttons
      const addressType = document.querySelector('input[name="addressType"]:checked');
      if (!addressType) {
        isValid = false;
        // You might want to show an error for radio too, but typically at least one is often defaulted.
      }

      if (!isValid) return;

      const form = {
        username: document.getElementById('username').value,
        phoneNo: document.getElementById('phoneNo').value,
        address: document.getElementById('address').value,
        country: document.getElementById('country').value,
        state: document.getElementById('state').value,
        district: document.getElementById('district').value,
        pincode: document.getElementById('pincode').value,
        houseFlatNo: document.getElementById('houseFlatNo').value,
        addressType: addressType.value
      };

      fetch('/profile/address/add', {
          method: 'POST',
          body: JSON.stringify(form),
          headers: { 'Content-Type': 'application/json' },
        })
        .then(response => response.ok ? response.json() : Promise.reject('Add failed'))
        .then(data => {
          $('#addAddressModal').modal('hide');
          this.reset(); // Clear form
          Swal.fire('Success!', 'Address added successfully', 'success');
          refreshAddressList();
        })
        .catch(error => {
          console.error('Error:', error);
          Swal.fire('Error!', 'Failed to add address', 'error');
        });
    });

    // Handle the edit address form submission
    document.getElementById('edit-address-form').addEventListener('submit', function(e) {
      e.preventDefault();

      const config = [
        ['edit-username', 'edit-username-validation', /^[a-zA-Z]+$/, 3, 20, 'At least 3 characters (no spaces/numbers).'],
        ['edit-phoneNo', 'edit-phoneNo-validation', /^\d+$/, 10, 10, 'Exactly 10 digits.'],
        ['edit-address', 'edit-address-validation', /^[a-zA-Z0-9,]+$/, 10, 50, '10-50 chars, no spaces, only commas.'],
        ['edit-country', 'edit-country-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-state', 'edit-state-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-district', 'edit-district-validation', /^[a-zA-Z]+$/, 4, 15, '4-15 alphabets (no spaces).'],
        ['edit-pincode', 'edit-pincode-validation', /^\d+$/, 6, 6, 'Exactly 6 digits.'],
        ['edit-houseFlatNo', 'edit-houseFlatNo-validation', /^[a-zA-Z0-9]+$/, 1, 10, 'Alpha-numeric only.']
      ];

      let isValid = true;
      config.forEach(f => {
        if (!validateInput(document.getElementById(f[0]), f[1], f[2], f[3], f[4], f[5])) isValid = false;
      });

      const addressType = document.querySelector('input[name="edit-addressType"]:checked');
      if (!addressType) isValid = false;

      if (!isValid) return;

      const id = document.getElementById('edit-address-id').value;
      const form = {
        username: document.getElementById('edit-username').value,
        phoneNo: document.getElementById('edit-phoneNo').value,
        address: document.getElementById('edit-address').value,
        country: document.getElementById('edit-country').value,
        state: document.getElementById('edit-state').value,
        district: document.getElementById('edit-district').value,
        pincode: document.getElementById('edit-pincode').value,
        houseFlatNo: document.getElementById('edit-houseFlatNo').value,
        addressType: addressType.value
      };

      fetch(`/profile/address/edit/${id}`, {
          method: 'PUT',
          body: JSON.stringify(form),
          headers: { 'Content-Type': 'application/json' },
        })
        .then(response => response.ok ? response.json() : Promise.reject('Edit failed'))
        .then(data => {
          $('#editAddressModal').modal('hide');
          Swal.fire('Success!', 'Address updated successfully', 'success');
          refreshAddressList();
        })
        .catch(error => {
          console.error('Error:', error);
          Swal.fire('Error!', 'Failed to update address', 'error');
        });
    });

  </script>

</body>

</html>