<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wallet - SUBTLETY</title>
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/user/userProfile.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"> <!-- Font Awesome CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.11.2/toastify.min.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <style>
    body {
      background-color: #f4f4f4;
    }

    .referral-section {
      margin-top: 20px;
      padding: 25px;
      background-color: #ffffff;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      border-left: 5px solid #9135ED;
      position: relative;
      transition: all 0.3s;
    }
    .referral-section.claimed {
      background-color: #f8f9fa;
      border-left-color: #adb5bd;
      opacity: 0.5;
      filter: grayscale(0.6);
    }
    .referral-section.claimed .copy-btn {
      background-color: #adb5bd;
      cursor: default;
    }
    .referral-section.claimed .copy-btn:hover {
      background-color: #adb5bd;
    }
    .claimed-badge {
      background-color: #e6ffed;
      color: #1e7e34;
      border: 1px solid #c3e6cb;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      position: absolute;
      top: 20px;
      right: 25px;
    }

    .copy-btn {
      background-color: #9135ED;
      color: white;
      border: none;
      padding: 8px 15px;
      border-radius: 0 5px 5px 0;
      cursor: pointer;
      transition: background 0.3s;
    }
    .copy-btn:hover { background-color: #7a2bc7; }


    .wallet-toggle-container {
      display: flex;
      gap: 15px;
      margin-top: 0px !important;
      margin-left: -5px;
      margin-bottom: 15px;
      border-bottom: 2px solid #eee;
      padding-bottom: 10px;
    }

    .toggle-btn {
      padding: 10px 20px;
      border: none;
      background: transparent;
      color: #777;
      font-weight: 600;
      cursor: pointer;
      position: relative;
      transition: all 0.3s;
      outline: none !important;
    }

    .toggle-btn.active {
      color: #9135ED;
    }

    .toggle-btn.active::after {
      content: '';
      position: absolute;
      bottom: -12px;
      left: 0;
      width: 100%;
      height: 3px;
      background: #9135ED;
    }

    .wallet-content-section {
      display: none;
    }

    .wallet-content-section.active {
      display: block;
    }

    .balance-card {
      background: #fff;
      padding: 30px;
      text-align: center;
      margin-bottom: 20px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
      border-radius: 12px;
    }


    .text-purple { color: #9135ED; }

    @media (max-width: 576px) {
      .toggle-btn {
        font-size: 0.8rem;
        padding: 10px 10px;
      }
      .wallet-toggle-container {
        gap: 5px;
      }
    }

  </style>
</head>

<body>

  <%- include('../partials/User/navBar') %>
  <!-- Wallet Section -->
  <section class="profile-section">
    <div class="container profile pt-2">
      <div class="d-flex justify-content-between align-items-center mb-4 breadcrumbs mt-4 mt-lg-0">
        <div>
          <a href="/user/home" class="text-decoration-none">Home</a> /
          <span style="color: #9135ED; font-weight: 500;">My Wallet</span>
        </div>
        <div>
          <h5>Welcome, <span style="color: #9135ED;"><%= user.firstname %>!</span></h5>
        </div>
      </div>
      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
          <%- include('../partials/User/userSidebar', { activePage: 'wallet' }) %>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9 col-12">
            <h2 class="section-main-title">My Wallet</h2>

            <div class="wallet-toggle-container">
                <button class="toggle-btn" id="toggle-wallet" onclick="switchWalletTab('wallet')">WALLET</button>
                <button class="toggle-btn" id="toggle-transactions" onclick="switchWalletTab('transactions')">TRANSACTION HISTORY</button>
            </div>

            <!-- WALLET TAB CONTENT -->
            <div id="section-wallet" class="wallet-content-section">
                <div class="balance-card">
                    <h5 class="text-muted text-uppercase small mb-2">Available Balance</h5>
                    <h2 class="mb-0 font-weight-bold" style="color: #333; font-size: 2.5rem;">₹<%= Math.floor(wallet.balance || 0) %></h2>
                </div>

                <div class="referral-section <%= user.referralCreditsClaimed ? 'claimed' : '' %>" style="min-height: 230px;">
                    <% if (user.referralCreditsClaimed) { %>
                        <span class="claimed-badge"><i class="fas fa-check-circle mr-1"></i> CLAIMED</span>
                    <% } %>
                    <h4 class="font-weight-bold" style="color: #333;">Refer a Friend and Earn ₹600!</h4>
                    <p class="text-muted">
                        Share your referral link with your friends. If they sign up using this link, you will earn a ₹600 reward in your wallet. This offer is valid only once per user.
                    </p>
                    <div class="d-flex align-items-center mt-3">
                        <input type="text" id="referral-link" class="form-control" style="border-radius: 5px 0 0 5px;" value="<%= referralBaseUrl %>/user/signup?referral=<%= user._id %>" readonly <%= user.referralCreditsClaimed ? 'disabled' : '' %>>
                        <button class="copy-btn" <%= user.referralCreditsClaimed ? 'disabled' : '' %> onclick="copyReferralLink()"><i class="far fa-copy"></i></button>
                    </div>
                </div>
            </div>

            <!-- TRANSACTIONS TAB CONTENT -->
            <div id="section-transactions" class="wallet-content-section">
                <!-- Search & Sort Bar -->
                <% if (totalTransactionsUnfiltered > 0) { %>
                <div class="row mt-1 mb-3 align-items-start">
                  <!-- Search -->
                  <div class="col-lg-5 col-md-12 mb-2">
                    <%- include('../partials/Common/searchBar', {
                      searchInputId: 'walletSearchInput',
                      searchContainerId: 'walletTableContainer',
                      searchPlaceholder: 'Search by ID...',
                      searchValue: search || '',
                      searchBasePath: 'wallet'
                    }) %>
                  </div>
                  <!-- Sort -->
                  <div class="col-lg-3 col-md-6 mb-2">
                    <div class="filter-sort-pill">
                      <select id="walletSortSelect" onchange="applyAjaxFilter('walletTableContainer', 'sort', this.value, 'wallet'); document.getElementById('clearWalletSortBtn').style.display=this.value!=='latest'?'flex':'none';">
                        <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Latest</option>
                        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                        <option value="credit" <%= sort === 'credit' ? 'selected' : '' %>>Credit</option>
                        <option value="debit" <%= sort === 'debit' ? 'selected' : '' %>>Debit</option>
                      </select>
                      <button id="clearWalletSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                        style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                        onclick="clearAjaxFilter('walletTableContainer', 'sort', 'wallet'); this.style.display='none'; document.getElementById('walletSortSelect').value='latest';">
                        <i class="fas fa-times"></i>
                      </button>
                    </div>
                  </div>
                </div>
                <% } %>

                <div id="walletTableContainer">
                    <%- include('../partials/User/walletTable') %>
                </div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/User/footer') %>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.11.2/toastify.min.js"></script>
  <script src="/js/ajaxTable.js"></script>

  <script>
    // Tab Switching Logic with Persistence
    function switchWalletTab(tabName) {
        // Save to localStorage
        localStorage.setItem('walletActiveTab', tabName);

        // Update Buttons
        document.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById('toggle-' + tabName).classList.add('active');

        // Update Content
        document.querySelectorAll('.wallet-content-section').forEach(sec => sec.classList.remove('active'));
        document.getElementById('section-' + tabName).classList.add('active');
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Check for persisted tab, default to 'wallet'
        const activeTab = localStorage.getItem('walletActiveTab') || 'wallet';
        
        // If sorting or searching is active, force 'transactions' tab
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('search') || urlParams.has('sort') || urlParams.has('page')) {
            switchWalletTab('transactions');
        } else {
            switchWalletTab(activeTab);
        }
    });

    // Search, Sort, and Pagination is now handled by /js/ajaxTable.js

    function copyReferralLink() {
      const referralLink = document.getElementById('referral-link');
      if (referralLink.disabled) return;
      
      const linkUrl = referralLink.value;

      navigator.clipboard.writeText(linkUrl).then(function() {
        Toastify({
          text: "Referral link copied!",
          duration: 3000,
          close: true,
          gravity: "top",
          position: "right",
          backgroundColor: "#9135ED",
          stopOnFocus: true,
        }).showToast();
      }).catch(function(err) {
        console.error('Copy failed', err);
      });
    }
</script>
</body>
</html>
