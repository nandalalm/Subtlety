<style>
    .pagination .btn-pagination {
        border-radius: 5px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #9135ED;
        color: #9135ED;
        background: transparent;
        transition: all 0.3s ease;
        text-decoration: none !important;
        flex: none !important;
    }
    .pagination .btn-pagination:hover:not(.disabled) {
        background-color: #9135ED !important;
        color: white !important;
    }
    .pagination .btn-pagination.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

<div class="pagination d-flex justify-content-center align-items-center mt-4 mb-2" style="gap: 5px;">
    <% 
        // Helper to build the URL with the current query parameters but a different page
        function getPageUrl(pageNum) {
            return `?page=${pageNum}${typeof search !== 'undefined' && search ? '&search=' + search : ''}${typeof sort !== 'undefined' && sort ? '&sort=' + sort : ''}${typeof paymentStatus !== 'undefined' && paymentStatus ? '&paymentStatus=' + paymentStatus : ''}${typeof category !== 'undefined' && category && category !== 'all' ? '&category=' + category : ''}`;
        }
    %>
    
    <a href="<%= currentPage > 1 ? getPageUrl(currentPage - 1) : '#' %>" 
       class="btn-pagination <%= currentPage === 1 ? 'disabled' : '' %>">
        <i class="fas fa-chevron-left"></i>
    </a>
    
    <span class="page-number text-center mx-3 font-weight-bold" 
          style="color: #9135ED; min-width: 80px; font-size: 0.95rem;">
        <%= currentPage %> of <%= totalPages %>
    </span>
    
    <a href="<%= currentPage < totalPages ? getPageUrl(currentPage + 1) : '#' %>" 
       class="btn-pagination <%= currentPage >= totalPages ? 'disabled' : '' %>">
        <i class="fas fa-chevron-right"></i>
    </a>
</div>
