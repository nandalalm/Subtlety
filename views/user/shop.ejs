<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="user-id" content="<%= user ? user._id : '' %>">
  <title>Explore Our Products - SUBTLETY</title>
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/user/home.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <style>
    .out-of-stock { opacity: 0.6; }
    .out-of-stock-label {
      position: absolute; top: 10px; right: 10px;
      background-color: red; color: white;
      padding: 5px 10px; border-radius: 4px;
      font-size: 12px; font-weight: bold;
    }
    .offer-badge {
      position: absolute; top: 10px; left: 10px;
      background-color: #28a745; color: white;
      padding: 5px 10px; border-radius: 4px;
      font-size: 12px; font-weight: bold;
    }
    .original-price { text-decoration: line-through; color: #6c757d; font-size: 0.9em; }
    .discounted-price { color: #28a745; font-weight: bold; }
    /* Shop filter bar */
    .shop-filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: flex-end;
      margin-bottom: 20px;
      background-color: #f8f9fa;
      padding: 14px 16px;
      border-radius: 10px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.07);
    }
    .shop-filter-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #6c757d;
      margin-bottom: 4px;
    }
    .shop-filter-item {
      min-width: 200px;
      flex: 1 1 220px;
      max-width: 280px;
    }
    .shop-filter-actions {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      margin-left: auto;
      flex: 0 0 auto;
    }
    .shop-clear-all-btn {
      height: 44px;
      min-width: 120px;
      padding: 0 18px;
      border: 1px solid #cfd4da;
      background: #e9ecef;
      color: #495057;
      border-radius: 8px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      line-height: 1;
      white-space: nowrap;
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    }
    .shop-clear-all-btn:hover {
      background: #dee2e6;
      border-color: #c2c8cf;
      color: #343a40;
    }
    .shop-clear-all-btn:focus {
      outline: none;
      box-shadow: none;
    }
    
    /* Shop Search Responsiveness */
    #search {
        height: 44px;
        width: 350px;
        background: transparent !important;
        color: white !important;
        border: 1px solid white !important;
        border-radius: 5px 0 0 5px !important;
        padding: 10px;
        padding-right: 35px;
        transition: width 0.3s;
    }
    #search:focus {
        background: transparent !important;
        box-shadow: none !important;
        outline: none !important;
    }
    #search-btn {
        background-color: #9135ED !important;
        color: white !important;
        border-radius: 0 5px 5px 0 !important;
        height: 44px;
        border: 1px solid #9135ED !important;
        padding: 0 25px;
        font-weight: 500;
        margin-left: 2px;
    }

    @media(max-width: 930px) {
        #search { width: 250px; }
    }
    @media(max-width: 576px) {
        #search { width: 155px; padding: 8px; padding-right: 25px; }
        #search-btn { padding: 0 15px; }
        .shop-filter-bar {
          align-items: stretch;
        }
        .shop-filter-item {
          min-width: 100%;
          max-width: 100%;
        }
        .shop-filter-actions {
          margin-left: 0;
          width: 100%;
          justify-content: stretch;
        }
        .shop-clear-all-btn { width: 100%; }
    }

    @media (min-width: 577px) and (max-width: 991px) {
      .shop-filter-actions {
        margin-left: 0;
      }
    }
  </style>
</head>

<body>
  <%- include('../partials/User/navBar') %>

  <section style="height: 380px !important;" class="hero-section text-center py-5" style="background-color: black;">
    <div class="container">
      <h1 style="color: #9135ED;" class="pt-5">Explore Our Products</h1>
      <div class="search-bar mt-4 text-center">
        <div class="d-inline-flex align-items-center" style="position: relative;">
            <div style="position: relative;">
                <input type="text" placeholder="Search for Merch.." value="<%= search || '' %>" id="search" name="search" />
                
                <span id="clearSearchBtn" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; color: rgba(255,255,255,0.7); z-index: 10; display: <%= (search && search.trim()) ? 'block' : 'none' %>;" 
                      onclick="document.getElementById('search').value=''; this.style.display='none'; clearAjaxFilter('product-grid', 'search', 'user/shop')" title="Clear search">
                    <i class="fas fa-times"></i>
                </span>
            </div>
            <button type="button" id="search-btn" class="btn">Search</button>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <!-- Filter Bar -->
    <div class="shop-filter-bar mt-3">

      <!-- Filter by Category -->
      <div class="shop-filter-item">
        <div class="shop-filter-label"><i class="fas fa-filter mr-1"></i>Category</div>
        <div class="filter-sort-pill">
          <select id="categorySelect" onchange="applyAjaxFilter('product-grid', 'category', this.value, 'user/shop'); document.getElementById('clearCategoryBtn').style.display=this.value!=='all'?'flex':'none';">
            <option value="all" <%= category === 'all' || !category ? 'selected' : '' %>>All Categories</option>
            <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>" <%= category === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
          <button id="clearCategoryBtn" type="button" class="sort-clear-inner" title="Clear category"
            style="display:<%= (category && category !== 'all') ? 'flex' : 'none' %>;"
            onclick="clearAjaxFilter('product-grid', 'category', 'user/shop'); this.style.display='none'; document.getElementById('categorySelect').value='all';">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>

      <!-- Sort By -->
      <div class="shop-filter-item">
        <div class="shop-filter-label"><i class="fas fa-sort mr-1"></i>Sort by</div>
        <div class="filter-sort-pill">
          <select id="shopSortSelect" onchange="applyAjaxFilter('product-grid', 'sort', this.value, 'user/shop'); document.getElementById('clearShopSortBtn').style.display=this.value!=='latest'?'flex':'none';">
            <option value="latest" <%= !sort || sort === 'latest' ? 'selected' : '' %>>Latest Arrivals</option>
            <option value="priceLowToHigh" <%= sort === 'priceLowToHigh' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="priceHighToLow" <%= sort === 'priceHighToLow' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="aToZ" <%= sort === 'aToZ' ? 'selected' : '' %>>A → Z</option>
            <option value="zToA" <%= sort === 'zToA' ? 'selected' : '' %>>Z → A</option>
          </select>
          <button id="clearShopSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
            style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
            onclick="clearAjaxFilter('product-grid', 'sort', 'user/shop'); this.style.display='none'; document.getElementById('shopSortSelect').value='latest';">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>

      <div class="shop-filter-actions">
        <button
          type="button"
          id="shopClearAllBtn"
          class="shop-clear-all-btn"
          style="display: <%= (search && search.trim()) || (sort && sort !== 'latest') || (category && category !== 'all') ? 'inline-flex' : 'none' %>;"
          onclick="clearAllShopFilters()">
          Clear All
        </button>
      </div>

    </div>

    <!-- AJAX Target Container -->
    <div id="product-grid" class="mt-4 mb-5 pb-5">
        <%- include('../partials/User/productGrid') %>
    </div>
  </div>

  <%- include('../partials/User/footer') %>

  <script src="https://code.jquery.com/jquery-3.5.2.slim.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="/js/cartControls.js"></script>
  <script src="/js/ajaxTable.js"></script>
  <script>
    let currentPage = 1;
    const itemsPerPage = 8;

    async function loadMoreProducts() {
      const btn = document.getElementById('load-more-btn');
      if (!btn) return;

      currentPage++;
      btn.disabled = true;
      btn.innerHTML = 'Loading...';

      const url = new URL(window.location.href);
      url.searchParams.set('ajax', 'true');
      url.searchParams.set('append', 'true');
      url.searchParams.set('page', currentPage);
      url.searchParams.set('limit', itemsPerPage);

      try {
        const response = await fetch(url.toString());
        if (!response.ok) throw new Error('Failed to load more products');
        
        const html = await response.text();
        const container = document.getElementById('products-list-inner');
        if (container) {
          container.insertAdjacentHTML('beforeend', html);
        }

        // We need to know if there's more. The server can send a header or we can check the response length.
        // For simplicity, let's assume if we get < 8 items, there's no more.
        // But a better way is to have the controller return a 'hasMore' flag in a header.
        const hasMore = response.headers.get('X-Has-More') === 'true';
        const loadMoreContainer = document.getElementById('load-more-container');
        if (!hasMore && loadMoreContainer) {
          loadMoreContainer.style.display = 'none';
        }
      } catch (error) {
        console.error('Error loading more products:', error);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = 'Load More';
        }
      }
    }

    // Override the generic applyAjaxFilter for this page to maintain the current limit
    const originalApplyAjaxFilter = applyAjaxFilter;
    window.applyAjaxFilter = function(containerId, param, value, basePath) {
      const url = new URL(window.location.href);
      if (basePath) {
        const absolutePath = basePath.startsWith('/') ? basePath : `/${basePath}`;
        url.pathname = absolutePath;
      }

      if (value === '' || value === 'all') {
        url.searchParams.delete(param);
        if (param === 'search') {
          const clearBtn = document.getElementById('clearSearchBtn');
          if (clearBtn) clearBtn.style.display = 'none';
        }
      } else {
        url.searchParams.set(param, value);
        if (param === 'search') {
          const clearBtn = document.getElementById('clearSearchBtn');
          if (clearBtn) clearBtn.style.display = 'block';
        }
      }
      
      // Reset page to 1 but keep the total limit loaded so far
      url.searchParams.set('page', '1');
      url.searchParams.set('limit', currentPage * itemsPerPage);
      
      const newUrl = `${url.pathname}${url.search}`;
      refreshTable(containerId, newUrl);
      window.history.pushState({}, '', newUrl);
      updateClearAllButtonVisibility();
    };

    function updateClearAllButtonVisibility() {
      const searchInput = document.getElementById('search');
      const sortSelect = document.getElementById('shopSortSelect');
      const categorySelect = document.getElementById('categorySelect');
      const clearAllBtn = document.getElementById('shopClearAllBtn');

      if (!clearAllBtn) return;

      const hasSearch = searchInput && searchInput.value.trim() !== '';
      const hasSort = sortSelect && sortSelect.value !== 'latest';
      const hasCategory = categorySelect && categorySelect.value !== 'all';

      clearAllBtn.style.display = hasSearch || hasSort || hasCategory ? 'inline-flex' : 'none';
    }

    window.clearAllShopFilters = function() {
      const searchInput = document.getElementById('search');
      const clearSearchBtn = document.getElementById('clearSearchBtn');
      const sortSelect = document.getElementById('shopSortSelect');
      const clearSortBtn = document.getElementById('clearShopSortBtn');
      const categorySelect = document.getElementById('categorySelect');
      const clearCategoryBtn = document.getElementById('clearCategoryBtn');
      const url = new URL(window.location.href);

      if (searchInput) searchInput.value = '';
      if (clearSearchBtn) clearSearchBtn.style.display = 'none';
      if (sortSelect) sortSelect.value = 'latest';
      if (clearSortBtn) clearSortBtn.style.display = 'none';
      if (categorySelect) categorySelect.value = 'all';
      if (clearCategoryBtn) clearCategoryBtn.style.display = 'none';

      url.searchParams.delete('search');
      url.searchParams.delete('sort');
      url.searchParams.delete('category');
      url.searchParams.set('page', '1');
      url.searchParams.set('limit', currentPage * itemsPerPage);

      const newUrl = `${url.pathname}${url.search}`;
      refreshTable('product-grid', newUrl);
      window.history.pushState({}, '', newUrl);
      updateClearAllButtonVisibility();
    };

    document.addEventListener('DOMContentLoaded', () => {
      const searchButton = document.getElementById('search-btn');
      const searchInput = document.getElementById('search');

      if (searchButton && searchInput) {
        searchButton.addEventListener('click', () => {
          applyAjaxFilter('product-grid', 'search', searchInput.value.trim(), 'user/shop');
        });
        searchInput.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            applyAjaxFilter('product-grid', 'search', searchInput.value.trim(), 'user/shop');
          }
        });
        searchInput.addEventListener('input', updateClearAllButtonVisibility);
      }

      updateClearAllButtonVisibility();
    });
  </script>

</body>

</html>
