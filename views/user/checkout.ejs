<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout - SUBTLETY</title>
  <!-- Bootstrap CSS -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Google Fonts: Poppins -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" />
  <!-- SweetAlert2 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

  <style>
    body {
      height: 100% !important;
      margin: 0;
      padding: 0;
      font-family: "Poppins", sans-serif !important;
      /* Apply Poppins font globally */
      background-color: #f4f4f4 !important;
    }

    .checkout {
      padding-top: 100px !important;
      padding-bottom: 100px !important;
      height: 100% !important;
      flex-grow: 1 !important;
    }

    .container {
      width: 95% !important;
    }

    .summary-card {
      margin-bottom: 20px;
      border: 1px solid #ddd;
      padding: 15px;
      border-radius: 5px;
    }

    .address-field {
      margin-bottom: 15px;
    }

    .product-summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 5px;
      padding: 5px 10px;
      border: 1px solid #ddd;
      border-radius: 5px;
    }

    .product-summary img {
      width: 50px;
      margin-right: 20px;
      border-radius: 7px;
    }

    .product-details {
      text-align: left;
      flex-grow: 1;
      width: 50%;
    }

    .product-price {
      text-align: right;
      width: 80px;
    }

    .pricing-summary {
      margin-top: 10px;
    }

    .quantity-details {
      text-align: center;
      width: 50px;
    }

    .list-group-item {
      padding: 2px 10px;
      border: none;
      background: transparent;
    }

    .error-message {
      color: red;
      font-size: 0.9em;
    }

    body>section>div>div.mb-5>a {
      color: black !important;
    }

    body>section>div>div.mb-5>a:hover {
      color: #9135ed !important;
      /* Change color on hover */
    }

    .form-control.is-invalid {
      border-color: #dc3545;
    }

    .form-control.is-valid {
      border-color: #28a745;
    }

    .product-unavailable {
      background-color: #ffeeee;
      color: #ff0000;
    }

    .coupon-flex {
      display: flex;
      align-items: stretch;
      gap: 10px;
    }

    input#couponCode {
      flex: 1;
      min-width: 150px;
      padding: 10px 15px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 0.9rem;
      transition: border-color 0.3s;
    }

    input#couponCode:focus {
      border-color: #9135ED;
      outline: none;
    }

    .apply-btn {
      padding: 10px 20px;
      background-color: #9135ED;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s;
    }

    .apply-btn:hover {
      background-color: #7b2cc8;
      transform: translateY(-1px);
    }

    .applied-coupon-badge {
      display: none;
      background-color: #f0fdf4;
      border: 1px dashed #22c55e;
      padding: 10px 15px;
      border-radius: 8px;
      margin-top: 5px;
      animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .coupon-info {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #166534;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .remove-coupon-link {
        color: #ef4444;
        font-size: 0.8rem;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background 0.2s;
    }

    .remove-coupon-link:hover {
        background: #fee2e2;
        text-decoration: none;
        color: #dc2626;
    }
  </style>
</head>

<body>
  <!-- Navbar -->
  <%- include('../partials/User/navBar') %>

  <section class="checkout">
    <div class="container mt-2 checkout-container">
      <div class="mb-5">
        <a href="/user/home" class="text-decoration-none">Home</a> /
        <a href="/cart" class="text-decoration-none">Cart</a> /
        <a href="/orders/checkout" class="text-decoration-none">Checkout</a>
      </div>
      <% if (locals.message) { %>
      <div class="alert alert-warning alert-dismissible fade show shadow-sm border-0" role="alert" style="background-color: #fff3cd; color: #856404; border-left: 5px solid #ffc107 !important;">
        <i class="fas fa-exclamation-triangle mr-2"></i> <strong>Price Update:</strong> <%= message %>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %>
      <div class="row mt-3">
        <div class="col-md-6">
          <% if(address && address.length > 0){ %>
          <h5>Select Saved Address</h5>
          <select class="form-control" id="addressSelect" onchange="populateAddress()" style="white-space: normal; height: auto; min-height: 38px;">
            <option value="">Select an address</option>
            <% address.forEach(address =>{ %>
            <option value="<%= address.username %>" data-email="<%= address.email %>" data-address="<%= address.houseFlatNo %>,<%= address.address %>,<%= address.district %>,<%= address.state %>,<%= address.country %>" data-pincode="<%= address.pincode %>" data-phone="<%= address.phoneNo %>">
              <%= address.username %> - <%= address.address.substring(0, 30) %>...
            </option>
            <% }) %>
          </select>
          <% } %>

          <h5 class="mt-4">Shipping Information</h5>
          <form id="shippingForm">
            <div class="form-group">
              <label for="fullName">Username</label>
              <input type="text" class="form-control address-field" id="fullName" placeholder="Ex: Nandalal" required oninput="validateFullName()" />
              <div class="error-message" id="fullNameError"></div>
            </div>

            <div class="form-group">
              <label for="address">Address</label>
              <textarea class="form-control address-field" id="address" placeholder="Ex: 3H,Harinandanam,Ettukandamnilam,Cottonmill-Road,Thiruvannur,Calicut,Kerala,India" rows="3" required oninput="validateAddress()"></textarea>
              <div class="error-message" id="addressError"></div>
            </div>

            <div class="form-group">
              <label for="pincode">Pincode</label>
              <input type="text" class="form-control address-field" id="pincode" placeholder="Ex: 673029" required oninput="validatePincode()" />
              <div class="error-message" id="pincodeError"></div>
            </div>

            <div class="form-group">
              <label for="phoneNo">Phone No</label>
              <input type="text" class="form-control address-field" id="phoneNo" placeholder="Ex: 9207402085" required oninput="validatePhone()" />
              <div class="error-message" id="phoneError"></div>
            </div>
          </form>
        </div>

        <div class="col-md-6">
          <h5>Cart Summary</h5>
          <div class="summary-card">
            <% let subtotal = 0 %> <% let hasUnlistedProduct = false %> <% let
              hasOutOfStockProduct = false %> <% if(cart) { %>
            <div id="cartData" data-cart="<%= JSON.stringify(cart) %>"></div>
            <% cart.products.forEach(cartItem => { %> 
            <% if (cartItem.productId.isListed && cartItem.productId.stock > 0) { %>
            <% const originalPrice = cartItem.productId.price %> 
            <% subtotal += originalPrice * cartItem.quantity %>
            <div class="product-summary">
              <img src="<%= cartItem.productId.images[0] %>" alt="product img" width="50" />
              <div class="product-details">
                <strong><%= cartItem.productId.name %></strong><br />
                <% if (cartItem.productId.bestOffer) { %>
                  <span class="text-muted" style="text-decoration: line-through; font-size: 0.85rem;">₹ <%= Math.floor(cartItem.productId.price) %></span>
                  <span class="font-weight-bold ml-1" style="color: #008000;">₹ <%= Math.floor(cartItem.productId.bestOffer.discountedPrice) %></span>
                <% } else { %>
                  <span class="font-weight-bold">₹ <%= Math.floor(cartItem.productId.price) %></span>
                <% } %>
              </div>
              <div class="quantity-details">
                <span>x <%= cartItem.quantity %></span>
              </div>
              <div class="product-price">
                <span>₹ <%= Math.floor(originalPrice * cartItem.quantity) %></span>
              </div>
            </div>
            <% } else if (!cartItem.productId.isListed) { %> 
            <% hasUnlistedProduct = true %>
            <div class="product-summary product-unavailable">
              <img src="<%= cartItem.productId.images[0] %>" alt="product img" width="50" />
              <div class="product-details">
                <strong><%= cartItem.productId.name %></strong><br />
                <span>Product no longer available</span>
              </div>
            </div>
            <% } else if (cartItem.productId.stock < 1) { %> 
            <% hasOutOfStockProduct = true %>
            <div class="product-summary product-unavailable">
              <img src="<%= cartItem.productId.images[0] %>" alt="product img" width="50" />
              <div class="product-details">
                <strong><%= cartItem.productId.name %></strong><br />
                <span>Product out of stock</span>
              </div>
            </div>
            <% } %> <% }); %> <% } %>

            <div class="pricing-summary">
              <ul class="list-group">
                <li class="list-group-item d-flex justify-content-between">
                  <span>Subtotal:</span>
                  <span id="subtotal">₹ <%= Math.floor(subtotal) %></span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                  <span>Offer Discount:</span>
                  <span id="offerDiscountDisplay" class="text-success">
                    <%= Math.floor(offerDiscount) > 0 ? `- ₹ ${Math.floor(offerDiscount)}` : '0' %>
                  </span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                  <span>Coupon Discount:</span>
                  <span id="couponDiscountDisplay" class="text-success">
                    <%= Math.floor(couponDiscount || 0) > 0 ? `- ₹ ${Math.floor(couponDiscount)}` : '0' %>
                  </span>
                </li>
                <li class="list-group-item d-flex flex-column">
                  <div class="d-flex justify-content-between align-items-center">
                    <span>Delivery Fee:</span>
                    <span id="deliveryChargeDisplayWrapper">
                      <% if (deliveryCharge === 0) { %>
                        <span class="text-muted" style="text-decoration: line-through;">₹ 80</span>
                        <span class="text-success font-weight-bold ml-1">Free</span>
                      <% } else { %>
                        ₹ <span id="deliveryChargeDisplay"><%= Math.floor(deliveryCharge) %></span>
                      <% } %>
                    </span>
                  </div>
                  <small id="deliveryChargeMessage" class="<%= deliveryCharge === 0 ? 'text-success' : 'text-muted' %> mt-1" style="font-size: 0.75rem;">
                    <%= deliveryCharge === 0 ? "Congrats! You've unlocked FREE delivery" : "Free delivery on orders above ₹600" %>
                  </small>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                  <strong>Total:</strong>
                  <strong id="totalAmount">₹ <%= Math.floor(totalAmount) %></strong>
                </li>
              </ul>

              <div class="coupon-container mt-2">
                <!-- Coupon Input Area -->
                <div id="couponInputContainer" class="coupon-flex">
                  <input type="text" id="couponCode" placeholder="Enter coupon code" />
                  <button id="applyCouponButton" class="apply-btn">Apply</button>
                </div>

                <!-- Applied Coupon Badge (Hidden by default) -->
                <div id="appliedCouponBadge" class="applied-coupon-badge">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="coupon-info">
                            <i class="fas fa-ticket-alt"></i>
                            <span>Applied: <span id="appliedCouponDisplay" class="text-uppercase font-weight-bold"></span></span>
                        </div>
                        <span id="removeCouponButton" class="remove-coupon-link">
                            <i class="fas fa-times-circle mr-1"></i>Remove
                        </span>
                    </div>
                </div>

                <div id="couponMessage" class="mt-1" style="font-size: 0.85rem;"></div>
              </div>

              <div class="mt-3">
                <h5 class="mt-3">Payment Method</h5>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="cod" value="CashOnDelivery" checked />
                  <label class="form-check-label" for="cod">
                    Cash on Delivery
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="razorpay" value="Razorpay" />
                  <label class="form-check-label" for="razorpay">
                    Pay with Razorpay
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="paymentMethod" id="wallet" value="Wallet" />
                  <label class="form-check-label" for="wallet">
                    Pay with Wallet
                  </label>
                </div>
              </div>
              <div class="text-left mt-3">
                <% if (hasUnlistedProduct || hasOutOfStockProduct) { %>
                <div class="alert alert-danger" role="alert">
                  Some of the products are no longer available or out of
                  stock. Please remove them from your cart before placing the
                  order.
                </div>
                <button id="placeOrderButton" class="btn btn-success" disabled>
                  Place Order <i class="fas fa-arrow-right"></i>
                </button>
                <% } else { %>
                <button id="placeOrderButton" class="btn btn-success" disabled>
                  Place Order <i class="fas fa-arrow-right"></i>
                </button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/User/footer') %>

  <!-- Bootstrap JS and dependencies -->
  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <!-- SwalCustom utility is already included via navBar.ejs -->
  <script>
    const placeOrderButton = document.getElementById("placeOrderButton");
    const delayedFetch = (url, options, loaderOptions) =>
      SwalCustom.withDelayedProcessing(() => authAwareFetch(url, options), loaderOptions);

    function checkFormValidity() {
      const fullName = document.getElementById("fullName").value;
      const address = document.getElementById("address").value;
      const pincode = document.getElementById("pincode").value;
      const phoneNo = document.getElementById("phoneNo").value;
      const paymentMethod = document.querySelector(
        'input[name="paymentMethod"]:checked'
      );

      const isFullNameValid = /^[A-Za-z]{3,}$/.test(fullName);
      const isAddressValid = /^[A-Za-z0-9,]{10,}$/.test(address);
      const isPincodeValid = /^\d{6}$/.test(pincode);
      const isPhoneValid = /^\d{10}$/.test(phoneNo);
      const isPaymentMethodSelected = paymentMethod !== null;

      placeOrderButton.disabled = !(
        isFullNameValid &&
        isAddressValid &&
        isPincodeValid &&
        isPhoneValid &&
        isPaymentMethodSelected
      );
    }

    function validateFullName() {
      const input = document.getElementById('fullName');
      const errorElement = document.getElementById('fullNameError');
      const regex = /^[A-Za-z]{3,}$/;
      
      if (input.value.trim() === '') {
        input.classList.remove('is-valid', 'is-invalid');
        errorElement.textContent = '';
      } else if (!regex.test(input.value)) {
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        errorElement.textContent = 'Username must contain only letters and be at least 3 characters long';
      } else {
        input.classList.add('is-valid');
        input.classList.remove('is-invalid');
        errorElement.textContent = '';
      }
      checkFormValidity();
    }

    function validateAddress() {
      const input = document.getElementById('address');
      const errorElement = document.getElementById('addressError');
      const regex = /^[A-Za-z0-9,]{10,}$/;
      
      if (input.value.trim() === '') {
        input.classList.remove('is-valid', 'is-invalid');
        errorElement.textContent = '';
      } else if (!regex.test(input.value)) {
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        errorElement.textContent = 'Address must be at least 10 characters long, contain only letters, numbers, and commas (no spaces allowed)';
      } else {
        input.classList.add('is-valid');
        input.classList.remove('is-invalid');
        errorElement.textContent = '';
      }
      checkFormValidity();
    }

    function validatePincode() {
      const input = document.getElementById('pincode');
      const errorElement = document.getElementById('pincodeError');
      const regex = /^\d{6}$/;
      
      if (input.value.trim() === '') {
        input.classList.remove('is-valid', 'is-invalid');
        errorElement.textContent = '';
      } else if (!regex.test(input.value)) {
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        errorElement.textContent = 'Pincode must be exactly 6 digits';
      } else {
        input.classList.add('is-valid');
        input.classList.remove('is-invalid');
        errorElement.textContent = '';
      }
      checkFormValidity();
    }

    function validatePhone() {
      const input = document.getElementById('phoneNo');
      const errorElement = document.getElementById('phoneError');
      const regex = /^\d{10}$/;
      
      if (input.value.trim() === '') {
        input.classList.remove('is-valid', 'is-invalid');
        errorElement.textContent = '';
      } else if (!regex.test(input.value)) {
        input.classList.add('is-invalid');
        input.classList.remove('is-valid');
        errorElement.textContent = 'Phone number must be exactly 10 digits';
      } else {
        input.classList.add('is-valid');
        input.classList.remove('is-invalid');
        errorElement.textContent = '';
      }
      checkFormValidity();
    }

    function populateAddress() {
      const addressSelect = document.getElementById("addressSelect");
      const fullnameInput = document.getElementById("fullName");
      const addressInput = document.getElementById("address");
      const pincodeInput = document.getElementById("pincode");
      const phoneInput = document.getElementById("phoneNo");

      const selectedOption =
        addressSelect.options[addressSelect.selectedIndex];

      if (selectedOption.value) {
        fullnameInput.value = selectedOption.value;
        addressInput.value = selectedOption.getAttribute("data-address");
        pincodeInput.value = selectedOption.getAttribute("data-pincode");
        phoneInput.value = selectedOption.getAttribute("data-phone");

        validateFullName();
        validateAddress();
        validatePincode();
        validatePhone();
      } else {
        fullnameInput.value = "";
        addressInput.value = "";
        pincodeInput.value = "";
        phoneInput.value = "";

        [fullnameInput, addressInput, pincodeInput, phoneInput].forEach(
          (input) => {
            input.classList.remove("is-valid", "is-invalid");
          }
        );
        document
          .querySelectorAll(".error-message")
          .forEach((el) => (el.textContent = ""));
      }

      checkFormValidity();
    }

    document.addEventListener("DOMContentLoaded", () => {
      let discount = 0;
      let appliedCouponCode = ""; // Ensure this is defined and used correctly

      const couponCodeInput = document.getElementById("couponCode");
      const applyCouponButton = document.getElementById("applyCouponButton");
      const discountAmountDisplay = document.getElementById("discountAmount");
      const couponMessage = document.getElementById("couponMessage");
      const subtotalElement = document.getElementById("subtotal");
      const removeCouponButton = document.getElementById("removeCouponButton");

      if (!subtotalElement) {
        console.error("Subtotal element not found!");
        return;
      }

      applyCouponButton.addEventListener("click", async () => {
        const couponCode = couponCodeInput.value.trim();
        if (!couponCode) return;

        try {
          const response = await authAwareFetch("/orders/checkout/apply-coupon", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ couponCode }),
          });
          if (!response) return;

          const data = await response.json();

          if (!response) return;
          if (response.ok && data.success) {
            appliedCouponCode = couponCode;
            
            // Update UI with truncated values
            document.getElementById('subtotal').innerText = `₹ ${Math.floor(data.subtotal)}`;
            document.getElementById('offerDiscountDisplay').innerText = data.offerDiscount > 0 ? `- ₹ ${Math.floor(data.offerDiscount)}` : '0';
            document.getElementById('couponDiscountDisplay').innerText = data.couponDiscount > 0 ? `- ₹ ${Math.floor(data.couponDiscount)}` : '0';
            
            // Update Delivery Charge UI
            const wrapper = document.getElementById('deliveryChargeDisplayWrapper');
            const message = document.getElementById('deliveryChargeMessage');
            if (data.deliveryCharge === 0) {
              wrapper.innerHTML = `<span class="text-muted" style="text-decoration: line-through;">₹ 80</span> <span class="text-success font-weight-bold ml-1">Free</span>`;
              message.innerText = "Congrats! You've unlocked FREE delivery";
              message.className = "text-success mt-1";
            } else {
              wrapper.innerHTML = `₹ <span id="deliveryChargeDisplay">${Math.floor(data.deliveryCharge)}</span>`;
              message.innerText = "Free delivery on orders above ₹600";
              message.className = "text-muted mt-1";
            }

            document.getElementById("totalAmount").innerText = `₹ ${Math.floor(data.totalAmount)}`;
            
            couponMessage.textContent = "Coupon applied successfully!";
            couponMessage.style.color = "green";
            
            // Hide Input area, show Badge
            document.getElementById('couponInputContainer').style.display = 'none';
            document.getElementById('appliedCouponDisplay').textContent = couponCode;
            document.getElementById('appliedCouponBadge').style.display = 'block';
          } else {
            couponMessage.textContent = data.message;
            couponMessage.style.color = "red";
          }
        } catch (error) {
          couponMessage.textContent = "Error applying coupon. Please try again.";
          couponMessage.style.color = "red";
        }
      });

      removeCouponButton.addEventListener("click", () => {
        appliedCouponCode = "";
        
        // Reset Coupon Discount in UI
        document.getElementById('couponDiscountDisplay').innerText = `0`;
        
        // Recalculate based on current subtotal and delivery
        const subtotalText = document.getElementById('subtotal').innerText.replace("₹ ", "").trim();
        const offerDiscountText = document.getElementById('offerDiscountDisplay').innerText.replace("- ₹ ", "").trim();
        
        const subtotal = Math.floor(parseFloat(subtotalText));
        const offerDiscount = offerDiscountText === '0' ? 0 : Math.floor(parseFloat(offerDiscountText));
        
        // Handle potentially non-numeric text like "Free" in delivery
        const deliveryChargeDisplay = document.getElementById('deliveryChargeDisplay');
        const delivery = deliveryChargeDisplay ? Math.floor(parseFloat(deliveryChargeDisplay.innerText)) : 0;
        
        const originalTotal = subtotal - offerDiscount + delivery;
        document.getElementById("totalAmount").innerText = `₹ ${Math.floor(originalTotal)}`;

        // Show Input area, hide Badge
        document.getElementById('couponInputContainer').style.display = 'flex';
        document.getElementById('appliedCouponBadge').style.display = 'none';
        couponCodeInput.value = "";
        couponMessage.textContent = "Coupon removed.";
        couponMessage.style.color = "blue";
      });

      async function placeOrder() {
        const fullName = document.getElementById("fullName").value;
        const address = document.getElementById("address").value;
        const pincode = document.getElementById("pincode").value;
        const phoneNumber = document.getElementById("phoneNo").value;
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked');

        if (!paymentMethod) {
          SwalCustom.error("Oops...", "Please select a payment method.");
          placeOrderButton.disabled = false;
          return;
        }

        const cartElement = document.getElementById("cartData");
        const cart = JSON.parse(cartElement.getAttribute("data-cart"));

        const items = cart.products.map((item) => ({
          productId: item.productId._id,
          quantity: item.quantity,
          price: item.discountedPrice || item.productId.price,
        }));

        const subtotal = cart.products.reduce(
          (acc, item) => acc + (item.discountedPrice || item.productId.price) * item.quantity,
          0
        );
        const deliveryChargeElement = document.getElementById('deliveryChargeDisplay');
        const deliveryCharge = deliveryChargeElement ? parseFloat(deliveryChargeElement.innerText) : 0;

        const shippingAddress = {
          fullname: fullName,
          address,
          pincode,
          phone: phoneNumber,
        };

        const totalAmountText = document.getElementById("totalAmount").innerText.replace("₹ ", "").trim();
        const totalAmountAfterDiscount = Math.floor(parseFloat(totalAmountText));

        const orderData = {
          items,
          totalAmount: totalAmountAfterDiscount,
          shippingAddress,
          paymentMethod: paymentMethod.value,
          couponCode: appliedCouponCode,
        };

        try {
          const orderResponse = await delayedFetch(
            "/orders/checkout/confirm",
            {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(orderData),
            },
            {
              title: "Placing order...",
              text: "Please wait while we confirm your order."
            }
          );

          if (!orderResponse) return;
          if (orderResponse.ok) {
            const order = await orderResponse.json();
            const orderId = order.orderId;

            if (paymentMethod.value === 'Wallet') {
              SwalCustom.success(
                "Success!",
                "Your order has been placed successfully using your wallet balance."
              ).then(() => {
                window.location.href = `/orders/success?orderId=${orderId}`;
              });
            } else if (paymentMethod.value === 'Razorpay') {
              const razorpayResponse = await delayedFetch(
                "/orders/razorpay/create",
                {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                  },
                  body: JSON.stringify({
                    orderId
                  }),
                },
                {
                  title: "Preparing payment...",
                  text: "Please wait while we connect to Razorpay."
                }
              );

              if (!razorpayResponse) return;
              if (razorpayResponse.ok) {
                const razorpayData = await razorpayResponse.json();
                const options = {
                  key: "rzp_test_KZK1gW6B1A7B5s",
                  amount: razorpayData.amount,
                  currency: "INR",
                  name: "Subtlety",
                  description: "Order Payment",
                  order_id: razorpayData.id,
                  handler: async function(response) {
                    try {
                      const paymentConfirmationResponse = await delayedFetch(
                        "/orders/razorpay/confirm",
                        {
                          method: "POST",
                          headers: {
                            "Content-Type": "application/json",
                          },
                          body: JSON.stringify({
                            orderId,
                            paymentResponse: response,
                          }),
                        },
                        {
                          title: "Confirming payment...",
                          text: "Please wait while we verify your Razorpay payment."
                        }
                      );

                        if (!paymentConfirmationResponse) return;
                        if (paymentConfirmationResponse.ok) {
                        const data = await paymentConfirmationResponse.json();
                        SwalCustom.success("Success!", data.message).then(() => {
                          window.location.href = `/orders/success?orderId=${orderId}`;
                        });
                      } else {
                        const errorData = await paymentConfirmationResponse.json();
                        SwalCustom.error("Oops...", `Error confirming payment: ${errorData.message}`);
                      }
                    } catch (error) {
                      SwalCustom.error(
                        "Oops...",
                        "An unexpected error occurred while confirming the payment."
                      );
                    }
                  },
                  modal: {
                    ondismiss: function() {
                      const redirectDelay = 1000;
                      setTimeout(() => {
                        SwalCustom.processing(
                          'Processing...',
                          'Redirecting to your order details.'
                        );
                      }, 250);
                      setTimeout(() => {
                        window.location.href = `/orders/${orderId}`;
                      }, redirectDelay);
                    }
                  }
                };

                const razorpay = new Razorpay(options);
                razorpay.on("payment.failed", async (res) => {
                  SwalCustom.error(
                    "Payment Failed",
                    "The payment failed or was declined. Redirecting to order details for retry."
                  ).then(() => {
                    window.location.href = `/orders/${orderId}`;
                  });
                });
                razorpay.open();
              } else {
                const errorData = await razorpayResponse.json();
                SwalCustom.error("Razorpay Error", errorData.message || "Failed to initiate payment.");
                placeOrderButton.disabled = false;
              }
            } else {
              // Cash on Delivery
              SwalCustom.success("Success!", "Your order has been placed successfully!").then(() => {
                window.location.href = `/orders/success?orderId=${orderId}`;
              });
            }
          } else {
            const errorData = await orderResponse.json();
            SwalCustom.error("Order Failed", errorData.message || "Error creating order.");
            placeOrderButton.disabled = false;
          }
        } catch (error) {
          console.error("Order process error:", error);
          SwalCustom.error("Error", "Something went wrong. Please try again later.");
          placeOrderButton.disabled = false;
        }
      }

      // Add event listener for placing the order
      placeOrderButton.addEventListener("click", function(e) {
        e.preventDefault();
        placeOrderButton.disabled = true; // Disable to prevent double-click
        placeOrder();
      });

      // Add event listeners for payment method changes
      document
        .querySelectorAll('input[name="paymentMethod"]')
        .forEach((radio) => {
          radio.addEventListener("change", checkFormValidity);
        });
    });
  </script>
</body>

</html>
