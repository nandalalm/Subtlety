<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="user-id" content="<%= user ? user._id : '' %>">
  <title>Home - SUBTLETY</title>

  <!-- Bootstrap CSS -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Fonts: Poppins -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <!-- Toastify CSS -->
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

  <link rel="stylesheet" href="/styles/user/home.css">
  <style>
    .out-of-stock {
      opacity: 0.5;
      filter: grayscale(50%);
    }

    .out-of-stock-label {
      position: absolute;
      top: 10px;
      right: 10px;
      background-color: rgba(255, 0, 0, 0.7);
      color: white;
      padding: 5px 10px;
      border-radius: 5px;
      font-size: 12px;
      font-weight: bold;
    }

    .view-more-btn:hover {
      background-color: #7b2cc8;
      border-color: #7b2cc8;
    }

    /* Return Policy Section Styles */
    .return-policy {
      padding: 60px 0;
      background-color: #f9f9f9;
    }

    .policy-card {
      background: white;
      padding: 30px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      transition: transform 0.3s ease;
      height: 100%;
      border: 1px solid #eee;
    }

    .policy-card:hover {
      transform: translateY(-10px);
    }

    .policy-icon {
      font-size: 3rem;
      color: #9135ED;
      margin-bottom: 20px;
    }

    .policy-title {
      font-weight: 600;
      margin-bottom: 15px;
      color: #333;
    }

    .policy-text {
      color: #666;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .policy-highlight {
      color: #9135ED;
      font-weight: 600;
    }
  </style>
</head>

<body>
  <%- include('../partials/User/navBar') %>

  <!-- Hero Section -->
  <section class="hero-section text-center py-0" style="background-color: black;">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-12 text-center pt-5">
          <h1>Experience the magic of anime with Subtlety</h1>
          <h4>—Where every piece tells a story.</h4>
          <form action="/user/shop" method="GET" class="search-bar mt-4" onsubmit="if(!this.search.value.trim()) return false;">
            <input type="text" name="search" placeholder="Search for Merch.." />
            <button type="submit">Search</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES Section -->
  <section id="category" class="categories">
    <% if (categories && categories.length > 0) { %>
    <div class="container category-container">
      <div class="this-month">
        <div class="this-month-box">
          <div class="this-month-square"></div>
          <span style="color: #9135ED;">Categories</span>
        </div>
        <div class="mt-3">
          <h2 class="text-left mb-0">SHOP BY CATEGORIES</h2>
        </div>
      </div>
      <div class="category-scroll-shell mt-4" id="category-scroll-shell">
        <button
          type="button"
          class="category-scroll-btn category-scroll-btn-prev"
          id="category-scroll-prev"
          aria-label="Scroll categories left">
          <i class="fas fa-chevron-left"></i>
        </button>
        <div id="category-scroll-container" class="category-scroll-container">
          <% categories.forEach(category => { %>
          <% if(category.isListed){%>
          <div class="category-item">
            <a class="card-links" href="/user/shop?category=<%= category._id %>">
              <div class="category-card vertical">
                <img src="<%= category.image %>" class="category-img" alt="Category Image">
                <h5 class="category-title"><%= category.name %></h5>
              </div>
            </a>
          </div>
          <% } %>
          <% }) %>
        </div>
        <button
          type="button"
          class="category-scroll-btn category-scroll-btn-next"
          id="category-scroll-next"
          aria-label="Scroll categories right">
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
    </div>
    <% } else { %>
    <p class="text-center">No categories available.</p>
    <% } %>
  </section>
  
<!-- NEW-ARRIVALS Section -->
<section id="new-arrivals"  class="new-arrivals">
  <div class="container new-arrival-container">
    <div class="this-month">
      <div class="this-month-box">
        <div class="this-month-square"></div>
        <span style="color: #9135ED;">Latest Arrivals</span>
      </div>
      <h2 class="text-left mt-3">SHOP BY LATEST ARRIVALS</h2>
    </div>
    <div class="row g-5" id="latest-products-grid">
      <% if (latestProducts && latestProducts.length > 0) { %>
      <% latestProducts.forEach(({ product, bestOffer, averageRating }) => { %>
      <% if (product && product.isListed) { %>
            <%- include('../partials/User/productCard', { product: product, bestOffer: bestOffer, cartItemMap: cartItemMap, averageRating: averageRating }) %>
      <% } %>
      <% }) %>
      <% } else { %>
      <p class="ml-3">No new arrivals available.</p>
      <% } %>
    </div>
    <div class="text-center my-4 mt-5 pt-3">
      <a href="/user/shop" class="btn btn-secondary view-more-btn">Go to shop  <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- TOP SELLING Section -->
<section id="top-selling" class="top-selling">
  <div class="container top-selling-container">
    <div class="this-month">
      <div class="this-month-box">
        <div class="this-month-square"></div>
        <span style="color: #9135ED;">Best Selling</span>
      </div>
      <h2 class="text-left mt-3">SHOP BY BEST SELLING PRODUCTS</h2>
    </div>
    
    <!-- Render Best Selling Products if Available -->
    <div style="color: #3097ff #4d64f9;" class="row g-5" id="best-selling-grid">
      <% if (bestSellingProducts && bestSellingProducts.length) { %>
        <% bestSellingProducts.forEach(({ product, bestOffer, count, averageRating }) => { %>
          <% if (product && product.isListed) { %>
                  <%- include('../partials/User/productCard', { product: product, bestOffer: bestOffer, cartItemMap: cartItemMap, averageRating: averageRating }) %>
          <% } %>
        <% }) %>
      <% } else { %>
        <% fallbackProducts.forEach(({ product, bestOffer, averageRating }) => { %>
          <% if (product && product.isListed) { %>
            <%- include('../partials/User/productCard', { product: product, bestOffer: bestOffer, cartItemMap: cartItemMap, averageRating: averageRating }) %>
          <% } %>
        <% }) %>
      <% } %>
    </div>

    <div class="text-center my-4 mt-5 pt-3">
      <a href="/user/shop" class="btn btn-secondary view-more-btn">Go to shop  <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- RETURN POLICY Section -->
<section id="return-policy" class="return-policy">
  <div class="container">
    <div class="this-month mb-5">
      <div class="this-month-box">
        <div class="this-month-square"></div>
        <span style="color: #9135ED;">Customer Protection</span>
      </div>
      <h2 class="text-left mt-3">OUR RETURN POLICY</h2>
    </div>

    <div class="row text-center g-4">
      <div class="col-12 col-md-6 col-lg-3">
        <div class="policy-card">
          <div class="policy-icon">
            <i class="fas fa-calendar-check"></i>
          </div>
          <h4 class="policy-title">7-Day Window</h4>
          <p class="policy-text">
            Changed your mind? No worries! We offer a <span class="policy-highlight">7-day return window</span> from the date of delivery for all eligible items.
          </p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="policy-card">
          <div class="policy-icon">
            <i class="fas fa-ticket-alt"></i>
          </div>
          <h4 class="policy-title">Coupon Restriction</h4>
          <p class="policy-text">
            To maintain our best prices, returns are <span class="policy-highlight">not available</span> for orders where a coupon was applied.
          </p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="policy-card">
          <div class="policy-icon">
            <i class="fas fa-box-open"></i>
          </div>
          <h4 class="policy-title">Easy Process</h4>
          <p class="policy-text">
            Simply head to your <span class="policy-highlight">Order Details</span> page and click the Return button. Our team will review your request promptly.
          </p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="policy-card">
          <div class="policy-icon">
            <i class="fas fa-wallet"></i>
          </div>
          <h4 class="policy-title">Quick Refunds</h4>
          <p class="policy-text">
            Once approved, your refund will be credited back to your <span class="policy-highlight">Wallet</span> instantly, ready for your next anime merch haul!
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

  <%- include('../partials/User/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://code.jquery.com/jquery-3.5.2.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Toastify JS -->
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="/js/cartControls.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const scrollShell = document.getElementById('category-scroll-shell');
      const scrollContainer = document.getElementById('category-scroll-container');
      const prevButton = document.getElementById('category-scroll-prev');
      const nextButton = document.getElementById('category-scroll-next');

      if (!scrollShell || !scrollContainer || !prevButton || !nextButton) return;

      const getScrollStep = () => {
        const firstItem = scrollContainer.querySelector('.category-item');
        if (!firstItem) return Math.max(scrollContainer.clientWidth * 0.75, 220);
        const itemWidth = firstItem.getBoundingClientRect().width;
        const gap = parseFloat(window.getComputedStyle(scrollContainer).columnGap || window.getComputedStyle(scrollContainer).gap || 0);
        return Math.max(itemWidth + gap, 220);
      };

      const syncScrollControls = () => {
        const maxScrollLeft = scrollContainer.scrollWidth - scrollContainer.clientWidth;
        const isScrollable = maxScrollLeft > 8;

        scrollShell.classList.toggle('is-scrollable', isScrollable);
        prevButton.disabled = !isScrollable || scrollContainer.scrollLeft <= 8;
        nextButton.disabled = !isScrollable || scrollContainer.scrollLeft >= maxScrollLeft - 8;
      };

      prevButton.addEventListener('click', function() {
        scrollContainer.scrollBy({ left: -getScrollStep(), behavior: 'smooth' });
      });

      nextButton.addEventListener('click', function() {
        scrollContainer.scrollBy({ left: getScrollStep(), behavior: 'smooth' });
      });

      scrollContainer.addEventListener('scroll', syncScrollControls, { passive: true });
      window.addEventListener('resize', syncScrollControls);

      syncScrollControls();
      setTimeout(syncScrollControls, 250);
    });
  </script>

</body>

</html>
