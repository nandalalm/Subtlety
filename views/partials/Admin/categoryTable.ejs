<% 
    const categoryList = typeof categories !== 'undefined' ? categories : [];
    const currPg = typeof currentPage !== 'undefined' ? parseInt(currentPage) : 1;
    const pgLimit = typeof limit !== 'undefined' ? parseInt(limit) : 10;
%>

<div class="table-container-shared card border-0 shadow-sm">
    <% if (categoryList.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <p class="text-muted">No results found for the given criteria.</p>
        </div>
    <% } else { %>
        <!-- Desktop Table -->
        <table class="table table-hover shared-table-desktop mb-0">
            <thead class="thead-light">
                <tr>
                    <th style="width: 10%;">S.No</th>
                    <th style="width: 40%;">Name</th>
                    <th style="width: 30%;">Image</th>
                    <th style="width: 20%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% categoryList.forEach((category, index) => { %>
                <tr data-row-id="<%= category._id %>">
                    <td><%= (currPg - 1) * pgLimit + (index + 1) %></td>
                    <td><span class="font-weight-bold text-dark"><%= category.name %></span></td>
                    <td>
                        <div class="d-flex align-items-center">
                            <% if (category.image) { %>
                                <img src="<%= category.image %>" alt="<%= category.name %>" class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover; border: 1px solid #eee;">
                            <% } else { %>
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; border: 1px solid #eee;">
                                    <i class="fas fa-image text-muted small"></i>
                                </div>
                            <% } %>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <button class="btn btn-outline-warning btn-sm rounded-pill px-3 mr-2" 
                                    data-toggle="modal" data-target="#editCategoryModal<%= category._id %>">
                                <i class="fas fa-edit mr-1"></i>Edit
                            </button>
                            <button class="btn btn-sm rounded-pill px-3 toggle-status-btn <%= category.isListed ? 'btn-outline-secondary' : 'btn-outline-primary' %>" 
                                    data-id="<%= category._id %>"
                                    data-status="<%= category.isListed %>"
                                    onclick="toggleCategoryStatus(this)">
                                <%= category.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Mobile Cards -->
        <div class="shared-cards-mobile p-3">
            <% categoryList.forEach((category, index) => { %>
            <div class="shared-item-card" data-card-id="<%= category._id %>">
                <div class="card-header-flex">
                    <span class="font-weight-bold">#<%= (currPg - 1) * pgLimit + (index + 1) %></span>
                    <span class="status-box status-<%= category.isListed ? 'successful' : 'failed' %>">
                        <%= category.isListed ? 'Listed' : 'Unlisted' %>
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="d-flex align-items-center mb-3">
                        <% if (category.image) { %>
                            <img src="<%= category.image %>" class="rounded mr-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover;">
                        <% } else { %>
                            <div class="bg-light rounded d-flex align-items-center justify-content-center mr-3" style="width: 60px; height: 60px;">
                                <i class="fas fa-image text-muted"></i>
                            </div>
                        <% } %>
                        <h6 class="font-weight-bold mb-0 text-dark"><%= category.name %></h6>
                    </div>
                    
                    <div class="mt-4 row">
                        <div class="col">
                            <button class="btn btn-outline-warning btn-block btn-sm rounded-pill" 
                                    data-toggle="modal" data-target="#editCategoryModal<%= category._id %>">
                                Edit
                            </button>
                        </div>
                        <div class="col">
                            <button class="btn btn-block btn-sm rounded-pill toggle-status-btn <%= category.isListed ? 'btn-outline-secondary' : 'btn-outline-primary' %>" 
                                    data-id="<%= category._id %>"
                                    data-status="<%= category.isListed %>"
                                    onclick="toggleCategoryStatus(this)">
                                <%= category.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Edit Category Modals (Hidden) -->
        <% categoryList.forEach((category) => { %>
            <div class="modal fade" id="editCategoryModal<%= category._id %>" tabindex="-1" role="dialog" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-md" role="document">
                    <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                        <div class="modal-header bg-light">
                            <h5 class="modal-title font-weight-bold">Edit Category</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <form action="/admin/categories/edit/<%= category._id %>" method="POST" enctype="multipart/form-data" class="editCategoryForm" onsubmit="return validateCategoryForm(this)">
                            <div class="modal-body p-4">
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold">Category Name</label>
                                    <input type="text" name="name" class="form-control" value="<%= category.name %>" required pattern="^[a-zA-Z]{4,}$">
                                    <div class="valid-feedback">Looks good!</div>
                                    <div class="invalid-feedback">Category name must be at least 4 characters long and contain only letters.</div>
                                </div>
                                
                                <div class="form-group mb-3">
                                    <label class="font-weight-bold">Category Image</label>
                                    <div class="custom-file mb-2">
                                        <input type="file" id="imageEdit<%= category._id %>" name="image" class="custom-file-input" accept="image/*">
                                        <label class="custom-file-label" for="imageEdit<%= category._id %>">Choose new image...</label>
                                    </div>
                                    
                                    <div id="imagePreviewEdit<%= category._id %>" class="mt-3 text-center" style="display:none;">
                                        <img id="cropImageEdit<%= category._id %>" class="img-fluid rounded shadow-sm" style="max-height: 250px;">
                                        <div class="mt-2">
                                            <button type="button" class="btn btn-sm btn-info rounded-pill px-3" onclick="startCroppingEdit('<%= category._id %>')">Crop</button>
                                        </div>
                                    </div>
                                    
                                    <div id="error-message-edit<%= category._id %>" class="text-danger mt-2 small" style="display: none;"></div>
                                </div>

                                <% if (category.image) { %>
                                    <div class="text-center mt-3 bg-light p-3 rounded">
                                        <p class="small text-muted mb-2">Current Category Image</p>
                                        <img src="<%= category.image %>" class="img-thumbnail" style="max-height: 80px;">
                                    </div>
                                <% } %>
                                
                                <input type="hidden" name="isListed" value="<%= category.isListed %>">
                            </div>
                            <div class="modal-footer bg-light border-0">
                                <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary rounded-pill px-4" style="background-color: #9135ED; border-color: #9135ED;">Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
    
        <!-- Pagination -->
        <% if (categoryList.length > 0 && typeof totalPages !== 'undefined') { %>
        <div class="px-3 pb-3">
            <%- include('../Common/pagination') %>
        </div>
        <% } %>
</div>
