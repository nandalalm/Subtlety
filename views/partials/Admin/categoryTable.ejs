<% 
    const categoryList = typeof categories !== 'undefined' ? categories : [];
    const currPg = typeof currentPage !== 'undefined' ? parseInt(currentPage) : 1;
    const pgLimit = typeof limit !== 'undefined' ? parseInt(limit) : 10;
%>

<div class="table-container-shared card border-0 shadow-sm">
    <% if (categoryList.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <p class="text-muted">No results found for the given criteria.</p>
        </div>
    <% } else { %>
        <!-- Desktop Table -->
        <table class="table table-hover shared-table-desktop mb-0">
            <thead class="thead-light">
                <tr>
                    <th style="width: 10%;">S.No</th>
                    <th style="width: 32%;">Name</th>
                    <th style="width: 24%;">Image</th>
                    <th style="width: 14%;">Status</th>
                    <th style="width: 20%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% categoryList.forEach((category, index) => { %>
                <tr data-row-id="<%= category._id %>">
                    <td><%= (currPg - 1) * pgLimit + (index + 1) %></td>
                    <td><span class="font-weight-bold text-dark"><%= category.name %></span></td>
                    <td>
                        <div class="d-flex align-items-center">
                            <% if (category.image) { %>
                                <div class="category-image-trigger rounded shadow-sm" onclick="openCategoryImagePreview('<%= category.image %>', '<%= category.name.replace(/'/g, '&#39;') %>')" title="View image">
                                    <img src="<%= category.image %>" alt="<%= category.name %>" class="rounded shadow-sm" style="width: 45px; height: 45px; object-fit: cover; border: 1px solid #eee;">
                                </div>
                            <% } else { %>
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; border: 1px solid #eee;">
                                    <i class="fas fa-image text-muted small"></i>
                                </div>
                            <% } %>
                        </div>
                    </td>
                    <td>
                        <span class="status-box status-<%= category.isListed ? 'successful' : 'failed' %>">
                            <%= category.isListed ? 'Listed' : 'Unlisted' %>
                        </span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <a class="btn btn-sm rounded-pill px-3 mr-2 table-action-btn table-btn-edit category-edit-trigger" href="/admin/categories/edit/<%= category._id %>?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>">Edit</a>
                            <button class="btn btn-sm rounded-pill px-3 toggle-status-btn table-action-btn <%= category.isListed ? 'table-btn-unlist' : 'table-btn-relist' %>" 
                                    data-id="<%= category._id %>"
                                    data-status="<%= category.isListed %>"
                                    onclick="toggleCategoryStatus(this)">
                                <%= category.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Mobile Cards -->
        <div class="shared-cards-mobile p-3">
            <% categoryList.forEach((category, index) => { %>
            <div class="shared-item-card" data-card-id="<%= category._id %>">
                <div class="card-header-flex">
                    <span class="font-weight-bold">#<%= (currPg - 1) * pgLimit + (index + 1) %></span>
                    <span class="status-box status-<%= category.isListed ? 'successful' : 'failed' %>">
                        <%= category.isListed ? 'Listed' : 'Unlisted' %>
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="d-flex align-items-center mb-3">
                        <% if (category.image) { %>
                            <div class="category-image-trigger rounded mr-3 shadow-sm" onclick="openCategoryImagePreview('<%= category.image %>', '<%= category.name.replace(/'/g, '&#39;') %>')" title="View image">
                                <img src="<%= category.image %>" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                            </div>
                        <% } else { %>
                            <div class="bg-light rounded d-flex align-items-center justify-content-center mr-3" style="width: 60px; height: 60px;">
                                <i class="fas fa-image text-muted"></i>
                            </div>
                        <% } %>
                        <h6 class="font-weight-bold mb-0 text-dark"><%= category.name %></h6>
                    </div>
                    
                    <div class="mt-4 row">
                        <div class="col">
                            <a class="btn btn-block btn-sm rounded-pill table-action-btn table-btn-edit category-edit-trigger" href="/admin/categories/edit/<%= category._id %>?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>">Edit</a>
                        </div>
                        <div class="col">
                            <button class="btn btn-block btn-sm rounded-pill toggle-status-btn table-action-btn <%= category.isListed ? 'table-btn-unlist' : 'table-btn-relist' %>" 
                                    data-id="<%= category._id %>"
                                    data-status="<%= category.isListed %>"
                                    onclick="toggleCategoryStatus(this)">
                                <%= category.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    <% } %>
    
        <!-- Pagination -->
        <% if (categoryList.length > 0 && typeof totalPages !== 'undefined') { %>
        <div class="px-3 pb-3">
            <%- include('../Common/pagination') %>
        </div>
        <% } %>
</div>

<div class="modal fade" id="categoryImagePreviewModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content border-0 shadow" style="border-radius: 16px; overflow: hidden;">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title font-weight-bold" id="categoryImagePreviewTitle">Category Image</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-3 p-md-4 text-center bg-white">
                <img id="categoryImagePreviewTarget" src="" alt="Category preview" class="img-fluid rounded shadow-sm" style="max-height: 70vh; width: auto;">
            </div>
        </div>
    </div>
</div>
