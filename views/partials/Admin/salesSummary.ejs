<!-- Summary Statistics -->
<div class="d-flex mb-4 flex-wrap">
    <div class="summary-card shadow-sm mb-lg-0 mb-3">
        <div class="summary-label">Total Sales Count</div>
        <div class="summary-value"><%= totalSalesCount %></div>
    </div>
    <div class="summary-card shadow-sm mb-lg-0 mb-3">
        <div class="summary-label">Total Order Amount</div>
        <div class="summary-value">₹<%= totalOrderAmount.toFixed(2) %></div>
    </div>
    <div class="summary-card shadow-sm">
        <div class="summary-label">Total Discounts Given</div>
        <div class="summary-value">₹<%= totalDiscount.toFixed(2) %></div>
    </div>
</div>
