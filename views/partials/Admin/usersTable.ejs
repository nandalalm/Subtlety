<% 
    const userList = typeof users !== 'undefined' ? users : [];
    const currPg = typeof currentPage !== 'undefined' ? parseInt(currentPage) : 1;
    const pgLimit = typeof limit !== 'undefined' ? parseInt(limit) : 10;
%>

<div class="table-container-shared card border-0 shadow-sm admin-cards-responsive">
    <% if (userList.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <p class="text-muted">No results found for the given criteria.</p>
        </div>
    <% } else { %>
        <!-- Desktop Table -->
        <table class="table table-hover shared-table-desktop mb-0">
            <thead class="thead-light">
                <tr>
                    <th style="width: 5%;">S.No</th>
                    <th style="width: 25%;">Name</th>
                    <th style="width: 25%;">Email</th>
                    <th style="width: 15%;">Phone Number</th>
                    <th style="width: 15%;">Status</th>
                    <th style="width: 15%;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% userList.forEach((user, index) => { %>
                <tr data-row-id="<%= user._id %>">
                    <td><%= (currPg - 1) * pgLimit + (index + 1) %></td>
                    <td><span class="font-weight-bold text-dark"><%= user.firstname %> <%= user.lastname %></span></td>
                    <td><%= user.email %></td>
                    <td><%= user.phoneNo || 'N/A' %></td>
                    <td>
                        <span class="status-box status-<%= user.isBlocked ? 'failed' : 'successful' %>" id="status-badge-<%= user._id %>">
                            <%= user.isBlocked ? 'Blocked' : 'Active' %>
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm rounded-pill px-3 table-action-btn <%= user.isBlocked ? 'table-btn-unblock' : 'table-btn-block' %>" 
                                data-user-id="<%= user._id %>" 
                                data-blocked="<%= user.isBlocked %>" 
                                onclick="toggleUserStatus(this)">
                            <%= user.isBlocked ? 'Unblock' : 'Block' %>
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Mobile Cards -->
        <div class="shared-cards-mobile p-3">
            <% userList.forEach((user, index) => { %>
            <div class="shared-item-card" data-card-id="<%= user._id %>">
                <div class="card-header-flex">
                    <span class="font-weight-bold">#<%= (currPg - 1) * pgLimit + (index + 1) %></span>
                    <span class="status-box status-<%= user.isBlocked ? 'failed' : 'successful' %>" id="status-badge-mobile-<%= user._id %>">
                        <%= user.isBlocked ? 'Blocked' : 'Active' %>
                    </span>
                </div>
                <div class="card-body p-0">
                    <p><strong>Name:</strong> <%= user.firstname %> <%= user.lastname %></p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <p><strong>Phone:</strong> <%= user.phoneNo || 'N/A' %></p>
                    
                    <div class="mt-3 text-right">
                        <button class="btn btn-sm rounded-pill px-4 table-action-btn <%= user.isBlocked ? 'table-btn-unblock' : 'table-btn-block' %>" 
                                data-user-id="<%= user._id %>" 
                                data-blocked="<%= user.isBlocked %>" 
                                onclick="toggleUserStatus(this)">
                            <%= user.isBlocked ? 'Unblock' : 'Block' %>
                        </button>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    <% } %>
    
        <!-- Pagination -->
        <% if (userList.length > 0 && typeof totalPages !== 'undefined') { %>
        <div class="px-3 pb-3">
            <%- include('../Common/pagination') %>
        </div>
        <% } %>
</div>
