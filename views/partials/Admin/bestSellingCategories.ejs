<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>#</th>
        <th>Category</th>
        <th class="text-center">Image</th>
      </tr>
    </thead>
    <tbody>
      <% bestSellingCategories.forEach((category, index) => { %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= category.name %></td>
        <td class="text-center">
          <% if (category.image) { %>
          <img src="<%= category.image %>" alt="Category Image" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;">
          <% } else { %>
          <span class="text-muted small">No Image</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
