<% 
    const productList = typeof products !== 'undefined' ? products : [];
    const currPg = typeof currentPage !== 'undefined' ? parseInt(currentPage) : 1;
    const pgLimit = typeof limit !== 'undefined' ? parseInt(limit) : 10;
%>

<div class="table-container-shared card border-0 shadow-sm admin-cards-responsive" id="productTableContainer">
    <% if (productList.length === 0) { %>
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
            <p class="text-muted">No results found for the given criteria.</p>
        </div>
<% } else { %>
        <!-- Desktop Table -->
        <table class="table table-hover shared-table-desktop mb-0">
            <thead class="thead-light">
                <tr>
                    <th style="width: 5%;">S.No</th>
                    <th style="width: 20%;">Name</th>
                    <th style="width: 20%;">Category</th>
                    <th style="width: 10%;">Price</th>
                    <th style="width: 10%;">Stock</th>
                    <th style="width: 15%;">Images</th>
                    <th style="width: 10%;">Status</th>
                    <th style="width: 18%;" class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                <% productList.forEach((product, index) => { %>
                <tr data-row-id="<%= product._id %>">
                    <td><%= (currPg - 1) * pgLimit + (index + 1) %></td>
                    <td>
                        <div class="font-weight-bold text-dark"><%= product.name %></div>
                        <div class="small text-muted text-truncate" style="max-width: 200px;"><%= product.description %></div>
                    </td>
                    <td><%= product.category ? product.category.name : 'N/A' %></td>
                    <td>₹<%= product.price %></td>
                    <td>
                        <span class="<%= product.stock < 5 ? 'text-danger font-weight-bold' : '' %>">
                            <%= product.stock %>
                        </span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <% if (product.images && product.images.length > 0) { %>
                                <% product.images.slice(0, 3).forEach(img => { %>
                                    <img src="<%= img %>" class="rounded border mr-1" style="width: 35px; height: 35px; object-fit: cover;">
                                <% }) %>
                                <% if (product.images.length > 3) { %>
                                    <span class="small text-muted ml-1">+<%= product.images.length - 3 %></span>
                                <% } %>
                            <% } else { %>
                                <span class="text-muted small">No images</span>
                            <% } %>
                        </div>
                    </td>
                    <td>
                        <span class="status-box status-<%= product.isListed ? 'successful' : 'failed' %>" id="status-badge-<%= product._id %>">
                            <%= product.isListed ? 'Listed' : 'Unlisted' %>
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex align-items-center justify-content-center">
                            <a href="/admin/products/<%= product._id %>/view?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>"
                               class="btn btn-sm rounded-pill px-3 mr-2 table-action-btn table-btn-view">
                                View
                            </a>
                            <a href="/admin/products/edit/<%= product._id %>?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>" 
                               class="btn btn-sm rounded-pill px-3 mr-2 table-action-btn table-btn-edit">
                                Edit
                            </a>
                            <button class="btn btn-sm toggle-status-btn rounded-pill px-3 table-action-btn <%= product.isListed ? 'table-btn-unlist' : 'table-btn-relist' %>" 
                                    data-id="<%= product._id %>"
                                    data-status="<%= product.isListed %>"
                                    onclick="toggleProductStatus(this)">
                                <%= product.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- Mobile Cards -->
        <div class="shared-cards-mobile p-3">
            <% productList.forEach((product, index) => { %>
            <div class="shared-item-card" data-card-id="<%= product._id %>">
                <div class="card-header-flex">
                    <span class="font-weight-bold">#<%= (currPg - 1) * pgLimit + (index + 1) %></span>
                    <span class="status-box status-<%= product.isListed ? 'successful' : 'failed' %>" id="status-badge-mobile-<%= product._id %>">
                        <%= product.isListed ? 'Listed' : 'Unlisted' %>
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="d-flex mb-3">
                        <% if (product.images && product.images.length > 0) { %>
                            <img src="<%= product.images[0] %>" class="rounded mr-3 shadow-sm" style="width: 70px; height: 70px; object-fit: cover; border: 1px solid #eee;">
                        <% } else { %>
                            <div class="bg-light rounded d-flex align-items-center justify-content-center mr-3" style="width: 70px; height: 70px; border: 1px solid #eee;">
                                <i class="fas fa-image text-muted"></i>
                            </div>
                        <% } %>
                        <div class="flex-grow-1">
                            <h6 class="font-weight-bold mb-1 text-dark"><%= product.name %></h6>
                            <p class="small text-muted mb-0">Cat: <%= product.category ? product.category.name : 'N/A' %></p>
                            <p class="font-weight-bold text-primary mb-0">₹<%= product.price %></p>
                        </div>
                    </div>
                    
                    <p><strong>Stock:</strong> <span class="<%= product.stock < 5 ? 'text-danger' : '' %>"><%= product.stock %></span></p>
                    
                    <div class="mt-4 row">
                        <div class="col-12 mb-2">
                            <a href="/admin/products/<%= product._id %>/view?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>" 
                               class="btn btn-sm btn-block rounded-pill table-action-btn table-btn-view">
                                View
                            </a>
                        </div>
                        <div class="col">
                            <a href="/admin/products/edit/<%= product._id %>?page=<%= currPg %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>&sort=<%= typeof sort !== 'undefined' ? sort : 'latest' %>" 
                               class="btn btn-sm btn-block rounded-pill table-action-btn table-btn-edit">
                                Edit
                            </a>
                        </div>
                        <div class="col">
                            <button class="btn btn-sm btn-block toggle-status-btn rounded-pill table-action-btn <%= product.isListed ? 'table-btn-unlist' : 'table-btn-relist' %>" 
                                    data-id="<%= product._id %>"
                                    data-status="<%= product.isListed %>"
                                    onclick="toggleProductStatus(this)">
                                <%= product.isListed ? 'Unlist' : 'Relist' %>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    <% } %>
    
        <!-- Pagination moved inside for AJAX refresh support -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="px-3 pb-3">
            <%- include('../Common/pagination') %>
        </div>
        <% } %>
</div>
