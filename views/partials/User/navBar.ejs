<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>navbar</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

  <!-- Google Fonts: Poppins -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <link rel="stylesheet" href="/styles/user/nav.css">
  <style>
    .navbar-nav {
      flex-direction: column;
      /* Stack items vertically */
      align-items: center;
      /* Center items horizontally */
    }

    @media (min-width: 992px) {

      /* Adjust for larger screens */
      .navbar-nav {
        flex-direction: row;
        /* Stack items horizontally for larger screens */
      }
    }

    .navbar .nav-item {
      margin: 0.5rem 0;
      /* Add margin for vertical spacing */
    }

    .collapse {
      background-color: rgba(255, 255, 255, 0.8) !important;
      /* White with 80% opacity */
    }
  </style>
  <meta name="user-id" content="<%= user ? user._id : '' %>">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-light position-fixed header-nav">
    <a class="navbar-brand" href="/user/home"><img src="/images/logo-bg-removed.png"></a>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav mx-auto">
        <!-- Center the navbar items -->
        <li class="nav-item active">
          <a class="nav-link" href="/user/home">Home</a>
        </li>
        <li class="nav-item active">
          <a class="nav-link" href="/user/shop">Shop</a>
        </li>
        <li class="nav-item active">
          <a class="nav-link" href="/#category">Categories</a>
        </li>
        <li class="nav-item active">
          <a class="nav-link" href="/#new-arrivals">New-Arrivals</a>
        </li>
         <li class="nav-item active">
          <a class="nav-link" href="/user/home#return-policy">Return-Policy</a>
        </li>
      </ul>
    </div>

    <!-- Icons and Toggle Button -->
    <div class="d-flex align-items-center position-absolute" style="right: 20px; top: 10px;">
      <div class="navbar-icons d-flex">
        <a href="/cart" class="nav-link"><i class="fas fa-shopping-cart"></i></a>
        <a href="/wishlist" class="nav-link"><i class="fas fa-heart"></i></a>
        <a href="/profile" class="nav-link"><i class="fas fa-user"></i></a>
      </div>
  </nav>

  <!-- SweetAlert2 & Custom Helper -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/swalHelper.js"></script>
  <script>
    window.handleBlockedSessionResponse = async function(response) {
      if (!response || response.status !== 401) return response;

      const contentType = response.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) return response;

      const payload = await response.clone().json().catch(() => null);
      if (!payload || !payload.logout) return response;

      const message = payload.error || payload.message || 'Your session is no longer available.';
      const redirect = payload.redirect || '/auth/login';
      await SwalCustom.error('Session Ended', message);
      window.location.href = redirect;
      return null;
    };

    window.authAwareFetch = async function(url, options = {}) {
      const mergedOptions = { ...options };
      const headers = new Headers(options.headers || {});
      if (!headers.has('Accept')) headers.set('Accept', 'application/json');
      if (!headers.has('X-Requested-With')) headers.set('X-Requested-With', 'XMLHttpRequest');
      mergedOptions.headers = headers;

      const response = await fetch(url, mergedOptions);
      return window.handleBlockedSessionResponse(response);
    };
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
</body>

</html>
