<div class="wishlist-content-area">
  <div class="row" id="wishlist-grid">
    <% if (products && products.length > 0) { %>
      <% products.forEach(({ product, bestOffer, averageRating }) => { %>
        <%- include('wishlistCard', { product: product, bestOffer: bestOffer, cartItemMap: cartItemMap, averageRating: averageRating }) %>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="text-center py-5 shadow-sm bg-white rounded">
          <i class="fas fa-heart fa-3x text-muted mb-3"></i>
          <% if (typeof search !== 'undefined' && search) { %>
            <p class="text-muted mb-0">No wishlist items found for "<strong><%= search %></strong>".</p>
          <% } else { %>
            <p class="text-muted mb-0">Your wishlist is empty. <a href="/user/home" style="font-weight: bold; color: #9135ED;">Continue Shopping</a></p>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>

  <% if (products && products.length > 0) { %>
    <div class="row mt-1">
      <div class="col-12 d-flex justify-content-center">
        <%- include('../Common/pagination', { currentPage: currentPage, totalPages: totalPages }) %>
      </div>
    </div>
  <% } %>
</div>
