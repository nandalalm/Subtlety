<div class="user-sidebar-wrapper">
  <!-- Mobile Toggle Button -->
  <button class="btn btn-primary d-lg-none sidebar-toggle-btn" id="sidebarToggle">
    <i class="fas fa-bars"></i>
  </button>

  <aside class="user-sidebar" id="userSidebar">
    <div class="sidebar-inner">
      <div class="sidebar-header">
        <h6 class="mb-0">Manage My Account</h6>
      </div>
      
      <nav class="sidebar-nav">
        <div class="nav-section">
          <p class="section-title">Account Settings</p>
          <ul class="list-unstyled">
            <li class="<%= activePage === 'profile' ? 'active' : '' %>">
              <a href="/profile" title="Profile">
                <i class="fas fa-user-circle"></i>
                <span class="nav-text">Profile</span>
              </a>
            </li>
            <li class="<%= activePage === 'address' ? 'active' : '' %>">
              <a href="/profile/address" title="Address Book">
                <i class="fas fa-map-marker-alt"></i>
                <span class="nav-text">Address Book</span>
              </a>
            </li>
          </ul>
        </div>

        <div class="nav-section">
          <p class="section-title">Orders & Activity</p>
          <ul class="list-unstyled">
            <li class="<%= activePage === 'orders' ? 'active' : '' %>">
              <a href="/orders" title="Orders">
                <i class="fas fa-shopping-bag"></i>
                <span class="nav-text">Orders</span>
              </a>
            </li>
            <li class="<%= activePage === 'wishlist' ? 'active' : '' %>">
              <a href="/wishlist" title="Wishlist">
                <i class="fas fa-heart"></i>
                <span class="nav-text">Wishlist</span>
              </a>
            </li>
            <li class="<%= activePage === 'wallet' ? 'active' : '' %>">
              <a href="/wallet" title="Wallet">
                <i class="fas fa-wallet"></i>
                <span class="nav-text">Wallet</span>
              </a>
            </li>
          </ul>
        </div>
      </nav>

      <div class="sidebar-footer">
        <form action="/auth/logout" method="POST" id="logout-form-sidebar">
          <button type="button" id="logout-btn-sidebar" class="btn btn-logout-sidebar" title="Logout">
            <i class="fas fa-sign-out-alt"></i>
            <span class="nav-text">Logout</span>
          </button>
        </form>
      </div>
    </div>
  </aside>
  
  <!-- Overlay for Mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sidebar = document.getElementById('userSidebar');
    const toggleBtn = document.getElementById('sidebarToggle');
    const overlay = document.getElementById('sidebarOverlay');
    const logoutBtn = document.getElementById('logout-btn-sidebar');
    const logoutForm = document.getElementById('logout-form-sidebar');

    if (toggleBtn) {
      toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('show');
        overlay.classList.toggle('show');
      });
    }

    if (overlay) {
      overlay.addEventListener('click', function() {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
      });
    }

    if (logoutBtn) {
      logoutBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (typeof Swal !== 'undefined') {
          Swal.fire({
            title: 'Are you sure?',
            text: "You will be logged out of your account.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, logout!',
            cancelButtonText: 'Cancel'
          }).then((result) => {
            if (result.isConfirmed) {
              logoutForm.submit();
            }
          });
        } else {
          if (confirm('Are you sure you want to logout?')) {
            logoutForm.submit();
          }
        }
      });
    }
  });
</script>
