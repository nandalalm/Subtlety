<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products - SUBTLETY</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/admin/dashboard.css">
    <link rel="stylesheet" href="/styles/shared/tables.css">
    <link rel="stylesheet" href="/styles/admin/products.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
    <div class="d-flex" id="wrapper">
        <%- include('../partials/Admin/adminSidebar', { activePage: 'products' }) %>

        <div id="page-content-wrapper">

            <div class="container-fluid">
                <h2 class="mb-4">Products</h2>

                <!-- Standardized Top Bar -->
                <div class="row mb-3 align-items-center">
                    <div class="col-lg-3 col-md-12 mb-3">
                        <a href="/admin/products/add" class="btn btn-primary btn-block rounded-pill">
                            <i class="fas fa-plus mr-1"></i> Add New Product
                        </a>
                    </div>

                    <div class="col-lg-5 col-md-12 mb-3">
                        <%- include('../partials/Common/searchBar', {
                          searchInputId: 'productSearchInput',
                          searchContainerId: 'productTableContainer',
                          searchPlaceholder: 'Search by name, category, price...',
                          searchValue: search || '',
                          searchBasePath: 'admin/products'
                        }) %>
                    </div>

                    <!-- Sort/Status Filter -->
                    <div class="col-lg-3 col-md-12 mb-3">
                        <div class="filter-sort-pill">
                            <select id="productSort" onchange="applyAjaxFilter('productTableContainer', 'sort', this.value, 'admin/products'); document.getElementById('clearProductSortBtn').style.display=this.value!=='latest'?'flex':'none';">
                                <option value="latest" <%=!sort || sort==='latest' ? 'selected' : '' %>>Sort: Latest</option>
                                <option value="oldest" <%=sort==='oldest' ? 'selected' : '' %>>Sort: Oldest</option>
                                <option disabled>── Status ──</option>
                                <option value="listed" <%=sort==='listed' ? 'selected' : '' %>>Listed</option>
                                <option value="unlisted" <%=sort==='unlisted' ? 'selected' : '' %>>Unlisted</option>
                            </select>
                            <button id="clearProductSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                              style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                              onclick="clearAjaxFilter('productTableContainer', 'sort', 'admin/products'); this.style.display='none'; document.getElementById('productSort').value='latest';">
                              <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                </div>



        <%- include('../partials/Admin/productTable') %>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <!-- SweetAlert2 and swalHelper are now global via adminScripts partial -->

    <script>
        // Search, Sort, and Pagination is now handled by /js/ajaxTable.js

        function toggleProductStatus(button) {
            const productId = button.getAttribute('data-id');
            const isListedBool = button.getAttribute('data-status') === 'true';
            const action = isListedBool ? 'unlist' : 'relist';

            SwalCustom.confirm(
                'Are you sure?',
                `Do you want to ${action} this product?`,
                `Yes, ${action}!`,
                'Cancel'
            ).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/admin/products/toggle-list/${productId}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                isListed: isListedBool
                            }),
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                const newIsListed = data.product.isListed;
                                
                                // Update status badges
                                const desktopBadge = document.getElementById(`status-badge-${productId}`);
                                const mobileBadge = document.getElementById(`status-badge-mobile-${productId}`);
                                
                                if (desktopBadge) {
                                    desktopBadge.textContent = newIsListed ? 'Listed' : 'Unlisted';
                                    desktopBadge.className = `status-box status-${newIsListed ? 'successful' : 'failed'}`;
                                }
                                if (mobileBadge) {
                                    mobileBadge.textContent = newIsListed ? 'Listed' : 'Unlisted';
                                    mobileBadge.className = `status-box status-${newIsListed ? 'successful' : 'failed'}`;
                                }

                                // Update ALL toggle buttons for this product
                                const buttons = document.querySelectorAll(`button[data-id="${productId}"]`);
                                buttons.forEach(btn => {
                                    if (btn.classList.contains('toggle-status-btn')) {
                                        btn.textContent = newIsListed ? 'Unlist' : 'Relist';
                                        btn.setAttribute('data-status', newIsListed.toString());
                                        btn.className = `btn btn-sm rounded-pill table-action-btn ${newIsListed ? 'table-btn-unlist' : 'table-btn-relist'} ${btn.classList.contains('btn-block') ? 'btn-block' : 'px-3'}`;
                                    }
                                });

                                SwalCustom.success('Updated!', `Product has been ${newIsListed ? 'listed' : 'unlisted'}.`);
                            } else {
                                SwalCustom.error('Error', data.message || 'Could not update status.');
                            }
                        })
                        .catch(err => SwalCustom.error('Error', 'Network error. Please try again.'));
                }
            });
        }



    </script>


    <%- include('../partials/Admin/adminScripts') %>
</body>
</html>
