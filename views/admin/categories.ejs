<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categories - SUBTLETY</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <link rel="stylesheet" href="/styles/admin/categories.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.11.2/toastify.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'categories' }) %>

    <!-- Page Content -->
    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid">
        <h2 class="mb-4">Categories</h2>

        <div class="row mb-3 align-items-center">
          <div class="col-lg-3 col-md-12 mb-3">
            <button type="button" class="btn btn-primary btn-block rounded-pill" data-toggle="modal" data-target="#addCategoryModal">
              <i class="fas fa-plus mr-1"></i> Add New Category
            </button>
          </div>

          <!-- Search -->
          <div class="col-lg-5 col-md-12 mb-3">
            <%- include('../partials/Common/searchBar', {
              searchInputId: 'categorySearchInput',
              searchContainerId: 'categoryTableContainer',
              searchPlaceholder: 'Search by name...',
              searchValue: search || '',
              searchBasePath: 'admin/categories'
            }) %>
          </div>

          <!-- Sort/Status Filter -->
          <div class="col-lg-3 col-md-12 mb-3">
            <div class="filter-sort-pill">
              <select id="categorySort" onchange="applyAjaxFilter('categoryTableContainer', 'sort', this.value, 'admin/categories'); document.getElementById('clearCategorySortBtn').style.display=this.value!=='latest'?'flex':'none';">
                <option value="latest" <%=!sort || sort==='latest' ? 'selected' : '' %>>Sort: Latest</option>
                <option value="oldest" <%=sort==='oldest' ? 'selected' : '' %>>Sort: Oldest</option>
                <option disabled>── Status ──</option>
                <option value="listed" <%=sort==='listed' ? 'selected' : '' %>>Listed</option>
                <option value="unlisted" <%=sort==='unlisted' ? 'selected' : '' %>>Unlisted</option>
              </select>
              <button id="clearCategorySortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                onclick="clearAjaxFilter('categoryTableContainer', 'sort', 'admin/categories'); this.style.display='none'; document.getElementById('categorySort').value='latest';">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
        </div>

        <div class="modal fade" id="addCategoryModal" tabindex="-1" role="dialog" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-md" role="document">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
              <div class="modal-header bg-light">
                <h5 class="modal-title font-weight-bold" id="addCategoryModalLabel">Add New Category</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <form action="/admin/categories/add" method="POST" enctype="multipart/form-data" id="addCategoryForm" class="addCategoryForm" onsubmit="return validateCategoryForm(this)">
                <div class="modal-body p-4">
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Category Name</label>
                    <input type="text" name="name" class="form-control" required pattern="^[a-zA-Z]{4,}$">
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Category name must be at least 4 characters long and contain only letters.</div>
                  </div>
                  <div class="form-group">
                    <label class="font-weight-bold">Category Image</label>
                    <input type="file" id="imageAdd" name="image" class="form-control-file" accept="image/*" required>
                    <div id="imagePreviewAdd" class="mt-3" style="display:none;">
                      <img id="cropImageAdd" class="img-fluid rounded" style="max-height: 300px;">
                    </div>
                    <div id="error-message-add" class="text-danger mt-2 small" style="display: none;"></div>
                  </div>
                  <input type="hidden" name="isListed" value="true">
                </div>
                <div class="modal-footer bg-light">
                  <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">Close</button>
                  <button type="submit" class="btn btn-primary rounded-pill px-4">Add Category</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div id="categoryTableContainer">
          <%- include('../partials/Admin/categoryTable') %>
        </div>

    </div>
  </div>
</div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.11.2/toastify.min.js"></script>

  <script>
    let cropper; // Variable for Cropper instance

    // Image selection and cropping logic for both Add and Edit
    document.querySelectorAll('input[type="file"]').forEach(input => {
      input.addEventListener('change', function(event) {
        const file = event.target.files[0];
        const isEdit = this.id.startsWith('imageEdit');
        const isAdd = this.id === 'imageAdd';
        
        if (!file) return;

        const categoryId = isEdit ? this.id.replace('imageEdit', '') : '';
        const errorId = isAdd ? 'error-message-add' : `error-message-edit${categoryId}`;
        const errorEl = document.getElementById(errorId);

        // Validation for image types
        const validImageTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
        if (!validImageTypes.includes(file.type)) {
          if (errorEl) {
            errorEl.textContent = 'Please select a valid image file (jpg, png, gif, webp).';
            errorEl.style.display = 'block';
          }
          this.value = '';
          return;
        } else if (errorEl) {
          errorEl.style.display = 'none';
        }

        const previewImgId = isEdit ? `cropImageEdit${categoryId}` : `cropImageAdd`;
        const previewContainerId = isEdit ? `imagePreviewEdit${categoryId}` : `imagePreviewAdd`;
        
        const imagePreview = document.getElementById(previewImgId);
        const reader = new FileReader();

        reader.onload = function(e) {
          imagePreview.src = e.target.result;
          document.getElementById(previewContainerId).style.display = 'block';

          if (cropper) cropper.destroy();
          cropper = new Cropper(imagePreview, {
            aspectRatio: 1,
            viewMode: 2,
            autoCropArea: 1
          });
        };
        reader.readAsDataURL(file);
      });
    });

    // Unified helper for AJAX form submission with Cropper
    function submitFormWithCropper(form, successMsg, callback) {
      if (cropper) {
        cropper.getCroppedCanvas().toBlob((blob) => {
          if (blob) {
            const formData = new FormData(form);
            formData.set('image', blob, 'cropped.png');
            performSubmit(form.action, formData, successMsg, callback);
          }
        }, 'image/png');
      } else {
        performSubmit(form.action, new FormData(form), successMsg, callback);
      }
    }

    function performSubmit(action, formData, successMsg, callback) {
      // Show loading indicator
      Swal.fire({
        title: 'Processing...',
        text: 'Please wait while we upload the image.',
        allowOutsideClick: false,
        didOpen: () => {
          Swal.showLoading();
        }
      });

      fetch(action, {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(result => {
          Swal.close(); // Close loading indicator
          if (result.status || result.success) { // Handle variations in server response
            // Close all modals
            $('#addCategoryModal').modal('hide');
            $('.modal').modal('hide'); // Close all to be safe
            
            // Re-fetch only the table partial
            refreshTable('categoryTableContainer');

            Toastify({
              text: result.message || "Operation successful!",
              duration: 3000,
              close: true,
              gravity: "top",
              position: "center",
              backgroundColor: "linear-gradient(to right, #00b09b, #96c93d)",
            }).showToast();
          } else {
            Toastify({
              text: result.message || "Error processing request",
              duration: 3000,
              close: true,
              gravity: "top",
              position: "center",
              backgroundColor: "linear-gradient(to right, #ff4949, #ee2020)",
            }).showToast();
          }
        })
        .catch(error => {
          Swal.close(); // Close loading indicator
          console.error('Fetch error:', error);
          Toastify({
            text: "An error occurred",
            duration: 3000,
            close: true,
            gravity: "top",
            position: "center",
            backgroundColor: "linear-gradient(to right, #ff4949, #ee2020)",
          }).showToast();
        });
    }

    // Handle form submission for Add Category
    document.querySelectorAll('.addCategoryForm').forEach(form => {
      form.addEventListener('submit', function(event) {
        event.preventDefault();
        if (validateCategoryForm(this)) {
          submitFormWithCropper(this, 'categoryAdded');
        }
      });
    });

    // Handle form submission for Edit Category
    document.querySelectorAll('.editCategoryForm').forEach(form => {
      form.addEventListener('submit', function(event) {
        event.preventDefault();
        if (validateCategoryForm(this)) {
          submitFormWithCropper(this, 'categoryEdited');
        }
      });
    });

    // Check for success messages on page load
    document.addEventListener('DOMContentLoaded', function() {
      if (localStorage.getItem('categoryAdded') === 'true') {
        Toastify({
          text: "New category added successfully!",
          duration: 3000,
          close: true,
          gravity: "top",
          position: "center",
          backgroundColor: "linear-gradient(to right, #00b09b, #96c93d)",
        }).showToast();
        localStorage.removeItem('categoryAdded');
      }
      if (localStorage.getItem('categoryEdited') === 'true') {
        Toastify({
          text: "Category updated successfully!",
          duration: 3000,
          close: true,
          gravity: "top",
          position: "center",
          backgroundColor: "linear-gradient(to right, #00b09b, #96c93d)",
        }).showToast();
        localStorage.removeItem('categoryEdited');
      }
    });

    // Function to validate category form
    function validateCategoryForm(form) {
      const nameInput = form.querySelector('input[name="name"]');
      const nameValue = nameInput.value.trim();
      const namePattern = /^[a-zA-Z]{4,}$/;

      if (namePattern.test(nameValue)) {
        nameInput.classList.add('is-valid');
        nameInput.classList.remove('is-invalid');
        return true;
      } else {
        nameInput.classList.add('is-invalid');
        nameInput.classList.remove('is-valid');
        return false;
      }
    }

    // Add real-time validation
    document.querySelectorAll('input[name="name"]').forEach(input => {
      input.addEventListener('input', function() {
        validateCategoryForm(this.form);
      });
    });

    // Search, Filter, and Pagination is now handled by /js/ajaxTable.js

    function toggleCategoryStatus(button) {
      const categoryId = button.getAttribute('data-id');
      const isCurrentlyListed = button.getAttribute('data-status') === 'true';
      const action = isCurrentlyListed ? 'unlist' : 'relist';

      Swal.fire({
        title: 'Are you sure?',
        text: `Do you want to ${action} this category?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#9135ED',
        cancelButtonColor: '#d33',
        confirmButtonText: `Yes, ${action}!`
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/categories/toggle-status/${categoryId}`, {
              method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                const isListed = data.category.isListed;
                
                // Update Desktop and Mobile status badges
                const desktopRow = document.querySelector(`tr[data-row-id="${categoryId}"]`);
                const mobileCard = document.querySelector(`.shared-item-card[data-card-id="${categoryId}"]`);
                
                // Desktop row logic (if it exists)
                if (desktopRow) {
                  // The desktop doesn't use a status box but I'll add one if needed? 
                  // Wait, check mobile card first as it definitely has one.
                }
                
                if (mobileCard) {
                  const badge = mobileCard.querySelector('.status-box');
                  if (badge) {
                    badge.textContent = isListed ? 'Listed' : 'Unlisted';
                    badge.className = `status-box status-${isListed ? 'successful' : 'failed'}`;
                  }
                }

                // Update ALL toggle buttons for this category
                const buttons = document.querySelectorAll(`button[data-id="${categoryId}"]`);
                buttons.forEach(btn => {
                  if (btn.classList.contains('toggle-status-btn')) {
                    btn.textContent = isListed ? 'Unlist' : 'Relist';
                    btn.setAttribute('data-status', isListed.toString());
                    btn.className = `btn btn-sm rounded-pill ${isListed ? 'btn-outline-secondary' : 'btn-outline-primary'} ${btn.classList.contains('btn-block') ? 'btn-block' : 'px-3'}`;
                  }
                });

                Swal.fire({
                  icon: 'success',
                  title: 'Updated!',
                  text: `Category has been ${isListed ? 'listed' : 'unlisted'}.`,
                  toast: true,
                  position: 'top-end',
                  showConfirmButton: false,
                  timer: 3000
                });
              } else {
                Swal.fire('Error', data.message || 'Could not update status.', 'error');
              }
            })
            .catch(() => Swal.fire('Error', 'Network error.', 'error'));
        }
      });
    }
  </script>
  <%- include('../partials/Admin/adminScripts') %>
</body>

</html>