<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categories - SUBTLETY</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <link rel="stylesheet" href="/styles/admin/categories.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" rel="stylesheet" />
  <style>
    .form-control:focus,
    .custom-file-input:focus ~ .custom-file-label,
    .btn:focus,
    .btn:active {
      box-shadow: none !important;
    }
    .form-control.is-valid,
    .form-control.is-invalid,
    .custom-file-input.is-valid ~ .custom-file-label,
    .custom-file-input.is-invalid ~ .custom-file-label {
      background-image: none !important;
      box-shadow: none !important;
    }
    .form-control.is-valid,
    .custom-file-input.is-valid ~ .custom-file-label {
      border-color: #28a745 !important;
    }
    .form-control.is-invalid,
    .custom-file-input.is-invalid ~ .custom-file-label {
      border-color: #dc3545 !important;
    }
    .admin-validation-message {
      display: none;
      font-size: 0.82rem;
      margin-top: 0.35rem;
      font-weight: 500;
    }
    .admin-validation-message.is-error {
      display: block;
      color: #dc3545;
    }
    .admin-validation-message.is-success {
      display: block;
      color: #28a745;
    }
    .valid-feedback,
    .invalid-feedback {
      display: none;
      font-size: 0.82rem;
      font-weight: 500;
    }
    .form-control.is-valid ~ .valid-feedback {
      display: block;
    }
    .form-control.is-invalid ~ .invalid-feedback {
      display: block;
    }
    .category-edit-trigger:not(:hover):focus,
    .category-edit-trigger:not(:hover):focus-visible,
    .category-edit-trigger:not(:hover).focus,
    .category-edit-trigger:not(:hover).active {
      color: #d39e00 !important;
      background-color: transparent !important;
      border-color: #d39e00 !important;
      box-shadow: none !important;
    }
  </style>
  <!-- SweetAlert2 is handled globally via partials -->
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'categories' }) %>

    <!-- Page Content -->
    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid">
        <h2 class="mb-4">Categories</h2>

        <div class="row mb-3 align-items-center">
          <div class="col-lg-3 col-md-12 mb-3">
            <a href="/admin/categories/add?page=<%= currentPage || 1 %>&search=<%= encodeURIComponent(search || '') %>&sort=<%= sort || 'latest' %>" class="btn btn-primary btn-block rounded-pill">
              <i class="fas fa-plus mr-2"></i>Add New Category
            </a>
          </div>

          <!-- Search -->
          <div class="col-lg-5 col-md-12 mb-3">
            <%- include('../partials/Common/searchBar', {
              searchInputId: 'categorySearchInput',
              searchContainerId: 'categoryTableContainer',
              searchPlaceholder: 'Search by name...',
              searchValue: search || '',
              searchBasePath: 'admin/categories'
            }) %>
          </div>

          <!-- Sort/Status Filter -->
          <div class="col-lg-3 col-md-12 mb-3">
            <div class="filter-sort-pill">
              <select id="categorySort" onchange="applyAjaxFilter('categoryTableContainer', 'sort', this.value, 'admin/categories'); document.getElementById('clearCategorySortBtn').style.display=this.value!=='latest'?'flex':'none';">
                <option value="latest" <%=!sort || sort==='latest' ? 'selected' : '' %>>Sort: Latest</option>
                <option value="oldest" <%=sort==='oldest' ? 'selected' : '' %>>Sort: Oldest</option>
                <option disabled>── Status ──</option>
                <option value="listed" <%=sort==='listed' ? 'selected' : '' %>>Listed</option>
                <option value="unlisted" <%=sort==='unlisted' ? 'selected' : '' %>>Unlisted</option>
              </select>
              <button id="clearCategorySortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                onclick="clearAjaxFilter('categoryTableContainer', 'sort', 'admin/categories'); this.style.display='none'; document.getElementById('categorySort').value='latest';">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
        </div>

        <div id="categoryTableContainer">
          <%- include('../partials/Admin/categoryTable') %>
        </div>

    </div>
  </div>
</div>
  <script>
    function openCategoryImagePreview(imageSrc, categoryName) {
      const previewImage = document.getElementById('categoryImagePreviewTarget');
      const previewTitle = document.getElementById('categoryImagePreviewTitle');

      if (previewImage) previewImage.src = imageSrc;
      if (previewTitle) previewTitle.textContent = categoryName || 'Category Image';

      $('#categoryImagePreviewModal').modal('show');
    }

    function toggleCategoryStatus(button) {
      const categoryId = button.getAttribute('data-id');
      const isCurrentlyListed = button.getAttribute('data-status') === 'true';
      const action = isCurrentlyListed ? 'unlist' : 'relist';

      SwalCustom.confirm(
        'Are you sure?',
        `Do you want to ${action} this category?`,
        `Yes, ${action}!`,
        'Cancel'
      ).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/categories/toggle-status/${categoryId}`, {
              method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                const isListed = data.category.isListed;
                
                // Update Desktop and Mobile status badges
                const desktopRow = document.querySelector(`tr[data-row-id="${categoryId}"]`);
                const mobileCard = document.querySelector(`.shared-item-card[data-card-id="${categoryId}"]`);

                if (desktopRow) {
                  const desktopBadge = desktopRow.querySelector('.status-box');
                  if (desktopBadge) {
                    desktopBadge.textContent = isListed ? 'Listed' : 'Unlisted';
                    desktopBadge.className = `status-box status-${isListed ? 'successful' : 'failed'}`;
                  }
                }

                if (mobileCard) {
                  const mobileBadge = mobileCard.querySelector('.status-box');
                  if (mobileBadge) {
                    mobileBadge.textContent = isListed ? 'Listed' : 'Unlisted';
                    mobileBadge.className = `status-box status-${isListed ? 'successful' : 'failed'}`;
                  }
                }

                // Update ALL toggle buttons for this category
                const buttons = document.querySelectorAll(`button[data-id="${categoryId}"]`);
                buttons.forEach(btn => {
                  if (btn.classList.contains('toggle-status-btn')) {
                    btn.textContent = isListed ? 'Unlist' : 'Relist';
                    btn.setAttribute('data-status', isListed.toString());
                    btn.className = `btn btn-sm rounded-pill table-action-btn ${isListed ? 'table-btn-unlist' : 'table-btn-relist'} ${btn.classList.contains('btn-block') ? 'btn-block' : 'px-3'}`;
                  }
                });

                SwalCustom.success('Updated!', `Category has been ${isListed ? 'listed' : 'unlisted'}.`);
              } else {
                SwalCustom.error('Error', data.message || 'Could not update status.');
              }
            })
            .catch(() => SwalCustom.error('Error', 'Network error.'));
        }
      });
    }
  </script>
  <%- include('../partials/Admin/adminScripts') %>
</body>

</html>
