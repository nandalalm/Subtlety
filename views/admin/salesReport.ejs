<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Report - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <style>
    /* Standardized Filter Select Style */
    .filter-select {
        border-radius: 20px;
        padding: 5px 15px;
        border: 1px solid #9135ED !important;
        height: 40px;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background-image: none !important;
        min-width: 150px;
        cursor: pointer;
    }


    /* Classy Summary Cards */
    .summary-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 12px 20px;
        flex: 1;
        margin-right: 15px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        transition: transform 0.2s ease;
    }
    
    .summary-card:hover {
        transform: translateY(-2px);
    }

    .summary-card:last-child { margin-right: 0; }

    .summary-label {
        font-size: 0.8rem;
        color: #777;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .summary-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
    }

    .clear-filter-icon {
        color: #9135ED;
        cursor: pointer;
        padding: 8px;
        font-size: 1.2rem;
        transition: color 0.2s;
    }

    .clear-filter-icon:hover {
        color: #dc3545;
    }

    .order-id-badge {
        font-weight: 600;
    }

    .custom-date-container {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-left: 10px;
    }

    .custom-date-input {
        border-radius: 10px;
        border: 1px solid #ccc;
        padding: 5px 10px;
        height: 40px;
    }

    /* Mild Badge Styles (moved to tables.css but kept here if not present) */
    .badge-mild-success { background-color: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
    .badge-mild-danger { background-color: #ffebee; color: #c62828; border: 1px solid #ffcdd2; }
    .badge-mild-warning { background-color: #fff3e0; color: #ef6c00; border: 1px solid #ffe0b2; }
    .badge-mild-info { background-color: #e3f2fd; color: #1565c0; border: 1px solid #bbdefb; }

  </style>
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'salesReport' }) %>

    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid">
        <h2 class="mb-4">Sales Report</h2>

        <!-- Action Bar -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap">
          <div class="d-flex align-items-center flex-wrap" style="gap: 10px;">
            <!-- Report Type Filter -->
            <div style="min-width: 175px;">
              <div class="filter-sort-pill shadow-sm">
                <select id="reportType" onchange="toggleCustomDates(this.value); if(this.value !== 'custom') applyAjaxFilter('salesTableContainerParent', 'reportType', this.value, 'admin/orders/sales-report'); document.getElementById('clearSalesReportBtn').style.display=this.value!=='all'?'flex':'none';">
                  <option value="all" <%= reportType === 'all' ? 'selected' : '' %>>All Time</option>
                  <option value="daily" <%= reportType === 'daily' ? 'selected' : '' %>>Daily</option>
                  <option value="monthly" <%= reportType === 'monthly' ? 'selected' : '' %>>Monthly</option>
                  <option value="yearly" <%= reportType === 'yearly' ? 'selected' : '' %>>Yearly</option>
                  <option value="custom" <%= reportType === 'custom' ? 'selected' : '' %>>Custom Range</option>
                </select>
                <button id="clearSalesReportBtn" type="button" class="sort-clear-inner" title="Clear Filters"
                  style="display:<%= reportType !== 'all' ? 'flex' : 'none' %>;"
                  onclick="clearAjaxFilter('salesTableContainerParent', 'reportType', 'admin/orders/sales-report'); document.getElementById('reportType').value='all'; toggleCustomDates('all'); this.style.display='none';">
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>

            <!-- Custom Date Inputs -->
            <div id="customDateRange" class="align-items-center mb-3" style="display: <%= reportType === 'custom' ? 'flex' : 'none' %>; gap: 8px;">
              <div class="filter-sort-pill shadow-sm px-2" style="background: white;">
                <input type="date" id="startDate" class="border-0 bg-transparent" style="height: 38px; outline: none;" value="<%= startDate %>">
                <span class="text-muted mx-1">to</span>
                <input type="date" id="endDate" class="border-0 bg-transparent" style="height: 38px; outline: none;" value="<%= endDate %>">
              </div>
              
              <button class="btn btn-primary rounded-pill px-4 shadow-sm" style="height: 40px; background: #9135ED; border: none;" onclick="applySalesFilter()">
                Generate
              </button>
            </div>
          </div>

          <div class="d-flex align-items-center mt-lg-0 mt-3">
            <button id="downloadPdf" class="btn btn-outline-danger shadow-sm rounded-pill px-4 mr-2" style="height: 40px;">
              <i class="fas fa-file-pdf mr-1"></i> PDF
            </button>
            <button id="downloadExcel" class="btn btn-outline-success shadow-sm rounded-pill px-4" style="height: 40px;">
              <i class="fas fa-file-excel mr-1"></i> Excel
            </button>
          </div>
        </div>

        <div id="salesTableContainerParent">
          <%- include('../partials/Admin/salesSummary') %>
          <%- include('../partials/Admin/salesTable') %>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function toggleCustomDates(value) {
        document.getElementById('customDateRange').style.display = (value === 'custom') ? 'flex' : 'none';
    }

    document.addEventListener('DOMContentLoaded', function() {
        toggleCustomDates(document.getElementById('reportType').value);
    });

    function applySalesFilter() {
        const reportType = document.getElementById('reportType').value;
        const startDate = document.getElementById('startDate').value;
        const endDate = document.getElementById('endDate').value;

        if (reportType === 'custom' && (!startDate || !endDate)) {
            return Swal.fire('Error', 'Please select both start and end dates', 'error');
        }

        const url = new URL(window.location.href);
        url.searchParams.set('reportType', reportType);
        if (reportType === 'custom') {
            url.searchParams.set('startDate', startDate);
            url.searchParams.set('endDate', endDate);
        } else {
            url.searchParams.delete('startDate');
            url.searchParams.delete('endDate');
        }
        url.searchParams.set('page', 1);

        refreshTable('salesTableContainerParent', url.pathname + url.search);
    }

    // PDF Download
    document.getElementById('downloadPdf').addEventListener('click', function() {
      const reportType = document.getElementById('reportType').value;
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;

      fetch('/admin/orders/sales-report/download/pdf', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reportType, startDate, endDate })
        })
        .then(response => response.ok ? response.blob() : Promise.reject('Export failed'))
        .then(blob => {
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'sales_report.pdf';
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
        })
        .catch(error => Swal.fire('Error', 'Failed to generate PDF', 'error'));
    });

    // Excel Download
    document.getElementById('downloadExcel').addEventListener('click', function() {
      const reportType = document.getElementById('reportType').value;
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;

      fetch('/admin/orders/sales-report/download/excel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reportType, startDate, endDate })
        })
        .then(response => response.ok ? response.blob() : Promise.reject('Export failed'))
        .then(blob => {
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'sales_report.xlsx';
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
        })
        .catch(error => Swal.fire('Error', 'Failed to generate Excel', 'error'));
    });
  </script>
  <%- include('../partials/Admin/adminScripts') %>
</body>
</html>