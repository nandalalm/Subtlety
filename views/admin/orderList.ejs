<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <style>
    .order-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
      border-bottom: 1px solid #f0f0f0;
      padding-bottom: 10px;
    }

    .order-card-body p { margin-bottom: 8px; font-size: 0.95rem; }
  </style>
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'orders' }) %>

    <!-- Page Content -->
    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid">
        <h2 class="mb-4">Order Management</h2>

        <!-- Standardized Search & Filter Bar -->
        <div class="row mb-3 align-items-center">
          <!-- Search -->
          <div class="col-lg-5 col-md-12 mb-3">
            <%- include('../partials/Common/searchBar', {
              searchInputId: 'adminOrderSearchInput',
              searchContainerId: 'orderTableContainer',
              searchPlaceholder: 'Search by Order ID or Email...',
              searchValue: search || '',
              searchBasePath: 'admin/orders'
            }) %>
          </div>

          <!-- Sort -->
          <div class="col-lg-3 col-md-12 mb-3">
            <div class="filter-sort-pill">
              <select id="adminOrderSortSelect" onchange="applyAjaxFilter('orderTableContainer', 'sort', this.value, 'admin/orders'); document.getElementById('clearAdminOrderSortBtn').style.display=this.value!=='default'?'flex':'none';">
                <option value="default" <%= sort === 'default' ? 'selected' : '' %>>Sort: Default Priority</option>
                <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Sort: Latest</option>
                <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Sort: Oldest</option>
                <option disabled>── Order Status ──</option>
                <option value="Pending" <%= sort === 'Pending' ? 'selected' : '' %>>Pending Only</option>
                <option value="Shipped" <%= sort === 'Shipped' ? 'selected' : '' %>>Shipped Only</option>
                <option value="Completed" <%= sort === 'Completed' ? 'selected' : '' %>>Completed Only</option>
                <option value="Cancelled" <%= sort === 'Cancelled' ? 'selected' : '' %>>Cancelled Only</option>
              </select>
              <button id="clearAdminOrderSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                style="display:<%= (sort !== 'default') ? 'flex' : 'none' %>;"
                onclick="clearAjaxFilter('orderTableContainer', 'sort', 'admin/orders'); this.style.display='none'; document.getElementById('adminOrderSortSelect').value='default';">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>

          <!-- Payment Status -->
          <div class="col-lg-3 col-md-12 mb-3">
            <div class="filter-sort-pill">
              <select id="orderPaymentSelect" onchange="applyAjaxFilter('orderTableContainer', 'paymentStatus', this.value, 'admin/orders'); document.getElementById('clearPaymentFilterBtn').style.display=this.value?'flex':'none';">
                <option value="" <%= !paymentStatus ? 'selected' : '' %>>Payment: All</option>
                <option value="Successful" <%= paymentStatus === 'Successful' ? 'selected' : '' %>>Successful Only</option>
                <option value="Pending" <%= paymentStatus === 'Pending' ? 'selected' : '' %>>Pending Only</option>
                <option value="Failed" <%= paymentStatus === 'Failed' ? 'selected' : '' %>>Failed Only</option>
              </select>
              <button id="clearPaymentFilterBtn" type="button" class="sort-clear-inner" title="Clear payment filter"
                style="display:<%= paymentStatus ? 'flex' : 'none' %>;"
                onclick="clearAjaxFilter('orderTableContainer', 'paymentStatus', 'admin/orders'); this.style.display='none'; document.getElementById('orderPaymentSelect').value='';">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
        </div>

        <div id="orderTableContainer">
          <%- include('../partials/Common/orderTable') %>
        </div>
      </div>
    </div>
  </div>

  <script>
    // AJAX Search, Filter, and Pagination is now handled by /js/ajaxTable.js
  </script>
  <%- include('../partials/Admin/adminScripts') %>
</body>

</html>
