<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mode === 'add' ? 'Add Category' : 'Edit Category' %> - SUBTLETY</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
  <style>
    :root { --primary-color: #9135ED; }
    body { font-family: 'Poppins', sans-serif; }
    .breadcrumb { background: transparent; padding: 0; margin-bottom: 5px; }
    .breadcrumb-item a { color: #6c757d; text-decoration: none; }
    .breadcrumb-item.active { color: var(--primary-color); }
    .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
    .card-header { background: white; border-bottom: 1px solid #eee; padding: 20px; border-radius: 15px 15px 0 0 !important; }
    .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); border-radius: 10px; padding: 10px 25px; }
    .btn-primary:hover { background-color: #7a2bc7; border-color: #7a2bc7; }
    .form-control:focus, .custom-file-input:focus ~ .custom-file-label, .btn:focus, .btn:active { box-shadow: none !important; }
    .form-control.is-valid, .form-control.is-invalid, .custom-file-input.is-valid ~ .custom-file-label, .custom-file-input.is-invalid ~ .custom-file-label { background-image: none !important; }
    .form-control.is-valid, .custom-file-input.is-valid ~ .custom-file-label { border-color: #28a745 !important; }
    .form-control.is-invalid, .custom-file-input.is-invalid ~ .custom-file-label { border-color: #dc3545 !important; }
    .field-feedback { display: none; margin-top: 0.35rem; font-size: 0.82rem; font-weight: 500; }
    .field-feedback.is-error { display: block; color: #dc3545 !important; }
    .image-preview-card { border: 1px solid #eee; border-radius: 14px; background: #fafafa; padding: 16px; }
    .cropper-container-wrapper { width: 100%; height: 420px; background: #333; overflow: hidden; }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'categories' }) %>
    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid pt-2 px-1 px-md-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a href="/admin/categories?<%= backQuery %>">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= mode === 'add' ? 'Add Category' : 'Edit Category' %></li>
          </ol>
        </nav>
        <div class="row">
          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h4 class="mb-0"><%= mode === 'add' ? 'Add New Category' : `Edit Category: ${category.name}` %></h4>
              </div>
              <div class="card-body p-4">
                <form id="categoryForm" enctype="multipart/form-data" novalidate>
                  <div class="row">
                    <div class="col-md-6">
                      <div class="form-group mb-4">
                        <label class="font-weight-600">Category Name</label>
                        <input type="text" id="name" name="name" class="form-control" value="<%= category?.name || '' %>" placeholder="Enter category name">
                        <small id="name-error" class="field-feedback"></small>
                      </div>
                      <div class="form-group mb-4">
                        <label class="font-weight-600">Category Image</label>
                        <div class="custom-file">
                          <input type="file" id="image" name="image" class="custom-file-input" accept="image/*">
                          <label class="custom-file-label" for="image"><%= mode === 'add' ? 'Choose image...' : 'Choose new image...' %></label>
                        </div>
                        <small id="image-error" class="field-feedback"></small>
                      </div>
                    </div>
                    <div class="col-md-6">
                      <div class="image-preview-card h-100">
                        <div class="small text-muted mb-2"><%= mode === 'add' ? 'Image Preview' : 'Current / New Image' %></div>
                        <% if (category?.image) { %>
                          <img id="currentImage" src="<%= category.image %>" alt="<%= category.name %>" class="img-fluid rounded shadow-sm mb-3" style="max-height: 220px;">
                        <% } %>
                        <img id="previewImage" src="" alt="Preview" class="img-fluid rounded shadow-sm" style="max-height: 220px; display:none;">
                      </div>
                    </div>
                    <div class="col-12">
                      <hr class="my-4">
                      <div class="d-flex justify-content-end">
                        <a href="/admin/categories?<%= backQuery %>" class="btn btn-light mr-3">Cancel</a>
                        <button type="submit" class="btn btn-primary"><%= mode === 'add' ? 'Save Category' : 'Update Category' %></button>
                      </div>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal fade" id="categoryCropperModal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog modal-lg">
      <div class="modal-content border-0">
        <div class="modal-header bg-dark text-white border-0">
          <h5 class="modal-title">Crop Image</h5>
          <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
        </div>
        <div class="modal-body p-0">
          <div class="cropper-container-wrapper">
            <img id="categoryCropperImage" src="">
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="applyCategoryCrop">Apply Crop</button>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/Admin/adminScripts') %>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
  <script>
    const form = document.getElementById('categoryForm');
    const nameInput = document.getElementById('name');
    const imageInput = document.getElementById('image');
    const previewImage = document.getElementById('previewImage');
    const currentImage = document.getElementById('currentImage');
    const imageLabel = document.querySelector('.custom-file-label');
    let cropper = null;
    let croppedImageBlob = null;
    function setFieldMessage(id, message = '') {
      const el = document.getElementById(id);
      el.textContent = message;
      el.className = message ? 'field-feedback is-error' : 'field-feedback';
    }
    function validateName() {
      const value = nameInput.value.trim();
      if (!value) {
        nameInput.classList.add('is-invalid');
        nameInput.classList.remove('is-valid');
        setFieldMessage('name-error', 'Category name is required.');
        return false;
      }
      if (!/^[A-Za-z]{4,}$/.test(value)) {
        nameInput.classList.add('is-invalid');
        nameInput.classList.remove('is-valid');
        setFieldMessage('name-error', 'Use at least 4 letters with no numbers or symbols.');
        return false;
      }
      nameInput.classList.remove('is-invalid');
      nameInput.classList.add('is-valid');
      setFieldMessage('name-error');
      return true;
    }
    function validateImage(force = false) {
      const hasFile = Boolean(croppedImageBlob || (imageInput.files && imageInput.files.length > 0));
      if (<%= mode === 'add' ? 'true' : 'false' %> && !hasFile && force) {
        imageInput.classList.add('is-invalid');
        imageInput.classList.remove('is-valid');
        setFieldMessage('image-error', 'Category image is required.');
        return false;
      }
      if (hasFile) {
        imageInput.classList.remove('is-invalid');
        imageInput.classList.add('is-valid');
        setFieldMessage('image-error');
      } else {
        imageInput.classList.remove('is-invalid', 'is-valid');
        if (force) setFieldMessage('image-error');
      }
      return true;
    }
    nameInput.addEventListener('input', validateName);
    imageInput.addEventListener('change', function() {
      const file = this.files[0];
      imageLabel.textContent = file ? file.name : '<%= mode === "add" ? "Choose image..." : "Choose new image..." %>';
      croppedImageBlob = null;
      if (!file) {
        validateImage();
        return;
      }
      if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
        this.value = '';
        imageLabel.textContent = '<%= mode === "add" ? "Choose image..." : "Choose new image..." %>';
        imageInput.classList.add('is-invalid');
        imageInput.classList.remove('is-valid');
        setFieldMessage('image-error', 'Only JPG, PNG, or WEBP images are allowed.');
        return;
      }
      setFieldMessage('image-error');
      imageInput.classList.remove('is-invalid');
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('categoryCropperImage').src = e.target.result;
        $('#categoryCropperModal').modal('show');
      };
      reader.readAsDataURL(file);
    });
    $('#categoryCropperModal').on('shown.bs.modal', function () {
      cropper = new Cropper(document.getElementById('categoryCropperImage'), {
        aspectRatio: 1,
        viewMode: 1,
        autoCropArea: 1
      });
    }).on('hidden.bs.modal', function () {
      if (cropper) {
        cropper.destroy();
        cropper = null;
      }
    });
    document.getElementById('applyCategoryCrop').addEventListener('click', function() {
      if (!cropper) return;
      const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
      canvas.toBlob((blob) => {
        croppedImageBlob = blob;
        previewImage.src = URL.createObjectURL(blob);
        previewImage.style.display = 'block';
        if (currentImage) currentImage.style.display = 'none';
        imageInput.classList.remove('is-invalid');
        imageInput.classList.add('is-valid');
        setFieldMessage('image-error');
        $('#categoryCropperModal').modal('hide');
      }, 'image/jpeg', 0.9);
    });
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const valid = validateName() & validateImage(true);
      if (!valid) return;
      const formData = new FormData();
      formData.append('name', nameInput.value.trim());
      formData.append('isListed', '<%= category?.isListed ?? true %>');
      if (croppedImageBlob) formData.append('image', croppedImageBlob, 'category.jpg');
      else if (imageInput.files[0]) formData.append('image', imageInput.files[0]);
      const endpoint = '<%= mode === "add" ? "/admin/categories/add" : `/admin/categories/edit/${category._id}` %>';
      const response = await SwalCustom.withDelayedProcessing(
        () => fetch(endpoint, { method: 'POST', body: formData }),
        { title: 'Uploading...', text: 'Please wait while we save the category image.' }
      );
      const data = await response.json();
      if (!response.ok || data.status === false) {
        return SwalCustom.error('Error', data.message || 'Failed to save category');
      }
      await SwalCustom.success('Success', data.message || 'Category saved successfully');
      window.location.href = '/admin/categories?<%= backQuery %>';
    });
  </script>
</body>
</html>
