<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= mode === 'add' ? 'Add Coupon' : 'Edit Coupon' %> - SUBTLETY</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <style>
    :root { --primary-color: #9135ED; }
    body { font-family: 'Poppins', sans-serif; }
    .breadcrumb { background: transparent; padding: 0; margin-bottom: 5px; }
    .breadcrumb-item a { color: #6c757d; text-decoration: none; }
    .breadcrumb-item.active { color: var(--primary-color); }
    .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
    .card-header { background: white; border-bottom: 1px solid #eee; padding: 20px; border-radius: 15px 15px 0 0 !important; }
    .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); border-radius: 10px; padding: 10px 25px; }
    .btn-primary:hover { background-color: #7a2bc7; border-color: #7a2bc7; }
    .form-control:focus, .btn:focus, .btn:active { box-shadow: none !important; }
    .form-control.is-valid, .form-control.is-invalid { background-image: none !important; box-shadow: none !important; }
    .form-control.is-invalid { border-color: #dc3545 !important; }
    .field-feedback { display: none; margin-top: 0.35rem; font-size: 0.82rem; font-weight: 500; }
    .field-feedback.is-error { display: block; color: #dc3545 !important; }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'coupons' }) %>
    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid pt-2 px-1 px-md-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a href="/admin/offers/coupons?<%= backQuery %>">Coupons</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= mode === 'add' ? 'Add Coupon' : 'Edit Coupon' %></li>
          </ol>
        </nav>
        <div class="card">
          <div class="card-header"><h4 class="mb-0"><%= mode === 'add' ? 'Add New Coupon' : 'Edit Coupon' %></h4></div>
          <div class="card-body p-4">
            <form id="couponForm" novalidate>
              <div class="row">
                <div class="col-md-6">
                  <div class="form-group mb-4"><label>Coupon Code</label><input id="code" class="form-control" value="<%= coupon?.code || '' %>" placeholder="e.g. SAVE20"><small id="code-error" class="field-feedback"></small></div>
                  <div class="form-group mb-4"><label>Discount Type</label><select id="discountType" class="form-control"><option value="">Choose the discount type</option><option value="flat" <%= coupon?.discountType==='flat'?'selected':'' %>>Flat Discount</option><option value="percentage" <%= coupon?.discountType==='percentage'?'selected':'' %>>Percentage Discount</option></select><small id="discountType-error" class="field-feedback"></small></div>
                  <div class="form-group mb-4"><label id="discountAmountLabel">Discount Amount</label><input id="discountAmount" type="number" class="form-control" value="<%= coupon?.discountAmount || '' %>" placeholder="Enter the discount value"><small id="discountAmount-error" class="field-feedback"></small></div>
                </div>
                <div class="col-md-6">
                  <div class="form-group mb-4" id="minOrderWrap" style="display:none;"><label>Minimum Order Value</label><input id="minOrderValue" type="number" class="form-control" value="<%= coupon?.minOrderValue || '' %>" placeholder="e.g. 2000"><small id="minOrderValue-error" class="field-feedback"></small></div>
                  <div class="form-group mb-4" id="maxDiscountWrap" style="display:none;"><label>Maximum Discount</label><input id="maxDiscount" type="number" class="form-control" value="<%= coupon?.maxDiscount || '' %>" placeholder="e.g. 500"><small id="maxDiscount-error" class="field-feedback"></small></div>
                  <div class="form-group mb-4"><label>Expiry Date</label><input id="expiresAt" type="date" class="form-control" value="<%= coupon?.expiresAt ? new Date(coupon.expiresAt).toISOString().split('T')[0] : '' %>" placeholder="Select an expiry date"><small id="expiresAt-error" class="field-feedback"></small></div>
                  <div class="form-group mb-4"><label>Usage Limit</label><input id="usageLimit" type="number" class="form-control" value="<%= coupon?.usageLimit || '' %>" placeholder="e.g. 100"><small id="usageLimit-error" class="field-feedback"></small></div>
                </div>
              </div>
              <hr class="my-4">
              <div class="d-flex justify-content-end">
                <a href="/admin/offers/coupons?<%= backQuery %>" class="btn btn-light mr-3">Cancel</a>
                <button class="btn btn-primary" type="submit"><%= mode === 'add' ? 'Save Coupon' : 'Update Coupon' %></button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/Admin/adminScripts') %>
  <script>
    const code = document.getElementById('code');
    const discountType = document.getElementById('discountType');
    const discountAmount = document.getElementById('discountAmount');
    const minOrderValue = document.getElementById('minOrderValue');
    const maxDiscount = document.getElementById('maxDiscount');
    const expiresAt = document.getElementById('expiresAt');
    const usageLimit = document.getElementById('usageLimit');
    const discountAmountLabel = document.getElementById('discountAmountLabel');
    const touchedFields = new Set();
    let submitAttempted = false;
    function setFieldState(id, message = '', showError = false) {
      const input = document.getElementById(id);
      const feedback = document.getElementById(`${id}-error`);
      if (showError && message) {
        input.classList.add('is-invalid');
        feedback.textContent = message;
        feedback.className = 'field-feedback is-error';
        return false;
      }
      input.classList.remove('is-invalid');
      feedback.textContent = '';
      feedback.className = 'field-feedback';
      return true;
    }
    function shouldShowError(id) {
      return submitAttempted || touchedFields.has(id);
    }
    function getToday() {
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      return today;
    }
    function validateField(id, forceShow = false) {
      const showError = forceShow || shouldShowError(id);
      let message = '';
      if (id === 'code') {
        if (!code.value.trim()) message = 'Coupon code is required.';
        else if (!/^[A-Za-z0-9]+$/.test(code.value.trim())) message = 'Use only letters and numbers, with no spaces.';
        else if (code.value.trim().length < 4) message = 'Coupon code must be at least 4 characters long.';
      }
      if (id === 'discountType' && !discountType.value) {
        message = 'Please select a discount type.';
      }
      if (id === 'discountAmount') {
        if (!discountAmount.value || Number(discountAmount.value) <= 0) message = 'Discount amount must be greater than 0.';
        else if (discountType.value === 'percentage' && (Number(discountAmount.value) < 1 || Number(discountAmount.value) > 80)) {
          message = 'Percentage discount must be between 1 and 80.';
        } else if (discountType.value === 'flat' && minOrderValue.value && Number(discountAmount.value) >= Number(minOrderValue.value)) {
          message = 'Discount amount must be less than Minimum Order Value.';
        }
      }
      if (id === 'minOrderValue') {
        if (discountType.value === 'flat') {
          if (!minOrderValue.value || Number(minOrderValue.value) <= 0) message = 'Minimum order value must be greater than 0.';
          else if (Number(discountAmount.value) >= Number(minOrderValue.value)) message = 'Minimum order value must be greater than flat discount.';
        }
      }
      if (id === 'maxDiscount') {
        if (discountType.value === 'percentage' && maxDiscount.value && Number(maxDiscount.value) <= 0) {
          message = 'Maximum discount must be greater than 0.';
        }
      }
      if (id === 'expiresAt') {
        if (!expiresAt.value) message = 'Expiry date is required.';
        else if (new Date(expiresAt.value) < getToday()) message = 'Expiry date cannot be a past date.';
      }
      if (id === 'usageLimit') {
        if (!usageLimit.value || Number(usageLimit.value) < 1) message = 'Usage limit must be at least 1.';
      }
      return setFieldState(id, message, showError);
    }
    function syncVisibility() {
      document.getElementById('minOrderWrap').style.display = discountType.value === 'flat' ? 'block' : 'none';
      document.getElementById('maxDiscountWrap').style.display = discountType.value === 'percentage' ? 'block' : 'none';
      discountAmountLabel.textContent = discountType.value === 'percentage' ? 'Percentage Value' : 'Discount Amount';
      discountAmount.placeholder = discountType.value === 'percentage' ? 'e.g. 20' : 'e.g. 250';
    }
    function validateForm(forceShowAll = false) {
      syncVisibility();
      if (forceShowAll) submitAttempted = true;
      let ok = true;
      code.value = code.value.trimStart();
      ok = validateField('code', forceShowAll) && ok;
      ok = validateField('discountType', forceShowAll) && ok;
      ok = validateField('discountAmount', forceShowAll) && ok;
      ok = validateField('minOrderValue', forceShowAll) && ok;
      ok = validateField('maxDiscount', forceShowAll) && ok;
      ok = validateField('expiresAt', forceShowAll) && ok;
      ok = validateField('usageLimit', forceShowAll) && ok;
      if (ok) {
        code.value = code.value.trim().toUpperCase();
      }
      return ok;
    }
    function handleFieldInteraction(id, relatedFieldIds = []) {
      touchedFields.add(id);
      validateField(id);
      relatedFieldIds.forEach((relatedId) => validateField(relatedId));
    }
    code.addEventListener('input', () => handleFieldInteraction('code'));
    discountType.addEventListener('change', () => {
      handleFieldInteraction('discountType', ['discountAmount', 'minOrderValue', 'maxDiscount']);
      syncVisibility();
    });
    discountAmount.addEventListener('input', () => handleFieldInteraction('discountAmount', ['minOrderValue']));
    minOrderValue.addEventListener('input', () => handleFieldInteraction('minOrderValue', ['discountAmount']));
    [maxDiscount, expiresAt, usageLimit].forEach((input) => {
      input.addEventListener('input', () => handleFieldInteraction(input.id));
    });
    syncVisibility();
    document.getElementById('couponForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validateForm(true)) return;
      const body = { code: code.value.trim(), discountAmount: discountAmount.value, discountType: discountType.value, maxDiscount: maxDiscount.value, minOrderValue: minOrderValue.value, expiresAt: expiresAt.value, usageLimit: usageLimit.value };
      const endpoint = '<%= mode === "add" ? "/admin/offers/coupons/add" : `/admin/offers/coupons/${coupon?._id}` %>';
      const method = '<%= mode === "add" ? "POST" : "PUT" %>';
      const response = await SwalCustom.withDelayedProcessing(
        () => fetch(endpoint, { method, headers: { 'Content-Type':'application/json' }, body: JSON.stringify(body) }),
        { title: 'Saving...', text: 'Please wait while we save the coupon.' }
      );
      const data = await response.json();
      if (!response.ok || data.success === false) return SwalCustom.error('Error', data.message || 'Failed to save coupon');
      await SwalCustom.success('Success', data.message || 'Coupon saved successfully');
      window.location.href = '/admin/offers/coupons?<%= backQuery %>';
    });
  </script>
</body>
</html>
