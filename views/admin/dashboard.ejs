<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    .custom-sales-overview {
      max-width: 900px !important;
      /* Adjust the max-width as needed */
      margin: auto;
      /* Center the container */
    }
  </style>
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'dashboard' }) %>

    <div id="page-content-wrapper">

      <div class="container-fluid">
        <div class="row pt-3">
          <div class="col-md-3 mb-4">
            <div class="stat-card card-users">
              <div class="card-icon-wrapper"><i class="fas fa-users"></i></div>
              <div class="card-info-content">
                <h5 class="card-title">Total Users</h5>
                <p class="card-value"><%= totalUsers %></p>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-4">
            <div class="stat-card card-orders">
              <div class="card-icon-wrapper"><i class="fas fa-shopping-bag"></i></div>
              <div class="card-info-content">
                <h5 class="card-title">Total Orders</h5>
                <p class="card-value"><%= totalOrders %></p>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-4">
            <div class="stat-card card-sales">
              <div class="card-icon-wrapper"><i class="fas fa-wallet"></i></div>
              <div class="card-info-content">
                <h5 class="card-title">Total Sales</h5>
                <p class="card-value">₹ <%= totalOrderAmount %></p>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-4">
            <div class="stat-card card-pending">
              <div class="card-icon-wrapper"><i class="fas fa-clock"></i></div>
              <div class="card-info-content">
                <h5 class="card-title">Total Pending</h5>
                <p class="card-value"><%= totalPending %></p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-4 mb-5">
          <div class="row">
            <div class="col-md-7 mb-4">
              <div class="dashboard-card">
                <div class="card-header-custom">
                  <h3>Sales Overview</h3>
                  <select id="timeframeSelect" class="form-control">
                    <option value="daily">Daily</option>
                    <option value="weekly">Weekly</option>
                    <option value="monthly" selected>Monthly</option>
                    <option value="yearly">Yearly</option>
                  </select>
                </div>
                <div class="chart-container">
                  <canvas id="salesChart"></canvas>
                </div>
              </div>
            </div>

            <div class="col-md-5 mb-4">
              <div class="dashboard-card">
                <div class="card-header-custom">
                  <h3>Best Selling Categories</h3>
                </div>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Category</th>
                        <th class="text-center">Image</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% bestSellingCategories.forEach((category, index) => { %>
                      <tr>
                        <td><%= index + 1 %></td>
                        <td><%= category.name %></td>
                        <td class="text-center">
                          <% if (category.image) { %>
                          <img src="<%= category.image %>" alt="Category Image" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;">
                          <% } else { %>
                          <span class="text-muted small">No Image</span>
                          <% } %>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-md-12 mb-4">
              <div class="dashboard-card">
                <div class="card-header-custom">
                  <h3>Best Selling Products</h3>
                </div>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Product Name</th>
                        <th class="hide-xs">Description</th>
                        <th class="text-center">Image</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% bestSellingProducts.forEach(product => { %>
                      <tr>
                        <td><%= product.index %></td>
                        <td class="font-weight-bold"><%= product.name %></td>
                        <td class="text-muted small hide-xs"><%= product.description.substring(0, 100) %>...</td>
                        <td class="text-center">
                          <% if (product.images.length > 0) { %>
                          <img src="<%= product.images[0] %>" alt="Product Image" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;">
                          <% } else { %>
                          <span class="text-muted small">No Image</span>
                          <% } %>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-md-12 mb-4">
              <div class="dashboard-card">
                <div class="card-header-custom">
                  <h3>Top 5 Highest Rated Products</h3>
                </div>
                <% if (topRatedProducts && topRatedProducts.length > 0) { %>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Product Name</th>
                        <th>Rating</th>
                        <th class="hide-xs">No. of Ratings</th>
                        <th class="text-center hide-xs">Image</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% topRatedProducts.forEach((product, index) => { %>
                      <tr>
                        <td><%= index + 1 %></td>
                        <td class="font-weight-bold"><%= product.name %></td>
                        <td>
                          <div class="d-flex align-items-center">
                            <span class="text-warning mr-2" style="white-space: nowrap;">
                              <% for(let i = 1; i <= 5; i++) { %>
                              <% if (i <= Math.round(product.avgRating)) { %>
                              <i class="fas fa-star"></i>
                              <% } else { %>
                              <i class="far fa-star text-muted"></i>
                              <% } %>
                              <% } %>
                            </span>
                            <span class="text-muted small">(<%= product.avgRating.toFixed(1) %>)</span>
                          </div>
                        </td>
                        <td class="hide-xs"><span class="badge badge-light border"><%= product.reviewCount %> ratings</span></td>
                        <td class="text-center hide-xs">
                          <% if (product.image) { %>
                          <img src="<%= product.image %>" alt="Product Image" style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover;">
                          <% } else { %>
                          <span class="text-muted small">No Image</span>
                          <% } %>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
                <% } else { %>
                <div class="text-center py-5">
                  <i class="fas fa-star-half-alt fa-3x text-muted mb-3" style="opacity: 0.3;"></i>
                  <h4 class="text-muted font-weight-light">No rated products yet</h4>
                  <p class="text-muted small mb-0">Product rankings will appear here once users start leaving reviews.</p>
                </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
  </div>
  </div>

  <script id="salesData" type="application/json">
    <%- JSON.stringify({
      daily: salesByDay,
      weekly: salesByWeek,
      monthly: salesByMonth,
      yearly: salesByYear
    }) %>
  </script>

  <script>
    async function fetchSalesData() {
      const dataElement = document.getElementById('salesData');
      if (!dataElement) return null;
      try {
        return JSON.parse(dataElement.textContent);
      } catch (e) {
        console.error('Error parsing sales data:', e);
        return null;
      }
    }

    async function renderChart(timeframe = 'monthly') {
      const salesData = await fetchSalesData();


      if (!salesData || !salesData[timeframe]) {
        console.error('No sales data available.');
        return;
      }

      const ctx = document.getElementById('salesChart').getContext('2d');
      let labels;
      let data;

      const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

      if (timeframe === 'monthly') {
        labels = monthNames; // Use month names instead of numbers
        data = salesData[timeframe].map(monthData => monthData.sales); // Get sales amounts
      } else {
        labels = Object.keys(salesData[timeframe]);
        data = Object.values(salesData[timeframe]);
      }

      // Clear previous chart if it exists
      if (window.salesChart instanceof Chart) {
        window.salesChart.destroy();
      }

      // Initialize new chart
      window.salesChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Total Sales',
            data: data,
            borderColor: '#9135ED',
            backgroundColor: (context) => {
              const chart = context.chart;
              const {
                ctx,
                chartArea
              } = chart;
              if (!chartArea) return null;
              const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
              gradient.addColorStop(0, 'rgba(145, 53, 237, 0.2)');
              gradient.addColorStop(1, 'rgba(145, 53, 237, 0.01)');
              return gradient;
            },
            borderWidth: 3,
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#ffffff',
            pointBorderColor: '#9135ED',
            pointBorderWidth: 2,
            pointHoverRadius: 6,
            pointHoverBackgroundColor: '#9135ED',
            pointHoverBorderColor: '#ffffff',
            pointHoverBorderWidth: 2,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              backgroundColor: '#1e293b',
              padding: 12,
              titleFont: {
                size: 14,
                weight: '600'
              },
              bodyFont: {
                size: 13
              },
              displayColors: false,
              borderRadius: 8,
              callbacks: {
                label: (context) => ` Sales: ₹${context.raw.toLocaleString()}`
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(0, 0, 0, 0.05)',
                drawBorder: false
              },
              ticks: {
                color: '#64748b',
                font: {
                  size: 11
                },
                callback: function(value) {
                  return '₹' + value.toLocaleString();
                }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                color: '#64748b',
                font: {
                  size: 11
                }
              }
            }
          }
        }
      });
    }

    document.getElementById('timeframeSelect').addEventListener('change', (event) => {
      const selectedTimeframe = event.target.value;
      renderChart(selectedTimeframe);
    });

    // Initialize chart on load
    document.addEventListener('DOMContentLoaded', () => {
      renderChart('monthly');
    });
  </script>
  <%- include('../partials/Admin/adminScripts') %>

</body>

</html>
