<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - SUBTLETY</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/admin/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.0.19/dist/sweetalert2.min.css">

    <style>
        :root {
            --primary-color: #9135ED;
            --secondary-color: #f3f0ff;
        }
        body { font-family: 'Poppins', sans-serif; }
        .breadcrumb { background: transparent; padding: 0; margin-bottom: 5px; }
        .breadcrumb-item { font-size: 0.95rem; }
        .breadcrumb-item a { color: var(--primary-color); text-decoration: none; }
        .breadcrumb-item.active { color: #6c757d; }
        
        @media (max-width: 768px) {
            .breadcrumb-item { font-size: 0.8rem; }
        }
        
        /* Custom Blue Button for Crop personally verified */
        .btn-blue {
            background-color: #007bff;
            border-color: #007bff;
            color: white;
            border-radius: 10px;
            padding: 10px 25px;
            transition: all 0.3s;
        }
        .btn-blue:hover {
            background-color: #0069d9;
            border-color: #0062cc;
            color: white;
        }
        
        .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .card-header { background: white; border-bottom: 1px solid #eee; padding: 20px; border-radius: 15px 15px 0 0 !important; }
        .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); border-radius: 10px; padding: 10px 25px; }
        .btn-primary:hover { background-color: #7a2bc7; border-color: #7a2bc7; }
        
        /* Image Slot System personally verified */
        .image-slots-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }

        .image-slot {
            aspect-ratio: 1;
            border: 2px dashed #ddd;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            cursor: pointer;
            overflow: hidden;
            background: #fafafa;
            transition: all 0.3s ease;
        }

        .image-slot:hover { border-color: var(--primary-color); background: var(--secondary-color); }
        .image-slot img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.3s; }
        
        .image-slot.has-image:hover img { opacity: 0.6; }
        .image-slot.has-image::after {
            content: '\f093'; /* fa-upload */
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 24px;
            color: var(--primary-color);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .image-slot.has-image:hover::after { opacity: 1; }
        
        .image-slot .remove-image {
            position: absolute;
            top: 5px; right: 5px;
            background: rgba(255, 0, 0, 0.7);
            color: white;
            border-radius: 50%;
            width: 24px; height: 24px;
            display: none;
            align-items: center; justify-content: center;
            font-size: 14px; z-index: 10;
        }

        .image-slot.has-image .remove-image { display: flex; }
        .image-slot.has-image .slot-placeholder { display: none; }

        .slot-placeholder { text-align: center; color: #888; }
        .slot-placeholder i { font-size: 24px; margin-bottom: 5px; }
        .slot-placeholder span { font-size: 11px; display: block; }

        /* Cropper Modal High Quality Styles personally verified */
        .cropper-container-wrapper {
            width: 100%;
            height: 500px;
            background: #333;
            overflow: hidden;
        }

        /* Responsive Fixes personally verified */
        @media (max-width: 768px) {
            .image-slots-container { grid-template-columns: repeat(3, 1fr); }
        }

        /* Remove Bootstrap green tick personally verified */
        .form-control.is-valid {
            background-image: none !important;
            border-color: #28a745 !important;
        }
        .form-control.is-invalid {
            background-image: none !important;
            border-color: #dc3545 !important;
        }
    </style>
</head>
<body class="bg-light">
    <!-- ... same body content ... -->
    <%- include('partials/adminNavbar') %>
    <div class="d-flex" id="wrapper">
        <%- include('partials/adminSidebar', { activePage: 'products' }) %>

        <div id="page-content-wrapper" class="w-100">
            <div class="container-fluid pt-2 px-1 px-md-3">
                <!-- Breadcrumbs personally verified -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/admin/products">Products</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Add Product</li>
                    </ol>
                </nav>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h4 class="mb-0">Add New Product</h4>
                            </div>
                            <div class="card-body p-4">
                                <form id="addProductForm">
                                    <div class="row">
                                        <!-- Basic Info personally verified -->
                                        <div class="col-md-6">
                                            <div class="form-group mb-4">
                                                <label class="font-weight-600">Product Name</label>
                                                <input type="text" name="name" class="form-control" placeholder="Enter product name" minlength="3">
                                                <small id="name-error" class="text-danger" style="display: none;"></small>
                                            </div>
                                            <div class="form-group mb-4">
                                                <label class="font-weight-600">Category</label>
                                                <select name="category" class="form-control">
                                                    <option value="">Select Category</option>
                                                    <% categories.forEach(cat => { %>
                                                        <option value="<%= cat._id %>"><%= cat.name %></option>
                                                    <% }) %>
                                                </select>
                                                <small id="category-error" class="text-danger" style="display: none;"></small>
                                            </div>
                                            <div class="row">
                                                <div class="col-6">
                                                    <div class="form-group mb-4">
                                                        <label class="font-weight-600">Price (₹)</label>
                                                        <input type="number" name="price" class="form-control" placeholder="0.00" step="0.01">
                                                        <small id="price-error" class="text-danger" style="display: none;"></small>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="form-group mb-4">
                                                        <label class="font-weight-600">Stock</label>
                                                        <input type="number" name="stock" class="form-control" placeholder="0">
                                                        <small id="stock-error" class="text-danger" style="display: none;"></small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Description personally verified -->
                                        <div class="col-md-6">
                                            <div class="form-group mb-4">
                                                <label class="font-weight-600">Description</label>
                                                <textarea name="description" class="form-control" rows="8" placeholder="Enter product description" minlength="10"></textarea>
                                                <small id="description-error" class="text-danger" style="display: none;"></small>
                                            </div>
                                        </div>

                                        <!-- Images Section personally verified -->
                                        <div class="col-12 mt-4">
                                            <h5 class="mb-3">Product Images <small class="text-muted">(Min 3, Max 8)</small></h5>
                                            <div id="add-image-slots" class="image-slots-container">
                                                <!-- Slots generated by JS personally verified -->
                                            </div>
                                            <button type="button" class="btn btn-outline-primary btn-sm mb-3" id="add-more-images-btn">
                                                <i class="fas fa-plus mr-1"></i> Add More Images
                                            </button>
                                            <div id="image-count-error" class="text-danger small mb-3" style="display: none;">You must upload at least 3 images.</div>
                                            
                                            <hr class="my-4">
                                            
                                            <div class="d-flex justify-content-end">
                                                <button type="button" class="btn btn-light mr-3" onclick="window.location.href='/admin/products'">Cancel</button>
                                                <button type="submit" class="btn btn-success">
                                                    <i class="fas fa-check mr-2"></i> Save Product
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Simplified Cropper Modal personally verified -->
    <div class="modal fade" id="cropperModal" tabindex="-1" role="dialog" data-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header bg-dark text-white border-0">
                    <h5 class="modal-title">Crop Image</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0">
                    <div class="cropper-container-wrapper">
                        <img id="cropperImage" src="">
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-blue" id="cropFinalButton">Apply Crop</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/adminScripts') %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const productImagesState = new Map();
        let cropper = null;
        let currentModalId = null;
        let currentSlotIndex = null;

        function initImageSlots(containerId, existingImages = []) {
            let state = existingImages.map(img => ({
                file: null,
                url: img.startsWith('/') ? img : '/' + img,
                isOriginal: true,
                rawPath: img
            }));
            if (state.length === 0) {
                for (let i = 0; i < 3; i++) state.push({ file: null, url: null, isOriginal: false });
            }
            productImagesState.set(containerId, state);
            renderSlots(containerId);
        }

        function renderSlots(containerId) {
            const container = document.getElementById(containerId);
            const state = productImagesState.get(containerId);
            container.innerHTML = '';
            state.forEach((item, index) => {
                const slot = document.createElement('div');
                slot.className = `image-slot ${item.url ? 'has-image' : ''}`;
                slot.innerHTML = `
                    <div class="slot-placeholder">
                        <i class="fas fa-camera"></i>
                        <span>${item.url ? 'Change' : 'Add Image'}</span>
                    </div>
                    ${item.url ? `<img src="${item.url}" alt="Preview">` : ''}
                    <div class="remove-image" onclick="removeImageSlot(event, '${containerId}', ${index})">
                        <i class="fas fa-times"></i>
                    </div>
                    <input type="file" class="d-none" accept="image/*" onchange="handleImageSelect(event, '${containerId}', ${index})">
                `;
                slot.onclick = (e) => {
                    if (e.target.closest('.remove-image')) return;
                    slot.querySelector('input').click();
                };
                container.appendChild(slot);
            });
            const addBtn = document.getElementById('add-more-images-btn');
            if (addBtn) addBtn.style.display = state.length < 8 ? 'inline-block' : 'none';
        }

        function handleImageSelect(event, containerId, index) {
            const file = event.target.files[0];
            if (!file) return;
            if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
                Toastify({ text: "Use JPG, PNG or WEBP", backgroundColor: "#ff5f6d" }).showToast();
                return;
            }
            currentModalId = containerId;
            currentSlotIndex = index;
            const reader = new FileReader();
            reader.onload = (e) => {
                const cropperImage = document.getElementById('cropperImage');
                cropperImage.src = e.target.result;
                $('#cropperModal').modal('show');
            };
            reader.readAsDataURL(file);
        }

        $('#cropperModal').on('shown.bs.modal', function () {
            cropper = new Cropper(document.getElementById('cropperImage'), {
                aspectRatio: 1, viewMode: 1, autoCropArea: 1
            });
        }).on('hidden.bs.modal', function () {
            if (cropper) { cropper.destroy(); cropper = null; }
        });

        document.getElementById('cropFinalButton').onclick = function() {
            if (!cropper) return;
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            canvas.toBlob((blob) => {
                const url = URL.createObjectURL(blob);
                const state = productImagesState.get(currentModalId);
                state[currentSlotIndex] = { file: blob, url: url, isOriginal: false };
                renderSlots(currentModalId);
                $('#cropperModal').modal('hide');
            }, 'image/jpeg', 0.9);
        };

        function removeImageSlot(event, containerId, index) {
            event.stopPropagation();
            const state = productImagesState.get(containerId);
            if (state.length <= 3) {
                Toastify({ text: "Min 3 images required", backgroundColor: "#ff5f6d" }).showToast();
                return;
            }
            state.splice(index, 1);
            renderSlots(containerId);
        }

        function addMoreImageSlot(containerId) {
            const state = productImagesState.get(containerId);
            if (state.length >= 8) return;
            state.push({ file: null, url: null, isOriginal: false });
            renderSlots(containerId);
        }

        function validateInput(input, regex, errorId, errorMessage) {
            const errorElement = document.getElementById(errorId);
            let isValid = false;
            const val = input.value.trim();

            if (input.type === 'number') {
                const num = parseFloat(val);
                if (input.name === 'stock') {
                    isValid = !isNaN(num) && num >= 0;
                } else {
                    isValid = !isNaN(num) && num > 0;
                }
            } else if (input.tagName === 'SELECT') {
                isValid = input.value !== "";
            } else {
                const minLen = parseInt(input.getAttribute('minlength')) || 0;
                // For name and description, we validate the TRIMMED value
                isValid = regex.test(val) && val.length >= minLen;
            }

            if (!isValid) {
                errorElement.textContent = errorMessage;
                errorElement.style.display = 'block';
                input.classList.add('is-invalid');
                input.classList.remove('is-valid');
            } else {
                errorElement.style.display = 'none';
                input.classList.remove('is-invalid');
                input.classList.add('is-valid');
            }
            return isValid;
        }

        document.addEventListener('DOMContentLoaded', () => {
            initImageSlots('add-image-slots');
            const form = document.getElementById('addProductForm');
            const nameInp = form.querySelector('[name="name"]');
            const descInp = form.querySelector('[name="description"]');
            const catSel = form.querySelector('[name="category"]');
            const priceInp = form.querySelector('[name="price"]');
            const stockInp = form.querySelector('[name="stock"]');

            const nameRegex = /^[a-zA-Z0-9]+(?:\s[a-zA-Z0-9]+)*$/;
            const descRegex = /^(?!\s+$)[\s\S]*$/;

            nameInp.addEventListener('input', () => validateInput(nameInp, nameRegex, 'name-error', 'Min 3 alphanumeric chars'));
            descInp.addEventListener('input', () => validateInput(descInp, descRegex, 'description-error', 'Min 10 characters required'));
            catSel.addEventListener('change', () => validateInput(catSel, null, 'category-error', 'Select a category'));
            priceInp.addEventListener('input', () => validateInput(priceInp, null, 'price-error', 'Price must be > 0'));
            stockInp.addEventListener('input', () => validateInput(stockInp, null, 'stock-error', 'Stock must be >= 0'));

            document.getElementById('add-more-images-btn').onclick = () => addMoreImageSlot('add-image-slots');

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const state = productImagesState.get('add-image-slots');
                const filledSlots = state.filter(s => s.url);
                if (filledSlots.length < 3) {
                    Toastify({ text: "At least 3 images required", backgroundColor: "#ff5f6d" }).showToast();
                    return;
                }
                const isValid = validateInput(nameInp, nameRegex, 'name-error', 'Min 3 alphanumeric chars') &&
                                validateInput(descInp, descRegex, 'description-error', 'Min 10 chars. Allowed symbols: , . -') &&
                                validateInput(catSel, null, 'category-error', 'Select a category') &&
                                validateInput(priceInp, null, 'price-error', 'Price must be > 0') &&
                                validateInput(stockInp, null, 'stock-error', 'Stock must be >= 0');
                if (!isValid) return;

                Swal.fire({ title: 'Saving Product...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                const formData = new FormData();
                formData.append('name', nameInp.value.trim());
                formData.append('description', descInp.value.trim());
                formData.append('category', catSel.value);
                formData.append('price', priceInp.value);
                formData.append('stock', stockInp.value);
                filledSlots.forEach((slot, i) => {
                    if (slot.file) formData.append('images', slot.file, `prod_${Date.now()}_${i}.jpg`);
                });

                try {
                    const res = await fetch('/admin/products/add', { method: 'POST', body: formData });
                    const data = await res.json();
                    Swal.close();
                    if (data.success) {
                        Swal.fire('Success', 'Product added!', 'success').then(() => window.location.href = '/admin/products');
                    } else {
                        Toastify({ text: data.message || "Error", backgroundColor: "#ff5f6d" }).showToast();
                    }
                } catch (err) {
                    Swal.close();
                    Toastify({ text: "Network error", backgroundColor: "#ff5f6d" }).showToast();
                }
            });
        });
    </script>
</body>
</html>
