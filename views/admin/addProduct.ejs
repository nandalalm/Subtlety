<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - SUBTLETY</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/admin/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">

    <style>
        :root {
            --primary-color: #9135ED;
            --secondary-color: #f3f0ff;
        }
        body { font-family: 'Poppins', sans-serif; }
        .breadcrumb { background: transparent; padding: 0; margin-bottom: 5px; }
        .breadcrumb-item { font-size: 0.95rem; }
        .breadcrumb-item a { color: var(--primary-color); text-decoration: none; }
        .breadcrumb-item.active { color: #6c757d; }
        
        @media (max-width: 768px) {
            .breadcrumb-item { font-size: 0.8rem; }
        }
        
        /* Custom Blue Button for Crop personally verified */
        .btn-blue {
            background-color: #007bff;
            border-color: #007bff;
            color: white;
            border-radius: 10px;
            padding: 10px 25px;
            transition: all 0.3s;
        }
        .btn-blue:hover {
            background-color: #0069d9;
            border-color: #0062cc;
            color: white;
        }
        
        .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .card-header { background: white; border-bottom: 1px solid #eee; padding: 20px; border-radius: 15px 15px 0 0 !important; }
        .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); border-radius: 10px; padding: 10px 25px; }
        .btn-primary:hover { background-color: #7a2bc7; border-color: #7a2bc7; }
        .form-section {
            border: 1px solid #edf0f5;
            border-radius: 14px;
            padding: 1.25rem;
            background: #fff;
            height: 100%;
        }
        .form-section-title { margin-bottom: 1rem; font-size: 1rem; font-weight: 600; color: #212529; }
        
        /* Image Slot System personally verified */
        .image-slots-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }

        .image-slot {
            aspect-ratio: 1;
            border: 2px dashed #ddd;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            cursor: pointer;
            overflow: hidden;
            background: #fafafa;
            transition: all 0.3s ease;
        }

        .image-slot:hover { border-color: var(--primary-color); background: var(--secondary-color); }
        .image-slot img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.3s; }
        
        .image-slot.has-image:hover img { opacity: 0.6; }
        .image-slot.has-image::after {
            content: '\f093'; /* fa-upload */
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 24px;
            color: var(--primary-color);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .image-slot.has-image:hover::after { opacity: 1; }
        
        .image-slot .remove-image {
            position: absolute;
            top: 5px; right: 5px;
            background: rgba(255, 0, 0, 0.7);
            color: white;
            border-radius: 50%;
            width: 24px; height: 24px;
            display: none;
            align-items: center; justify-content: center;
            font-size: 14px; z-index: 10;
        }

        .image-slot.has-image .remove-image { display: flex; }
        .image-slot.has-image .slot-placeholder { display: none; }

        .slot-placeholder { text-align: center; color: #888; }
        .slot-placeholder i { font-size: 24px; margin-bottom: 5px; }
        .slot-placeholder span { font-size: 11px; display: block; }

        /* Cropper Modal High Quality Styles personally verified */
        .cropper-container-wrapper {
            width: 100%;
            height: 500px;
            background: #333;
            overflow: hidden;
        }

        /* Responsive Fixes personally verified */
        @media (max-width: 768px) {
            .image-slots-container { grid-template-columns: repeat(3, 1fr); }
        }

        /* Remove Bootstrap green tick personally verified */
        .form-control.is-valid {
            background-image: none !important;
            border-color: #28a745 !important;
            box-shadow: none !important;
        }
        .form-control.is-invalid {
            background-image: none !important;
            border-color: #dc3545 !important;
            box-shadow: none !important;
        }
        .form-control:focus,
        .btn:focus,
        .btn:active {
            box-shadow: none !important;
        }
        .field-feedback {
            display: none;
            margin-top: 0.35rem;
            font-size: 0.82rem;
            font-weight: 500;
        }
        .field-feedback.is-error {
            display: block;
            color: #dc3545 !important;
        }
        .field-feedback.is-success {
            display: block;
            color: #28a745 !important;
        }
        .image-slot.image-slot-error {
            border-color: #dc3545 !important;
        }
    </style>
</head>
<body class="bg-light">
    <!-- ... same body content ... -->
    <%- include('../partials/Admin/adminNavbar') %>
    <div class="d-flex" id="wrapper">
        <%- include('../partials/Admin/adminSidebar', { activePage: 'products' }) %>

        <div id="page-content-wrapper" class="w-100">
            <div class="container-fluid pt-2 px-1 px-md-3">
                <!-- Breadcrumbs personally verified -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/admin/products">Products</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Add Product</li>
                    </ol>
                </nav>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h4 class="mb-0">Add New Product</h4>
                            </div>
                            <div class="card-body p-4">
                                <form id="addProductForm" novalidate>
                                    <div class="row">
                                        <!-- Basic Info personally verified -->
                                        <div class="col-md-6 mb-4 mb-md-0">
                                            <div class="form-section">
                                            <h5 class="form-section-title">Basic Information</h5>
                                            <div class="form-group mb-4">
                                                <label class="font-weight-600">Product Name</label>
                                                <input type="text" name="name" class="form-control" placeholder="Enter product name" minlength="3">
                                                <small id="name-error" class="field-feedback"></small>
                                            </div>
                                            <div class="form-group mb-4">
                                                <label class="font-weight-600">Category</label>
                                                <select name="category" class="form-control">
                                                    <option value="">Select Category</option>
                                                    <% categories.forEach(cat => { %>
                                                        <option value="<%= cat._id %>"><%= cat.name %></option>
                                                    <% }) %>
                                                </select>
                                                <small id="category-error" class="field-feedback"></small>
                                            </div>
                                            <div class="row">
                                                <div class="col-6">
                                                    <div class="form-group mb-4">
                                                        <label class="font-weight-600">Price (₹)</label>
                                                        <input type="number" name="price" class="form-control" placeholder="0.00" step="0.01">
                                                        <small id="price-error" class="field-feedback"></small>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="form-group mb-4">
                                                        <label class="font-weight-600">Stock</label>
                                                        <input type="number" name="stock" class="form-control" placeholder="0">
                                                        <small id="stock-error" class="field-feedback"></small>
                                                    </div>
                                                </div>
                                            </div>
                                            </div>
                                        </div>

                                        <!-- Description personally verified -->
                                        <div class="col-md-6">
                                            <div class="form-section">
                                            <h5 class="form-section-title">Description</h5>
                                            <div class="form-group mb-0">
                                                <label class="font-weight-600">Description</label>
                                                <textarea name="description" class="form-control" rows="8" placeholder="Enter product description" minlength="10"></textarea>
                                                <small id="description-error" class="field-feedback"></small>
                                            </div>
                                            </div>
                                        </div>

                                        <!-- Images Section personally verified -->
                                        <div class="col-12 mt-4">
                                            <div class="form-section">
                                            <div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
                                            <h5 class="form-section-title mb-0">Product Images <small class="text-muted">(Min 3, Max 8)</small></h5>
                                            <button type="button" class="btn btn-outline-primary btn-sm mt-2 mt-sm-0" id="add-more-images-btn">
                                                <i class="fas fa-plus mr-1"></i> Add More Images
                                            </button>
                                            </div>
                                            <div id="add-image-slots" class="image-slots-container">
                                                <!-- Slots generated by JS personally verified -->
                                            </div>
                                            <div id="image-count-error" class="field-feedback mb-0">You must upload at least 3 images.</div>
                                            
                                            <hr class="my-4">
                                            
                                            <div class="d-flex justify-content-end">
                                                <a href="/admin/products" class="btn btn-light mr-3">Cancel</a>
                                                <button type="submit" class="btn btn-primary">Save Product</button>
                                            </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Simplified Cropper Modal personally verified -->
    <div class="modal fade" id="cropperModal" tabindex="-1" role="dialog" data-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header bg-dark text-white border-0">
                    <h5 class="modal-title">Crop Image</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0">
                    <div class="cropper-container-wrapper">
                        <img id="cropperImage" src="">
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-blue" id="cropFinalButton">Apply Crop</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/Admin/adminScripts') %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <!-- SweetAlert2 and swalHelper are now global via adminScripts partial -->

    <script>
        const productImagesState = new Map();
        const productImageValidationState = new Map();
        const productImageFileErrorState = new Map();
        let cropper = null;
        let currentModalId = null;
        let currentSlotIndex = null;

        function initImageSlots(containerId, existingImages = []) {
            let state = existingImages.map(img => ({
                file: null,
                url: img.startsWith('/') ? img : '/' + img,
                isOriginal: true,
                rawPath: img
            }));
            if (state.length === 0) {
                for (let i = 0; i < 3; i++) state.push({ file: null, url: null, isOriginal: false });
            }
            productImagesState.set(containerId, state);
            if (!productImageValidationState.has(containerId)) {
                productImageValidationState.set(containerId, false);
            }
            if (!productImageFileErrorState.has(containerId)) {
                productImageFileErrorState.set(containerId, null);
            }
            renderSlots(containerId);
        }

        function renderSlots(containerId) {
            const container = document.getElementById(containerId);
            const state = productImagesState.get(containerId);
            container.innerHTML = '';
            state.forEach((item, index) => {
                const slot = document.createElement('div');
                slot.className = `image-slot ${item.url ? 'has-image' : ''}`;
                slot.innerHTML = `
                    <div class="slot-placeholder">
                        <i class="fas fa-camera"></i>
                        <span>${item.url ? 'Change' : 'Add Image'}</span>
                    </div>
                    ${item.url ? `<img src="${item.url}" alt="Preview">` : ''}
                    <div class="remove-image" onclick="removeImageSlot(event, '${containerId}', ${index})">
                        <i class="fas fa-times"></i>
                    </div>
                    <input type="file" class="d-none" accept="image/*" onchange="handleImageSelect(event, '${containerId}', ${index})">
                `;
                slot.onclick = (e) => {
                    if (e.target.closest('.remove-image')) return;
                    slot.querySelector('input').click();
                };
                container.appendChild(slot);
            });
            const addBtn = document.getElementById('add-more-images-btn');
            if (addBtn) addBtn.style.display = state.length < 8 ? 'inline-block' : 'none';
            validateImageCount(containerId);
        }

        function handleImageSelect(event, containerId, index) {
            const file = event.target.files[0];
            if (!file) return;
            if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
                productImageFileErrorState.set(containerId, index);
                validateImageCount(containerId, 3, true, 'Only JPG, PNG, or WEBP images are allowed.');
                event.target.value = '';
                return;
            }
            productImageFileErrorState.set(containerId, null);
            validateImageCount(containerId);
            currentModalId = containerId;
            currentSlotIndex = index;
            const reader = new FileReader();
            reader.onload = (e) => {
                const cropperImage = document.getElementById('cropperImage');
                cropperImage.src = e.target.result;
                $('#cropperModal').modal('show');
            };
            reader.readAsDataURL(file);
        }

        $('#cropperModal').on('shown.bs.modal', function () {
            cropper = new Cropper(document.getElementById('cropperImage'), {
                aspectRatio: 1, viewMode: 1, autoCropArea: 1
            });
        }).on('hidden.bs.modal', function () {
            if (cropper) { cropper.destroy(); cropper = null; }
        });

        document.getElementById('cropFinalButton').onclick = function() {
            if (!cropper) return;
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            canvas.toBlob((blob) => {
                const url = URL.createObjectURL(blob);
                const state = productImagesState.get(currentModalId);
                state[currentSlotIndex] = { file: blob, url: url, isOriginal: false };
                renderSlots(currentModalId);
                $('#cropperModal').modal('hide');
            }, 'image/jpeg', 0.9);
        };

        function removeImageSlot(event, containerId, index) {
            event.stopPropagation();
            const state = productImagesState.get(containerId);
            if (!state || !state[index]) return;
            state[index] = { file: null, url: null, isOriginal: false };
            productImageFileErrorState.set(containerId, null);
            renderSlots(containerId);
            validateImageCount(containerId);
        }

        function addMoreImageSlot(containerId) {
            const state = productImagesState.get(containerId);
            if (state.length >= 8) return;
            state.push({ file: null, url: null, isOriginal: false });
            renderSlots(containerId);
            validateImageCount(containerId);
        }

        function setFieldMessage(errorElement, state, message = '') {
            errorElement.textContent = message;
            errorElement.className = `field-feedback${state ? ` ${state}` : ''}`;
        }

        function validateInput(input, config) {
            const errorElement = document.getElementById(config.errorId);
            const val = input.value.trim();
            let isValid = false;

            if (input.type === 'number') {
                if (!val) {
                    setFieldMessage(errorElement, 'is-error', config.requiredMessage);
                } else {
                    const num = parseFloat(val);
                    const minValue = typeof config.minValue === 'number' ? config.minValue : 0;
                    isValid = !isNaN(num) && num >= minValue;
                    if (!isValid) setFieldMessage(errorElement, 'is-error', config.invalidMessage);
                }
            } else if (input.tagName === 'SELECT') {
                isValid = input.value !== "";
                if (!isValid) setFieldMessage(errorElement, 'is-error', config.requiredMessage);
            } else {
                if (!val) {
                    setFieldMessage(errorElement, 'is-error', config.requiredMessage);
                } else if (typeof config.customValidate === 'function') {
                    const customMessage = config.customValidate(val);
                    if (customMessage) {
                        setFieldMessage(errorElement, 'is-error', customMessage);
                    } else if (config.minLength && val.length < config.minLength) {
                        setFieldMessage(errorElement, 'is-error', config.invalidMessage);
                    } else {
                        isValid = true;
                    }
                } else if (config.regex && !config.regex.test(val)) {
                    setFieldMessage(errorElement, 'is-error', config.invalidMessage);
                } else if (config.minLength && val.length < config.minLength) {
                    setFieldMessage(errorElement, 'is-error', config.invalidMessage);
                } else {
                    isValid = true;
                }
            }

            if (!isValid) {
                input.classList.add('is-invalid');
                input.classList.remove('is-valid');
            } else {
                setFieldMessage(errorElement, '', '');
                input.classList.remove('is-invalid');
                input.classList.add('is-valid');
            }
            return isValid;
        }

        function validateImageCount(containerId, minRequired = 3, showNow = false, customMessage = '') {
            const container = document.getElementById(containerId);
            const state = productImagesState.get(containerId) || [];
            const filledSlots = state.filter(s => s.url);
            const errorElement = document.getElementById('image-count-error');
            const shouldShow = showNow || productImageValidationState.get(containerId);
            const invalidSlotIndex = productImageFileErrorState.get(containerId);

            if (showNow) {
                productImageValidationState.set(containerId, true);
            }

            container.querySelectorAll('.image-slot').forEach((slot) => {
                slot.classList.remove('image-slot-error');
            });

            if (typeof invalidSlotIndex === 'number') {
                const invalidSlot = container.querySelectorAll('.image-slot')[invalidSlotIndex];
                if (invalidSlot) invalidSlot.classList.add('image-slot-error');
                setFieldMessage(errorElement, 'is-error', customMessage || 'Only JPG, PNG, or WEBP images are allowed.');
                return false;
            }

            if (filledSlots.length < minRequired) {
                if (shouldShow) {
                    const missingCount = minRequired - filledSlots.length;
                    let marked = 0;
                    container.querySelectorAll('.image-slot:not(.has-image)').forEach((slot) => {
                        if (marked < missingCount) {
                            slot.classList.add('image-slot-error');
                            marked += 1;
                        }
                    });
                    setFieldMessage(errorElement, 'is-error', `At least ${minRequired} images are required.`);
                } else {
                    setFieldMessage(errorElement, '', '');
                }
                return false;
            }

            setFieldMessage(errorElement, '', '');
            return true;
        }

        document.addEventListener('DOMContentLoaded', () => {
            initImageSlots('add-image-slots');
            const form = document.getElementById('addProductForm');
            const nameInp = form.querySelector('[name="name"]');
            const descInp = form.querySelector('[name="description"]');
            const catSel = form.querySelector('[name="category"]');
            const priceInp = form.querySelector('[name="price"]');
            const stockInp = form.querySelector('[name="stock"]');

            const textRegex = /^[A-Za-z0-9]+(?:\s+[A-Za-z0-9]+)*$/;
            const nameConfig = {
                errorId: 'name-error',
                regex: textRegex,
                minLength: 3,
                requiredMessage: 'Non-empty product name is required.',
                invalidMessage: 'No special characters allowed. Use at least 3 letters or numbers.'
            };
            const descriptionConfig = {
                errorId: 'description-error',
                minLength: 10,
                requiredMessage: 'Non-empty description is required.',
                invalidMessage: 'Use at least 10 characters.',
                customValidate: (value) => /[A-Za-z]/.test(value)
                    ? ''
                    : 'Description must include letters and cannot be only spaces, numbers, or special characters.'
            };
            const categoryConfig = {
                errorId: 'category-error',
                requiredMessage: 'Category is required.'
            };
            const priceConfig = {
                errorId: 'price-error',
                minValue: 0.01,
                requiredMessage: 'Price is required.',
                invalidMessage: 'Price must be greater than 0.'
            };
            const stockConfig = {
                errorId: 'stock-error',
                minValue: 1,
                requiredMessage: 'Stock is required.',
                invalidMessage: 'Stock must be at least 1 for a new product.'
            };

            nameInp.addEventListener('input', () => validateInput(nameInp, nameConfig));
            descInp.addEventListener('input', () => validateInput(descInp, descriptionConfig));
            catSel.addEventListener('change', () => validateInput(catSel, categoryConfig));
            priceInp.addEventListener('input', () => validateInput(priceInp, priceConfig));
            stockInp.addEventListener('input', () => validateInput(stockInp, stockConfig));

            document.getElementById('add-more-images-btn').onclick = () => addMoreImageSlot('add-image-slots');

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const state = productImagesState.get('add-image-slots');
                const filledSlots = state.filter(s => s.url);
                const isValid = [
                                validateInput(nameInp, nameConfig),
                                validateInput(descInp, descriptionConfig),
                                validateInput(catSel, categoryConfig),
                                validateInput(priceInp, priceConfig),
                                validateInput(stockInp, stockConfig),
                                validateImageCount('add-image-slots', 3, true)
                              ].every(Boolean);
                if (!isValid) return;

                const formData = new FormData();
                formData.append('name', nameInp.value.trim());
                formData.append('description', descInp.value.trim());
                formData.append('category', catSel.value);
                formData.append('price', priceInp.value);
                formData.append('stock', stockInp.value);
                filledSlots.forEach((slot, i) => {
                    if (slot.file) formData.append('images', slot.file, `prod_${Date.now()}_${i}.jpg`);
                });

                try {
                    const res = await SwalCustom.withDelayedProcessing(
                        () => fetch('/admin/products/add', { method: 'POST', body: formData }),
                        { title: 'Uploading...', text: 'Please wait while we upload the product images.' }
                    );
                    const data = await res.json();
                    if (data.success) {
                        SwalCustom.success('Success', 'Product added!').then(() => window.location.href = '/admin/products');
                    } else {
                        Toastify({ text: data.message || "Error", backgroundColor: "#ff5f6d" }).showToast();
                    }
                } catch (err) {
                    Toastify({ text: "Network error", backgroundColor: "#ff5f6d" }).showToast();
                }
            });
        });
    </script>
</body>
</html>
