<!DOCTYPE html>
<html lang="en">

<head>
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/admin/login.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

  <style>
    .invalid-feedback {
      display: none;
      color: #dc3545;
      font-size: 80%;
    }

    #loginError {
      display: none;
      color: #dc3545;
      text-align: center;
      margin-top: 10px;
    }

    .password-field-shell {
      position: relative;
    }

    .password-field-shell .form-control {
      padding-right: 3rem;
    }

    .password-toggle-btn {
      position: absolute;
      top: 50%;
      right: 0.8rem;
      transform: translateY(-50%);
      width: 34px;
      height: 34px;
      border: 0;
      background: transparent;
      color: #6b7280;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      transition: color 0.2s ease;
      padding: 0;
      appearance: none;
      -webkit-appearance: none;
    }

    .password-toggle-btn:hover {
      color: #111827;
    }

    .password-toggle-btn:focus,
    .password-toggle-btn:active {
      outline: none;
      box-shadow: none;
      background: transparent !important;
      border-color: transparent !important;
    }
  </style>
</head>

<body>
  <div class="login-container pb-5" style="padding-bottom: 40px !important;">
    <h2 style="color: #9135ED;" class="text-center">SUBTLETY</h2>
    <div id="loginError" class="alert alert-danger" role="alert">
      Incorrect email or password
    </div>

    <form id="loginForm" action="/admin/login" method="post">
      <div class="form-group">
        <label for="email"><small>Email</small></label>
        <input type="email" class="form-control rounded-pill" id="email" name="email" placeholder="Enter email">
        <div class="invalid-feedback" id="emailFeedback"></div>
      </div>
      <div class="form-group password-wrapper">
        <label for="password"><small>Password</small></label>
        <div class="password-field-shell">
          <input type="password" class="form-control rounded-pill" id="password" name="password" placeholder="Enter password">
          <button type="button" class="password-toggle-btn" id="togglePassword" aria-label="Toggle password visibility">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
        <div class="invalid-feedback" id="passwordFeedback"></div>
      </div>
      <button style="background-color: #9135ED;" type="submit" class="btn btn-primary btn-block rounded-pill mt-4">Login</button>
    </form>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script>
    $(document).ready(function() {
      function validateEmail(email) {
        const re = /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
      }

      function validatePassword(password) {
        return password.length >= 6 && !password.includes(' ');
      }

      $('#email').on('input', function() {
        const email = $(this).val().trim();
        if (!validateEmail(email)) {
          $('#emailFeedback').text('Please enter a valid email address').show();
          $(this).removeClass('is-valid').addClass('is-invalid');
        } else {
          $('#emailFeedback').hide();
          $(this).removeClass('is-invalid').addClass('is-valid');
        }
      });

      $('#password').on('input', function() {
        const password = $(this).val();
        if (!validatePassword(password)) {
          $('#passwordFeedback').text('Password must be at least 6 characters long and contain no spaces').show();
          $(this).removeClass('is-valid').addClass('is-invalid');
        } else {
          $('#passwordFeedback').hide();
          $(this).removeClass('is-invalid').addClass('is-valid');
        }
      });

      $('#togglePassword').on('click', function() {
        const passwordInput = $('#password');
        const icon = $(this).find('i');
        const isPassword = passwordInput.attr('type') === 'password';
        
        passwordInput.attr('type', isPassword ? 'text' : 'password');
        icon.toggleClass('fa-eye', !isPassword);
        icon.toggleClass('fa-eye-slash', isPassword);
      });

      $('#loginForm').on('submit', function(e) {
        e.preventDefault();
        const email = $('#email').val().trim();
        const password = $('#password').val();

        // Validate before submitting
        if (validateEmail(email) && validatePassword(password)) {
          $.ajax({
            url: '/admin/login',
            method: 'POST',
            data: {
              email: email,
              password: password
            },
            success: function(response) {
              window.location.href = '/admin/dashboard'; // Redirect on success
            },
            error: function(xhr) {
              $('#loginError').show();
            }
          });
        } else {
          $('#loginError').hide(); // Hide error if validation fails
        }
      });
    });
  </script>
</body>

</html>