<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'users' }) %>

    <div id="page-content-wrapper">
      <div class="container-fluid">

        <!-- Page Heading -->
        <h2 class="mb-4">Users</h2>

        <!-- Search & Sort Bar -->
        <div class="row mb-3 align-items-start">

          <!-- Search -->
          <div class="col-lg-5 col-md-12 mb-2">
            <%- include('../partials/Common/searchBar', {
              searchInputId: 'userSearchInput',
              searchContainerId: 'usersTableContainer',
              searchPlaceholder: 'Search by name or email...',
              searchValue: search || '',
              searchBasePath: 'admin/users'
            }) %>
          </div>

          <!-- Sort/Status Filter -->
          <div class="col-lg-3 col-md-6 mb-2">
            <div class="filter-sort-pill">
              <select id="userSortSelect" onchange="applyAjaxFilter('usersTableContainer', 'sort', this.value, 'admin/users'); document.getElementById('clearUserSortBtn').style.display=this.value!=='latest'?'flex':'none';">
                <option value="latest" <%= !sort || sort === 'latest' ? 'selected' : '' %>>Latest</option>
                <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
                <option disabled>── Status ──</option>
                <option value="active" <%= sort === 'active' ? 'selected' : '' %>>Active Only</option>
                <option value="blocked" <%= sort === 'blocked' ? 'selected' : '' %>>Blocked Only</option>
              </select>
              <button id="clearUserSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                style="display:<%= (sort && sort !== 'latest') ? 'flex' : 'none' %>;"
                onclick="clearAjaxFilter('usersTableContainer', 'sort', 'admin/users'); this.style.display='none'; document.getElementById('userSortSelect').value='latest';">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>

        </div>

        <div id="usersTableContainer">
          <%- include('../partials/Admin/usersTable') %>
        </div>


      </div>
    </div>
  </div>

  <script>
    // AJAX Search, Sort, and Pagination is now handled by /js/ajaxTable.js

    function toggleUserStatus(button) {
      const userId = button.getAttribute('data-user-id');
      const blocked = button.getAttribute('data-blocked') === 'true';
      const action = blocked ? 'unblock' : 'block';

      Swal.fire({
        title: 'Are you sure?',
        text: `Do you want to ${action} this user?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#9135ED',
        cancelButtonColor: '#d33',
        confirmButtonText: `Yes, ${action}!`
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/users/toggle-status/${userId}`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              }
            })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                const isBlocked = data.user.isBlocked;
                
                // Update Desktop and Mobile status badges
                const desktopBadge = document.getElementById(`status-badge-${userId}`);
                const mobileBadge = document.getElementById(`status-badge-mobile-${userId}`);
                
                if (desktopBadge) {
                  desktopBadge.textContent = isBlocked ? 'Blocked' : 'Active';
                  desktopBadge.className = `status-box status-${isBlocked ? 'failed' : 'successful'}`;
                }
                if (mobileBadge) {
                  mobileBadge.textContent = isBlocked ? 'Blocked' : 'Active';
                  mobileBadge.className = `status-box status-${isBlocked ? 'failed' : 'successful'}`;
                }

                // Update ALL toggle buttons for this user (both desktop row and mobile card)
                const buttons = document.querySelectorAll(`button[data-user-id="${userId}"]`);
                buttons.forEach(btn => {
                  btn.textContent = isBlocked ? 'Unblock' : 'Block';
                  btn.setAttribute('data-blocked', isBlocked.toString());
                  btn.className = `btn btn-sm rounded-pill ${isBlocked ? 'btn-outline-success' : 'btn-outline-danger'} ${btn.classList.contains('px-4') ? 'px-4' : 'px-3'}`;
                });

                Swal.fire({
                  icon: 'success',
                  title: 'Updated!',
                  text: `User has been ${isBlocked ? 'blocked' : 'unblocked'}.`,
                  toast: true,
                  position: 'top-end',
                  showConfirmButton: false,
                  timer: 3000
                });
              } else {
                Swal.fire('Error', data.message || 'Could not update status.', 'error');
              }
            })
            .catch(() => Swal.fire('Error', 'Network error. Please try again.', 'error'));
        }
      });
    }
  </script>

  <%- include('../partials/Admin/adminScripts') %>
</body>

</html>