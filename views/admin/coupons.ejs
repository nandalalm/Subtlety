<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coupons - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <style>
    .modal-body .scrollable-select {
      max-height: 150px;
      overflow-y: auto;
    }

    .is-invalid {
      border-color: #dc3545;
      outline-color: #dc3545;
    }

    .is-valid {
      border-color: #28a745;
      outline-color: #28a745;
    }

    .invalid-feedback {
      display: none;
      color: #dc3545;
      font-size: 80%;
    }

    /* Standardized Filter Select Style */
    .filter-select {
        border-radius: 20px;
        padding: 5px 15px;
        border: 1px solid #9135ED !important;
        height: 40px;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background-image: none !important;
        width: 100%;
        cursor: pointer;
    }


    /* Compact Responsive Card Layout */
    .coupon-card {
        display: none;
        background: white;
        border-radius: 12px;
        margin-bottom: 12px;
        padding: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border: 1px solid #eee;
        transition: transform 0.2s ease;
    }

    .coupon-card:hover { transform: translateY(-2px); }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #f8f9fa;
    }

    .card-code {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
    }

    .card-badge {
        padding: 2px 10px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        display: inline-block;
    }

    .badge-active { background: #e8f5e9; color: #2e7d32; }
    .badge-expired { background: #ffebee; color: #c62828; }
    .badge-listed { background: #f3e5f5; color: #7b1fa2; }
    .badge-unlisted { background: #eee; color: #666; }

    .card-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-bottom: 15px;
    }

    .card-item-label {
        font-size: 0.7rem;
        color: #999;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 2px;
        display: block;
    }

    .card-item-value {
        font-size: 0.9rem;
        color: #333;
        font-weight: 600;
    }

    .card-actions {
        display: flex;
        gap: 8px;
    }

    .card-actions .btn {
        flex: 1;
        font-size: 0.85rem;
        padding: 6px;
    }

    @media (max-width: 768px) {
        .table-responsive-custom {
            display: none;
        }
        .coupon-card {
            display: block;
        }
    }

    @media (max-width: 768px) {
        .table-responsive-custom {
            display: none;
        }
        .coupon-card {
            display: block;
        }
    }

    /* Sort Group Styling for Clear Icon */
    .sort-group {
        position: relative;
        display: flex;
        align-items: center;
    }

    .clear-sort {
        position: absolute;
        right: 15px;
        color: #9135ED;
        cursor: pointer;
        font-size: 1rem;
        z-index: 5;
        transition: color 0.2s;
        background: white;
        padding-left: 5px;
    }

    .clear-sort:hover {
        color: #dc3545;
    }
  </style>
</head>

<body class="bg-light text-dark">
  <%- include('partials/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('partials/adminSidebar', { activePage: 'coupons' }) %>

    <div id="page-content-wrapper" class="w-100">
      <div class="container-fluid">
        <h2 class="mb-4">Coupons</h2>
        
        <!-- Search & Filter Bar -->
        <div class="row mb-3 align-items-center">
            <!-- Add Coupon Button -->
            <div class="col-lg-3 col-md-12 mb-3">
                <button type="button" class="btn btn-primary btn-block rounded-pill shadow-sm" data-toggle="modal" data-target="#addCouponModal">
                    <i class="fas fa-plus mr-1"></i> Add New Coupon
                </button>
            </div>

            <!-- Search -->
            <div class="col-lg-5 col-md-12 mb-3">
                <form action="/admin/coupons" method="GET" class="search-group" id="searchForm">
                    <div class="input-group shadow-sm" style="border-radius: 20px; overflow: hidden;">
                        <input type="text" name="search" id="searchInput" class="form-control" placeholder="Search by code..." style="border-radius: 20px 0 0 20px; border: 1px solid #9135ED; height: 40px;" value="<%= typeof search !== 'undefined' ? search : '' %>">
                        <input type="hidden" name="sort" value="<%= sort %>">
                        <div class="input-group-append">
                            <% if (typeof search !== 'undefined' && search) { %>
                            <a href="/admin/coupons?sort=<%= sort %>" class="btn btn-outline-secondary d-flex align-items-center px-2" title="Clear search" style="border-radius:0; border-color: #9135ED; color: #9135ED; height: 40px; border-left: none;">
                                <i class="fas fa-times"></i>
                            </a>
                            <% } %>
                            <button class="btn" type="submit" style="border-radius: 0 20px 20px 0; background-color: #9135ED; border: 1px solid #9135ED; color: white; height: 40px;"><i class="fas fa-search"></i></button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Sort -->
            <div class="col-lg-3 col-md-12 mb-3">
                <div class="sort-group shadow-sm" style="border-radius: 20px;">
                    <select id="couponSort" class="form-control filter-select" onchange="handleSort(this.value)">
                        <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Sort by: Latest</option>
                        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Sort by: Oldest</option>
                        <option value="listed" <%= sort === 'listed' ? 'selected' : '' %>>Status: Listed</option>
                        <option value="unlisted" <%= sort === 'unlisted' ? 'selected' : '' %>>Status: Unlisted</option>
                        <option value="active" <%= sort === 'active' ? 'selected' : '' %>>Status: Active</option>
                        <option value="expired" <%= sort === 'expired' ? 'selected' : '' %>>Status: Expired</option>
                        <option value="flat" <%= sort === 'flat' ? 'selected' : '' %>>Type: Flat Discount</option>
                        <option value="percentage" <%= sort === 'percentage' ? 'selected' : '' %>>Type: Percentage</option>
                    </select>
                    <% if (typeof sort !== 'undefined' && sort !== 'latest') { %>
                        <i class="fas fa-times clear-sort" onclick="handleSort('latest')" title="Clear Sort"></i>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Add Coupon Modal -->
        <div class="modal fade" id="addCouponModal" tabindex="-1" role="dialog" aria-labelledby="addCouponModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-md" role="document">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
              <div class="modal-header bg-light">
                <h5 class="modal-title font-weight-bold" id="addCouponModalLabel">Add New Coupon</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body p-4">
                <form id="addCouponForm" novalidate>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Coupon Code</label>
                    <input type="text" class="form-control" id="code" placeholder="e.g. SUMMER20" required pattern="^[a-zA-Z0-9]*$" title="No spaces or special characters allowed">
                    <div class="invalid-feedback">No spaces or special characters allowed</div>
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Discount Type</label>
                    <select class="form-control" id="addDiscountType" required>
                      <option value="">Select Type</option>
                      <option value="flat">Flat Discount</option>
                      <option value="percentage">Percentage Discount</option>
                    </select>
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Discount Amount</label>
                    <input type="number" class="form-control" id="addDiscountAmount" min="1" required>
                    <div class="invalid-feedback">Required: Percentage (1-80), Flat (Must be < Min Order)</div>
                  </div>
                  <div class="form-group mb-3" id="addMinOrderValueGroup" style="display: none;">
                    <label class="font-weight-bold">Minimum Order Value</label>
                    <input type="number" class="form-control" id="addMinOrderValue" min="0">
                  </div>
                  <div class="form-group mb-3" id="addMaxDiscountGroup" style="display: none;">
                    <label class="font-weight-bold">Maximum Discount</label>
                    <input type="number" class="form-control" id="addMaxDiscount" min="0">
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Expiry Date</label>
                    <input type="date" class="form-control" id="addExpiresAt" required>
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Usage Limit</label>
                    <input type="number" class="form-control" id="addUsageLimit" min="1" required>
                  </div>
                  <div class="modal-footer bg-light px-0 pb-0 pt-3">
                      <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">Close</button>
                      <button type="submit" class="btn btn-primary rounded-pill px-4">Add Coupon</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Edit Coupon Modal -->
        <div class="modal fade" id="editCouponModal" tabindex="-1" role="dialog" aria-labelledby="editCouponModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-md" role="document">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
              <div class="modal-header bg-light">
                <h5 class="modal-title font-weight-bold" id="editCouponModalLabel">Edit Coupon</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body p-4">
                <form id="editCouponForm" novalidate>
                  <input type="hidden" id="editCouponId">
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Coupon Code</label>
                    <input type="text" class="form-control" id="editCode" required pattern="^[a-zA-Z0-9]*$">
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Discount Type</label>
                    <select class="form-control" id="editDiscountType" required>
                      <option value="flat">Flat Discount</option>
                      <option value="percentage">Percentage Discount</option>
                    </select>
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Discount Amount</label>
                    <input type="number" class="form-control" id="editDiscountAmount" required>
                  </div>
                  <div class="form-group mb-3" id="editMinOrderValueGroup" style="display: none;">
                    <label class="font-weight-bold">Minimum Order Value</label>
                    <input type="number" class="form-control" id="editMinOrderValue">
                  </div>
                  <div class="form-group mb-3" id="editMaxDiscountGroup" style="display: none;">
                    <label class="font-weight-bold">Maximum Discount</label>
                    <input type="number" class="form-control" id="editMaxDiscount">
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Expiry Date</label>
                    <input type="date" class="form-control" id="editExpiresAt" required>
                  </div>
                  <div class="form-group mb-3">
                    <label class="font-weight-bold">Usage Limit</label>
                    <input type="number" class="form-control" id="editUsageLimit" required>
                  </div>
                  <div class="modal-footer bg-light px-0 pb-0 pt-3">
                      <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">Close</button>
                      <button type="submit" class="btn btn-primary rounded-pill px-4">Update Coupon</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <% if (coupons.length === 0) { %>
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No coupons found</h4>
        </div>
        <% } else { %>
        <!-- Desktop Table View -->
        <div class="table-responsive-custom bg-white rounded shadow-sm overflow-hidden">
            <table class="table table-hover mb-0">
              <thead class="thead-light">
                <tr>
                  <th style="width: 8%;">S.No</th>
                  <th style="width: 10%;">Code</th>
                  <th style="width: 15%;">Type</th>
                  <th style="width: 15%;">Discount</th>
                  <th style="width: 8%;">Limit</th>
                  <th style="width: 12%;">Expires At</th>
                  <th style="width: 25%;" class="text-center">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% coupons.forEach((coupon, index) => { %>
                <tr>
                  <td><%= (currentPage - 1) * limit + (index + 1) %></td>
                  <td class="font-weight-bold"><%= coupon.code %></td>
                  <td><%= coupon.discountType === 'flat' ? 'Flat' : 'Percentage' %></td>
                  <td>
                    <%= coupon.discountType === 'flat' ? `₹ ${coupon.discountAmount}` : `${coupon.discountAmount} %` %>
                  </td>
                  <td><%= coupon.usageLimit %></td>
                  <td class="<%= new Date(coupon.expiresAt) < new Date() ? 'text-danger font-weight-bold' : '' %>">
                      <%= new Date(coupon.expiresAt).toLocaleDateString() %>
                  </td>
                  <td class="text-center">
                    <button class="btn btn-outline-warning btn-sm rounded-pill px-3 mr-1" 
                            data-coupon='<%= JSON.stringify(coupon) %>' 
                            onclick="openEditCouponModal(this.dataset.coupon)">
                        Edit
                    </button>
                    <button class="btn btn-sm rounded-pill px-3 <%= coupon.isActive ? 'btn-outline-secondary' : 'btn-outline-primary' %>" 
                            data-id="<%= coupon._id %>"
                            data-action="<%= coupon.isActive ? 'unlist' : 'list' %>"
                            onclick="toggleCouponStatus(this.dataset.id, this.dataset.action)">
                      <%= coupon.isActive ? 'Unlist' : 'List' %>
                    </button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
        </div>

        <!-- Premium Mobile Card View -->
        <% coupons.forEach((coupon, index) => { 
            const isExpired = new Date(coupon.expiresAt) < new Date();
        %>
        <div class="coupon-card shadow-sm">
            <div class="card-header-flex">
                <h4 class="card-code"><%= coupon.code %></h4>
                <div class="d-flex align-items-center" style="gap: 4px;">
                    <span class="card-badge <%= isExpired ? 'badge-expired' : 'badge-active' %>">
                        <%= isExpired ? 'Exp' : 'Act' %>
                    </span>
                    <span class="card-badge <%= coupon.isActive ? 'badge-listed' : 'badge-unlisted' %>">
                        <%= coupon.isActive ? 'List' : 'Unlist' %>
                    </span>
                </div>
            </div>
            
            <div class="card-detail-grid">
                <div>
                    <span class="card-item-label">Discount</span>
                    <div class="card-item-value">
                        <%= coupon.discountType === 'flat' ? `₹${coupon.discountAmount}` : `${coupon.discountAmount}%` %>
                    </div>
                </div>
                <div class="text-right">
                    <span class="card-item-label">Type</span>
                    <div class="card-item-value"><%= coupon.discountType === 'flat' ? 'Flat' : 'Perc' %></div>
                </div>
                <div>
                    <span class="card-item-label">Expires</span>
                    <div class="card-item-value <%= isExpired ? 'text-danger' : '' %>">
                        <%= new Date(coupon.expiresAt).toLocaleDateString() %>
                    </div>
                </div>
                <div class="text-right">
                    <span class="card-item-label">Limit</span>
                    <div class="card-item-value"><%= coupon.usageLimit %></div>
                </div>
            </div>
            
            <div class="card-actions">
                <button class="btn btn-outline-warning rounded-pill" 
                        data-coupon='<%= JSON.stringify(coupon) %>' 
                        onclick="openEditCouponModal(this.dataset.coupon)">
                    Edit
                </button>
                <button class="btn rounded-pill <%= coupon.isActive ? 'btn-outline-secondary' : 'btn-outline-primary' %>" 
                        data-id="<%= coupon._id %>"
                        data-action="<%= coupon.isActive ? 'unlist' : 'list' %>"
                        onclick="toggleCouponStatus(this.dataset.id, this.dataset.action)">
                    <%= coupon.isActive ? 'Unlist' : 'List' %>
                </button>
            </div>
        </div>
        <% }) %>

        <%- include('partials/adminPagination') %>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.4/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function handleSort(value) {
        const urlParams = new URLSearchParams(window.location.search);
        urlParams.set('sort', value);
        urlParams.set('page', '1');
        window.location.href = `?${urlParams.toString()}`;
    }

    // Update visibility based on discount type for add modal
    function updateAddDiscountTypeVisibility() {
      const discountType = document.getElementById('addDiscountType').value;
      document.getElementById('addMinOrderValueGroup').style.display = discountType === 'flat' ? 'block' : 'none';
      document.getElementById('addMaxDiscountGroup').style.display = discountType === 'percentage' ? 'block' : 'none';
    }

    // Update visibility based on discount type for edit modal
    function updateEditDiscountTypeVisibility() {
      const discountType = document.getElementById('editDiscountType').value;
      document.getElementById('editMinOrderValueGroup').style.display = discountType === 'flat' ? 'block' : 'none';
      document.getElementById('editMaxDiscountGroup').style.display = discountType === 'percentage' ? 'block' : 'none';
    }

    document.getElementById('addDiscountType').addEventListener('change', updateAddDiscountTypeVisibility);
    document.getElementById('editDiscountType').addEventListener('change', updateEditDiscountTypeVisibility);

    function validateInput(input) {
      if (input.id === 'code' || input.id === 'editCode') {
        if (!/^[a-zA-Z0-9]*$/.test(input.value)) {
          input.setCustomValidity('No leading or trailing spaces and no special characters allowed');
        } else {
          input.setCustomValidity('');
        }
      }

      const isAdd = input.id.startsWith('add');
      const discountAmountId = isAdd ? 'addDiscountAmount' : 'editDiscountAmount';
      const discountTypeId = isAdd ? 'addDiscountType' : 'editDiscountType';

      if (input.id === discountAmountId) {
        const discountType = document.getElementById(discountTypeId).value;
        const minOrderValue = document.getElementById(isAdd ? 'addMinOrderValue' : 'editMinOrderValue').value;

        if (discountType === 'percentage') {
          if (isNaN(input.value) || input.value < 1 || input.value > 80) {
            input.setCustomValidity('Should be between 1 and 80 for percentage.');
          } else {
            input.setCustomValidity('');
          }
        } else if (discountType === 'flat') {
          if (isNaN(input.value) || input.value <= 0) {
            input.setCustomValidity('Discount must be greater than 0.');
          } else if (minOrderValue && Number(input.value) >= Number(minOrderValue)) {
            input.setCustomValidity('Discount must be less than Minimum Order Value.');
          } else {
            input.setCustomValidity('');
          }
        }
      }

      if (input.checkValidity()) {
        input.classList.remove('is-invalid');
        input.classList.add('is-valid');
      } else {
        input.classList.remove('is-valid');
        input.classList.add('is-invalid');
      }
    }

    const inputs = document.querySelectorAll('input, select');
    inputs.forEach(input => {
      input.addEventListener('input', () => validateInput(input));
    });

    document.getElementById('addCouponForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const code = document.getElementById('code').value.trim();
      const expiresAt = document.getElementById('addExpiresAt').value;
      
      if(new Date(expiresAt) < new Date().setHours(0,0,0,0)) {
        return Swal.fire('Error!', 'Must be today or a future date', 'error');
      }

      const discountAmount = document.getElementById('addDiscountAmount').value;
      const discountType = document.getElementById('addDiscountType').value;
      const minOrderValue = document.getElementById('addMinOrderValue').value;

      if (discountType === 'flat' && Number(discountAmount) >= Number(minOrderValue)) {
        return Swal.fire('Error!', 'Flat discount must be less than Minimum Order Value', 'error');
      }

      const body = {
        code,
        discountAmount,
        discountType,
        maxDiscount: document.getElementById('addMaxDiscount').value,
        minOrderValue,
        expiresAt,
        usageLimit: document.getElementById('addUsageLimit').value
      };

      fetch('/admin/coupons/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        })
        .then(res => res.json())
        .then(data => {
            Swal.fire({
                icon: data.success === false ? 'error' : 'success',
                title: data.success === false ? 'Error' : 'Success',
                text: data.message,
                confirmButtonColor: '#007bff'
            }).then(() => { if(data.success !== false) location.reload(); });
        })
        .catch(err => Swal.fire('Error!', 'Network Error', 'error'));
    });

    function openEditCouponModal(couponStr) {
      const coupon = JSON.parse(couponStr);
      document.getElementById('editCouponId').value = coupon._id;
      document.getElementById('editCode').value = coupon.code;
      document.getElementById('editDiscountAmount').value = coupon.discountAmount;
      document.getElementById('editDiscountType').value = coupon.discountType;
      updateEditDiscountTypeVisibility();
      document.getElementById('editMinOrderValue').value = coupon.minOrderValue || '';
      document.getElementById('editMaxDiscount').value = coupon.maxDiscount || '';
      document.getElementById('editExpiresAt').value = new Date(coupon.expiresAt).toISOString().split('T')[0];
      document.getElementById('editUsageLimit').value = coupon.usageLimit;
      $('#editCouponModal').modal('show');
    }

    document.getElementById('editCouponForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const couponId = document.getElementById('editCouponId').value;
      const discountAmount = document.getElementById('editDiscountAmount').value;
      const discountType = document.getElementById('editDiscountType').value;
      const minOrderValue = document.getElementById('editMinOrderValue').value;

      if (discountType === 'flat' && Number(discountAmount) >= Number(minOrderValue)) {
        return Swal.fire('Error!', 'Flat discount must be less than Minimum Order Value', 'error');
      }

      const body = {
        code: document.getElementById('editCode').value.trim(),
        discountAmount,
        discountType,
        maxDiscount: document.getElementById('editMaxDiscount').value,
        minOrderValue,
        expiresAt: document.getElementById('editExpiresAt').value,
        usageLimit: document.getElementById('editUsageLimit').value
      };

      fetch(`/admin/coupons/${couponId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        })
        .then(res => res.json())
        .then(data => {
            Swal.fire({
                icon: data.success === false ? 'error' : 'success',
                title: data.success === false ? 'Error' : 'Success',
                text: data.success === false ? data.message : 'Coupon updated successfully!',
                confirmButtonColor: '#007bff'
            }).then(() => { if(data.success !== false) location.reload(); });
        })
        .catch(err => Swal.fire('Error!', 'Network Error', 'error'));
    });

    function toggleCouponStatus(couponId, action) {
      Swal.fire({
        title: 'Are you sure?',
        text: `Do you want to ${action} this coupon?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes',
        cancelButtonText: 'No'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/coupons/toggle-status/${couponId}`, { method: 'POST' })
            .then(res => res.ok ? location.reload() : Swal.fire('Error', 'Failed', 'error'));
        }
      });
    }
  </script>
  <%- include('partials/adminScripts') %>
</body>
</html>