<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reviews Management - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="/styles/shared/tables.css">
</head>

<body class="bg-light text-dark">
  <%- include('../partials/Admin/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('../partials/Admin/adminSidebar', { activePage: 'reviews' }) %>

    <div id="page-content-wrapper">
      <div class="container-fluid">
        <!-- Page Heading -->
        <h2 class="mb-4" style="font-weight: 600; color: #333;">Reviews Management</h2>

        <!-- Search & Filter Bar -->
        <div class="row mb-3 align-items-center">
            <!-- Search -->
            <div class="col-lg-5 col-md-12 mb-3">
                <%- include('../partials/Common/searchBar', {
                  searchInputId: 'reviewSearchInput',
                  searchContainerId: 'reviewTableContainer',
                  searchPlaceholder: 'Search by name or email...',
                  searchValue: (typeof search !== 'undefined' ? search : '') || '',
                  searchBasePath: 'admin/reviews'
                }) %>
            </div>

            <!-- Sort By -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="filter-sort-pill">
                    <select id="reviewSort" onchange="applyAjaxFilter('reviewTableContainer', 'sort', this.value, 'admin/reviews'); document.getElementById('clearReviewSortBtn').style.display=this.value!=='latest'?'flex':'none';">
                        <option value="latest" <%= sort === 'latest' ? 'selected' : '' %>>Sort by: Latest</option>
                        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Sort by: Oldest</option>
                        <option disabled>── Status ──</option>
                        <option value="listed" <%= sort === 'listed' ? 'selected' : '' %>>Status: Listed</option>
                        <option value="unlisted" <%= sort === 'unlisted' ? 'selected' : '' %>>Status: Unlisted</option>
                    </select>
                    <button id="clearReviewSortBtn" type="button" class="sort-clear-inner" title="Clear sort"
                      style="display:<%= (typeof sort !== 'undefined' && sort !== 'latest') ? 'flex' : 'none' %>;"
                      onclick="clearAjaxFilter('reviewTableContainer', 'sort', 'admin/reviews'); this.style.display='none'; document.getElementById('reviewSort').value='latest';">
                      <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>

            <!-- Filter Rating -->
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="filter-sort-pill">
                    <select id="ratingFilter" onchange="applyAjaxFilter('reviewTableContainer', 'rating', this.value, 'admin/reviews'); document.getElementById('clearRatingFilterBtn').style.display=this.value?'flex':'none';">
                        <option value="" <%= !rating ? 'selected' : '' %>>All Ratings</option>
                        <option value="rating-high" <%= rating === 'rating-high' ? 'selected' : '' %>>High to Low</option>
                        <option value="rating-low" <%= rating === 'rating-low' ? 'selected' : '' %>>Low to High</option>
                    </select>
                    <button id="clearRatingFilterBtn" type="button" class="sort-clear-inner" title="Clear rating"
                        style="display:<%= rating ? 'flex' : 'none' %>;"
                        onclick="clearAjaxFilter('reviewTableContainer', 'rating', 'admin/reviews'); this.style.display='none'; document.getElementById('ratingFilter').value='';">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        <%- include('../partials/Admin/reviewTable') %>

      </div>
    </div>
  </div>

  <%- include('../partials/Admin/adminScripts') %>
  <script>
    // AJAX Search, Sort, and Pagination is now handled by /js/ajaxTable.js

    function toggleReviewStatus(button) {
      const reviewId = button.getAttribute('data-id');
      const isCurrentlyListed = button.getAttribute('data-status') === 'true';
      const action = isCurrentlyListed ? 'unlist' : 'relist';

      SwalCustom.confirm(
        'Confirm Moderation',
        `Are you sure you want to ${action} this review?`,
        `Yes, ${action} it!`,
        'Cancel'
      ).then((result) => {
        if (result.isConfirmed) {
          fetch(`/admin/reviews/toggle-listing/${reviewId}`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            }
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              const isListed = data.review.isListed;
              
              const desktopRow = document.querySelector(`tr[data-row-id="${reviewId}"]`);
              const mobileCard = document.querySelector(`.shared-item-card[data-card-id="${reviewId}"]`);

              if (desktopRow) {
                const desktopBadge = desktopRow.querySelector('.status-box');
                if (desktopBadge) {
                  desktopBadge.textContent = isListed ? 'Listed' : 'Unlisted';
                  desktopBadge.className = `status-box status-${isListed ? 'successful' : 'failed'}`;
                }
              }

              if (mobileCard) {
                const mobileBadge = mobileCard.querySelector('.status-box');
                if (mobileBadge) {
                  mobileBadge.textContent = isListed ? 'Listed' : 'Unlisted';
                  mobileBadge.className = `status-box status-${isListed ? 'successful' : 'failed'}`;
                }
              }

              // Update ALL toggle buttons for this review
              const buttons = document.querySelectorAll(`button[data-id="${reviewId}"]`);
              buttons.forEach(btn => {
                if (btn.classList.contains('toggle-review-btn')) {
                  btn.textContent = isListed ? 'Unlist' : 'Relist';
                  btn.setAttribute('data-status', isListed.toString());
                  btn.className = `btn btn-sm toggle-review-btn rounded-pill table-action-btn ${isListed ? 'table-btn-unlist' : 'table-btn-relist'} ${btn.classList.contains('px-4') ? 'px-4' : 'px-3'}`;
                }
              });

              SwalCustom.success(
                'Updated!',
                `The review has been successfully ${isListed ? 'listed' : 'unlisted'}.`
              );
            } else {
              SwalCustom.error('Error', data.message || 'Failed to update status');
            }
          })
          .catch(() => SwalCustom.error('Error', 'Network error. Please try again.'));
        }
      });
    }

    $(document).ready(function() {
      // Logic handled via onclick toggleReviewStatus(this)
    });
  </script>
</body>
</html>
