<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/png" href="/images/mini-logo-bg-removed.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reviews Management - SUBTLETY</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/admin/dashboard.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  
  <style>
    .star-rating i {
      font-size: 0.85rem;
    }
    .table td {
      vertical-align: middle;
    }
    .review-comment {
      max-width: 250px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      cursor: pointer;
    }
    .review-comment:hover {
      white-space: normal;
      overflow: visible;
      background: #f8f9fa;
      position: absolute;
      z-index: 10;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    /* Responsive Styles */
    @media (max-width: 1199.98px) {
      .review-table-desktop {
        display: none !important;
      }
      .review-cards-mobile {
        display: block !important;
      }
    }

    @media (min-width: 1200px) {
      .review-table-desktop {
        display: block !important;
      }
      .review-cards-mobile {
        display: none !important;
      }
    }

    .review-card {
      background: #fff;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 15px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      border: 1px solid #eee;
    }

    .review-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #f0f0f0;
      padding-bottom: 8px;
      margin-bottom: 10px;
    }

    .review-card-body p {
      margin-bottom: 5px;
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .review-card-footer {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      margin-top: 8px;
      padding-top: 6px;
      border-top: 1px solid #f5f5f5;
    }

    .toggle-review-btn-mobile {
      width: 120px;
      font-size: 0.85rem;
      font-weight: 500;
    }
  </style>
</head>

<body class="bg-light text-dark">
  <%- include('partials/adminNavbar') %>
  <div class="d-flex" id="wrapper">
    <%- include('partials/adminSidebar', { activePage: 'reviews' }) %>

    <div id="page-content-wrapper">
      <div class="container-fluid">
        <!-- Page Heading -->
        <h2 class="mb-4" style="font-weight: 600; color: #333;">Reviews Management</h2>

        <!-- Card shadows and card-body padding removed for better integration of responsive views -->
        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden; background: transparent;">
          <div class="card-body p-0">
            <!-- Desktop Table View -->
            <div class="table-responsive review-table-desktop">
              <table class="table table-hover mb-0 bg-white">
                <thead  class="thead-light">
                  <tr>
                    <th>S.No</th>
                    <th class="px-4">Reviewer</th>
                    <th>Product</th>
                    <th>Rating</th>
                    <th>Review</th>
                    <th>Date</th>
                    <th class="text-center px-4">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach((review, index) => { %>
                      <tr>
                        <td><%= (currentPage - 1) * limit + (index + 1) %></td>
                        <td class="px-4">
                          <div class="font-weight-600 text-dark"><%= review.userId.firstname %></div>
                          <small class="text-muted"><%= review.userId.email %></small>
                        </td>
                        <td>
                          <div class="font-weight-600 text-dark"><%= review.productId.name %></div>
                        </td>
                        <td>
                          <div class="star-rating text-warning">
                            <% for(let i=1; i<=5; i++) { %>
                              <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                            <% } %>
                          </div>
                        </td>
                        <td>
                          <div class="review-comment text-muted" title="Click to expand">
                            <%= review.comment || 'No review' %>
                          </div>
                        </td>
                        <td class="text-muted small">
                          <%= new Date(review.createdAt).toLocaleDateString('en-GB') %>
                        </td>
                        <td class="text-center px-4">
                          <button class="btn btn-sm toggle-review-btn <%= review.isListed ? 'btn-outline-danger' : 'btn-outline-success' %> rounded-pill px-3" 
                                  data-id="<%= review._id %>" 
                                  data-status="<%= review.isListed %>"
                                  style="min-width: 85px; font-weight: 500;">
                            <%= review.isListed ? 'Unlist' : 'List' %>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="7" class="text-center py-5">
                        <div class="py-4">
                          <i class="fas fa-comment-slash fa-4x text-muted mb-3 opacity-25"></i>
                          <h5 class="text-muted">No reviews to moderate yet.</h5>
                          <p class="text-muted small">When users rate products, they will appear here.</p>
                        </div>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>

            <!-- Mobile Card View -->
            <div class="review-cards-mobile px-2">
              <% if (reviews && reviews.length > 0) { %>
                <% reviews.forEach((review, index) => { %>
                  <div class="review-card">
                    <div class="review-card-header">
                      <span class="font-weight-bold text-dark">#<%= (currentPage - 1) * limit + (index + 1) %></span>
                      <span class="badge <%= review.isListed ? 'badge-success' : 'badge-danger' %>">
                        <%= review.isListed ? 'Listed' : 'Unlisted' %>
                      </span>
                    </div>
                    <div class="review-card-body">
                      <p><strong>Product:</strong> <%= review.productId.name %> | <strong>Rating:</strong> 
                        <span class="text-warning">
                          <% for(let i=1; i<=5; i++) { %>
                            <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                          <% } %>
                        </span>
                      </p>
                      <p><strong>Review:</strong> <span class="text-muted"><%= review.comment || 'No review' %></span></p>
                      <p class="small text-muted mb-0"><%= new Date(review.createdAt).toLocaleDateString('en-GB') %></p>
                    </div>
                    <div class="review-card-footer">
                      <button class="btn toggle-review-btn toggle-review-btn-mobile <%= review.isListed ? 'btn-outline-danger' : 'btn-outline-success' %> rounded-pill" 
                              data-id="<%= review._id %>" 
                              data-status="<%= review.isListed %>">
                        <%= review.isListed ? 'Unlist' : 'List' %>
                      </button>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="text-center py-5 bg-white rounded shadow-sm">
                  <i class="fas fa-comment-slash fa-3x text-muted mb-3 opacity-25"></i>
                  <h5 class="text-muted">No reviews found</h5>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Pagination -->
        <% if (reviews && reviews.length > 0) { %>
          <div class="mt-2 d-flex justify-content-center">
            <%- include('partials/adminPagination', { currentPage: currentPage, totalPages: totalPages }) %>
          </div>
        <% } %>

      </div>
    </div>
  </div>

  <%- include('partials/adminScripts') %>
  <script>
    $(document).ready(function() {
      // Toggle Review Display status
      $('.toggle-review-btn').on('click', function() {
        const btn = $(this);
        const reviewId = btn.data('id');
        const isCurrentlyListed = btn.data('status');
        const action = isCurrentlyListed ? 'unlist' : 'list';
        Swal.fire({
          title: `Confirm Moderation`,
          text: `Are you sure you want to ${action} this review?`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#3085d6',
          cancelButtonColor: '#6c757d',
          confirmButtonText: `Yes, ${action} it!`
        }).then((result) => {
          if (result.isConfirmed) {
            $.ajax({
              url: `/admin/reviews/toggle-listing/${reviewId}`,
              method: 'POST',
              success: function(response) {
                if (response.success) {
                  Swal.fire({
                    icon: 'success',
                    title: 'Updated!',
                    text: `The review has been successfully ${action}ed.`,
                    timer: 1500,
                    showConfirmButton: false
                  }).then(() => {
                    location.reload();
                  });
                } else {
                  Swal.fire('Error', response.message || 'Failed to update status', 'error');
                }
              },
              error: function() {
                Swal.fire('Error!', 'A server error occurred. Please try again.', 'error');
              }
            });
          }
        });
      });
    });
  </script>
</body>
</html>
